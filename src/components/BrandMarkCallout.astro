---
import Button from './Button.astro';

interface Props {
  variant?: 'journal' | '404';
}

const { variant = 'journal' } = Astro.props;

const copy = {
  journal: {
    headline: "Your words, hand-painted on wood. On your wall this week.",
    body: "Tell me what you want painted: your logo, your name, a phrase that matters to your business. I hand-paint it on a wood panel up to 16 square feet and finish it however you want. $500 includes installation, a protective topcoat, and $500 in credit toward any future project.",
  },
  '404': {
    headline: "Your words, hand-painted on wood. On your wall this week.",
    body: "Tell me what you want painted: your logo, your name, a phrase that matters to your business. I hand-paint it on a wood panel up to 16 square feet and finish it however you want. $500 includes installation, a protective topcoat, and $500 in credit toward any future project.",
  },
};

const { headline, body } = copy[variant];
---

<aside class="bg-midnight-graphite border border-slate-gray px-6 py-10 lg:px-10 lg:py-12">
  <div class="max-w-xl mx-auto text-center">
    <p class="font-mono text-smoke-gray uppercase mb-4" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
      The Brand Mark / Starting at $500
    </p>
    <h3 class="font-heading text-titanium-white mb-4" style="font-size: var(--text-fluid-2xl); line-height: var(--leading-tight);">
      {headline}
    </h3>
    <p class="font-body text-soft-gray mb-8" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
      {body}
    </p>
    <Button href="/brand-mark" variant="primary" size="default">
      Claim Your Brand Mark
    </Button>
  </div>
</aside>
