---
import Button from './Button.astro';

interface Props {
  headline?: string;
  description?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  trustLine?: string;
  backgroundImage?: string;
}

const {
  headline = "Let's figure out what belongs on your wall.",
  description = 'Free site visit. You see the design before we start. Richmond, VA and surrounding areas.',
  primaryHref = '/contact',
  primaryLabel = 'Schedule Your Free Discovery Session',
  secondaryHref = '/murals',
  secondaryLabel = 'See Our Work',
  trustLine = '',
  backgroundImage,
} = Astro.props;
---

<section class:list={["section-rule py-24 lg:py-32 px-6 lg:px-12", backgroundImage && "overflow-hidden"]}>
  {backgroundImage && (
    <div class="absolute inset-0" aria-hidden="true">
      <img
        src={backgroundImage}
        alt=""
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-bone-black/80"></div>
    </div>
  )}
  <div class="relative z-10 max-w-4xl mx-auto text-center" data-animate="fade">
    <h2
      class="font-heading text-titanium-white mb-6"
      style="font-size: var(--text-fluid-3xl); line-height: var(--leading-tight);"
    >
      {headline}
    </h2>
    {description && (
      <p
        class="font-body text-soft-gray mb-10 max-w-2xl mx-auto"
        style="font-size: var(--text-fluid-lg);"
      >
        {description}
      </p>
    )}
    <div class="flex flex-wrap items-center justify-center gap-6 mb-8">
      <Button href={primaryHref} variant="primary">{primaryLabel}</Button>
      <Button href={secondaryHref} variant="ghost">{secondaryLabel}</Button>
    </div>
    {trustLine && (
      <p
        class="font-mono text-smoke-gray uppercase"
        style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
      >
        {trustLine}
      </p>
    )}
  </div>
</section>
