---
import Button from './Button.astro';
---

<footer class="footer-c mt-auto" role="contentinfo">
  <!-- Editorial masthead band -->
  <div class="footer-c-masthead" aria-hidden="true">
    <div class="footer-c-masthead-inner">
      <span class="footer-c-masthead-mark">UMM</span>
      <div class="footer-c-masthead-meta">
        <span class="footer-c-masthead-dot"></span>
        <span>Colophon</span>
        <span class="footer-c-masthead-sep">/</span>
        <span>Richmond, VA</span>
        <span class="footer-c-masthead-sep">/</span>
        <span>37.5407&deg; N &nbsp;77.4360&deg; W</span>
      </div>
    </div>
  </div>

  <div class="footer-c-body mx-auto max-w-7xl px-6 lg:px-12">
    <!-- Link Columns -->
    <nav aria-label="Footer navigation" class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <!-- Work -->
      <div>
        <p class="footer-c-eyebrow">Work</p>
        <ul>
          <li class="mb-3"><a href="/murals" class="font-body text-shadow-gray hover:text-titanium-white transition-colors block" style="font-size: var(--text-fluid-sm);">Murals</a></li>
          <li class="mb-3"><a href="/hand-painted-signs" class="font-body text-shadow-gray hover:text-titanium-white transition-colors block" style="font-size: var(--text-fluid-sm);">Hand-Painted Signs</a></li>
          <li class="mb-3"><a href="/brand-mark" class="font-body text-shadow-gray hover:text-titanium-white transition-colors block" style="font-size: var(--text-fluid-sm);">Brand Mark</a></li>
          <li class="mb-3"><a href="/work" class="font-body text-shadow-gray hover:text-titanium-white transition-colors block" style="font-size: var(--text-fluid-sm);">Case Studies</a></li>
        </ul>
      </div>

      <!-- Tools -->
      <div>
        <p class="footer-c-eyebrow">Tools</p>
        <ul>
          <li class="mb-3"><a href="/mural-cost-estimator" class="font-body text-shadow-gray hover:text-titanium-white transition-colors block" style="font-size: var(--text-fluid-sm);">Mural Cost Estimator</a></li>
          <li class="mb-3"><a href="/brand-mark/claim" class="font-body text-shadow-gray hover:text-titanium-white transition-colors block" style="font-size: var(--text-fluid-sm);">Claim a Brand Mark</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="footer-c-eyebrow">Contact</p>
        <ul>
          <li class="mb-3"><a href="/contact" class="font-body text-shadow-gray hover:text-titanium-white transition-colors block" style="font-size: var(--text-fluid-sm);">Request a Site Visit</a></li>
          <li class="mb-3"><a href="mailto:hello@untitledmixedmedia.com" class="font-body text-shadow-gray hover:text-titanium-white transition-colors block" style="font-size: var(--text-fluid-sm);">hello@untitledmixedmedia.com</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <p class="footer-c-eyebrow">Richmond, by hand.</p>
        <p class="font-body text-shadow-gray mb-4" style="font-size: var(--text-fluid-sm);">
          Quarterly updates on new projects, public art in Richmond, and what we're painting next.
        </p>
        <form class="flex flex-col sm:flex-row gap-2" action="#" method="POST" data-newsletter-form aria-label="Newsletter signup">
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            aria-label="Email address"
            required
            autocomplete="email"
            class="flex-1 bg-transparent border border-slate-gray px-4 py-2.5 font-mono text-titanium-white placeholder:text-smoke-gray focus:border-soft-gray focus:outline-none transition-colors"
            style="font-size: var(--text-fluid-xs);"
          />
          <Button type="submit" variant="primary" size="compact" icon="none">
            Join
          </Button>
        </form>
      </div>
    </nav>

    <!-- Philosophy -->
    <div class="footer-c-philosophy max-w-2xl mb-12">
      <div class="footer-c-rule" aria-hidden="true"></div>
      <p class="footer-c-quote">
        Meaning discovered, <span class="italic-accent">not imposed.</span>
      </p>
      <p class="footer-c-philo-body">
        I don't decide what goes on your wall. I find out. Hand-painted murals and signs in Richmond, Virginia.
      </p>
    </div>

    <!-- Info Row -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 pt-8 border-t border-slate-gray">
      <div class="font-sans text-shadow-gray tracking-wide" style="font-size: var(--text-fluid-xs);">
        <p>Based in Richmond, Virginia</p>
        <p>
          <a href="mailto:hello@untitledmixedmedia.com" class="hover:text-titanium-white transition-colors">
            hello@untitledmixedmedia.com
          </a>
        </p>
      </div>

      <!-- Social -->
      <div class="flex items-center gap-6">
        <a
          href="https://www.instagram.com/untitledmixedmedia/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-shadow-gray hover:text-titanium-white transition-colors"
          aria-label="Untitled Mixed Media on Instagram"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/untitledmixedmedia"
          target="_blank"
          rel="noopener noreferrer"
          class="text-shadow-gray hover:text-titanium-white transition-colors"
          aria-label="Untitled Mixed Media on Facebook"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Copyright + Legal -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mt-8">
      <p class="font-sans text-smoke-gray tracking-wide" style="font-size: var(--text-fluid-xs);">
        &copy; 2026 Untitled Mixed Media LLC. All rights reserved.
      </p>
      <nav aria-label="Legal" class="flex items-center gap-6">
        <a href="/privacy" class="font-sans text-smoke-gray tracking-wide hover:text-titanium-white transition-colors" style="font-size: var(--text-fluid-xs);">Privacy</a>
        <a href="/terms" class="font-sans text-smoke-gray tracking-wide hover:text-titanium-white transition-colors" style="font-size: var(--text-fluid-xs);">Terms</a>
      </nav>
    </div>
  </div>

  <style>
    .footer-c {
      background: var(--color-bone-black);
      border-top: 1px solid rgba(238, 236, 233, 0.08);
      position: relative;
    }
    .footer-c-masthead {
      border-bottom: 1px solid rgba(238, 236, 233, 0.06);
      padding-block: clamp(2.5rem, 5vw, 4rem);
      padding-inline: clamp(1.5rem, 3vw, 3rem);
      overflow: hidden;
    }
    .footer-c-masthead-inner {
      max-width: 1280px;
      margin-inline: auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-6);
      flex-wrap: wrap;
    }
    .footer-c-masthead-mark {
      font-family: var(--font-blackletter);
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      line-height: 0.95;
      color: var(--color-titanium-white);
      letter-spacing: 0.01em;
    }
    .footer-c-masthead-meta {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(238, 236, 233, 0.55);
    }
    .footer-c-masthead-dot {
      width: 7px; height: 7px; border-radius: 999px;
      background: var(--color-editorial-accent);
      box-shadow: 0 0 0 3px rgba(228, 26, 28, 0.18);
    }
    .footer-c-masthead-sep { color: rgba(238, 236, 233, 0.3); }
    .footer-c-body {
      padding-top: clamp(3rem, 6vw, 5rem);
      padding-bottom: clamp(3rem, 6vw, 5rem);
    }
    .footer-c-eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(238, 236, 233, 0.72);
      margin-bottom: var(--space-6);
      display: inline-flex;
      align-items: baseline;
      gap: 10px;
    }
    .footer-c-eyebrow-num {
      color: var(--color-editorial-accent);
      font-weight: 600;
    }
    .footer-c-philosophy { padding-top: var(--space-8); }
    .footer-c-rule {
      width: 40px;
      height: 2px;
      background: var(--color-editorial-accent);
      margin-bottom: var(--space-5);
    }
    .footer-c-quote {
      font-family: var(--font-heading);
      color: var(--color-titanium-white);
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      line-height: 1.15;
      letter-spacing: -0.015em;
      font-weight: 500;
      margin-bottom: var(--space-4);
      max-width: 22ch;
    }
    .footer-c-philo-body {
      font-family: var(--font-body);
      color: rgba(238, 236, 233, 0.65);
      font-size: var(--text-fluid-sm);
      line-height: 1.55;
      max-width: 52ch;
    }
    @media (max-width: 640px) {
      .footer-c-masthead-inner { flex-direction: column; align-items: flex-start; }
      .footer-c-masthead-meta { font-size: 10px; letter-spacing: 0.2em; }
    }
  </style>
</footer>
