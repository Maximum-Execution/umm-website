---
import Button from './Button.astro';

type NavChild = { label: string; href: string };
type NavLink = { label: string; href: string; children?: NavChild[] };

const navLinks: NavLink[] = [
  {
    label: 'Work',
    href: '/work',
    children: [
      { label: 'Murals', href: '/murals' },
      { label: 'Hand-Painted Signs', href: '/hand-painted-signs' },
      { label: 'Brand Mark', href: '/brand-mark' },
    ],
  },
  { label: 'Contact', href: '/contact' },
];
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-titanium-white focus:text-bone-black focus:px-4 focus:py-2 focus:font-sans focus:text-sm focus:font-medium focus:tracking-[0.15em] focus:uppercase">
  Skip to content
</a>
<header class="nav-c fixed top-0 left-0 right-0 z-50" id="main-nav">
  <div class="nav-c-meta" aria-hidden="true">
    <span class="nav-c-meta-item">
      <span class="nav-c-meta-dot"></span>
      Richmond, Virginia
    </span>
    <span class="nav-c-meta-item nav-c-meta-item--center">Untitled Mixed Media LLC</span>
    <span class="nav-c-meta-item nav-c-meta-item--right">Est. 2019</span>
  </div>
  <nav aria-label="Main navigation" class="nav-c-row mx-auto max-w-7xl px-6 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="nav-c-logo">
      <span class="nav-c-logo-blackletter">untitled</span><span class="nav-c-logo-serif"> mixed media</span>
    </a>

    <!-- Desktop Nav + CTA (right-aligned group) -->
    <div class="hidden lg:flex items-center gap-8">
    <ul class="flex items-center gap-8">
      {navLinks.map((link) => (
        <li class="relative group">
          <a
            href={link.href}
            class="font-sans text-titanium-white text-sm tracking-[0.15em] uppercase hover:text-light-ash transition-colors inline-flex items-center gap-1.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-titanium-white focus-visible:ring-offset-2 focus-visible:ring-offset-bone-black"
            aria-haspopup={link.children ? 'true' : undefined}
            aria-expanded={link.children ? 'false' : undefined}
          >
            {link.label}
            {link.children && (
              <svg class="w-2.5 h-2.5 opacity-70 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
          {link.children && (
            <ul
              class="absolute top-full left-0 min-w-[13rem] bg-bone-black/95 backdrop-blur-md border border-slate-gray py-3 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto group-focus-within:opacity-100 group-focus-within:pointer-events-auto transition-opacity duration-200"
              role="menu"
              aria-label={`${link.label} submenu`}
            >
              {link.children.map((child) => (
                <li role="none">
                  <a
                    href={child.href}
                    role="menuitem"
                    class="block px-5 py-2.5 font-sans text-titanium-white text-xs tracking-[0.15em] uppercase hover:text-light-ash hover:bg-midnight-graphite transition-colors whitespace-nowrap focus-visible:outline-none focus-visible:bg-midnight-graphite focus-visible:text-titanium-white"
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <Button
      href="/mural-cost-estimator"
      variant="primary"
      size="compact"
      icon="none"
    >
      Get a Price Estimate
    </Button>
    </div>

    <!-- Mobile Menu Button -->
    <button
      type="button"
      class="lg:hidden text-titanium-white p-2.5"
      id="mobile-menu-btn"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="menu-icon" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="close-icon" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <style>
    .nav-c {
      background: rgba(0, 2, 5, 0.72);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(238, 236, 233, 0.08);
      transition: background-color 200ms ease, border-color 200ms ease;
    }
    .nav-c.is-scrolled {
      background: rgba(0, 2, 5, 0.94);
      border-bottom-color: rgba(238, 236, 233, 0.14);
    }
    .nav-c-meta {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      align-items: center;
      gap: var(--space-4);
      padding: 8px clamp(1.5rem, 3vw, 3rem);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(238, 236, 233, 0.55);
      border-bottom: 1px solid rgba(238, 236, 233, 0.06);
    }
    .nav-c-meta-item { display: inline-flex; align-items: center; gap: 8px; }
    .nav-c-meta-item--center { justify-self: center; }
    .nav-c-meta-item--right { justify-self: end; }
    .nav-c-meta-dot {
      width: 6px; height: 6px; border-radius: 999px;
      background: var(--color-editorial-accent);
      box-shadow: 0 0 0 3px rgba(228, 26, 28, 0.15);
    }
    .nav-c-row { padding-block: 18px; }
    .nav-c-logo {
      color: var(--color-titanium-white);
      text-decoration: none;
      letter-spacing: 0.01em;
      display: inline-flex;
      align-items: baseline;
      gap: 2px;
      transition: opacity 200ms ease;
    }
    .nav-c-logo:hover { opacity: 0.82; }
    .nav-c-logo-blackletter {
      font-family: var(--font-blackletter);
      font-size: 22px;
      line-height: 1;
    }
    .nav-c-logo-serif {
      font-family: var(--font-heading);
      font-weight: 400;
      font-style: italic;
      font-size: 17px;
      letter-spacing: -0.005em;
    }
    @media (max-width: 768px) {
      .nav-c-meta { grid-template-columns: 1fr 1fr; padding: 6px clamp(1rem, 3vw, 1.5rem); font-size: 9px; letter-spacing: 0.2em; }
      .nav-c-meta-item--center { display: none; }
      .nav-c-logo-serif { font-size: 15px; }
    }
  </style>

  <!-- Mobile Menu -->
  <div class="hidden lg:hidden bg-bone-black/95 backdrop-blur-md border-t border-slate-gray" id="mobile-menu" role="region" aria-label="Mobile navigation">
    <ul class="flex flex-col items-center gap-6 py-8">
      {navLinks.map((link) => (
        <li class="flex flex-col items-center gap-4">
          <a
            href={link.href}
            class="font-sans text-titanium-white text-base tracking-[0.15em] uppercase hover:text-light-ash transition-colors focus-visible:outline-none focus-visible:underline focus-visible:underline-offset-4"
          >
            {link.label}
          </a>
          {link.children && (
            <ul class="flex flex-col items-center gap-3" aria-label={`${link.label} submenu`}>
              {link.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class="font-sans text-soft-gray text-xs tracking-[0.2em] uppercase hover:text-titanium-white transition-colors focus-visible:outline-none focus-visible:text-titanium-white focus-visible:underline focus-visible:underline-offset-4"
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <div class="flex justify-center pb-8">
      <Button href="/mural-cost-estimator" variant="primary" size="default">
        Get a Price Estimate
      </Button>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  const nav = document.getElementById('main-nav');

  function getFocusableElements(): HTMLElement[] {
    if (!menu) return [];
    const menuItems = Array.from(
      menu.querySelectorAll<HTMLElement>('a[href], button, [tabindex]:not([tabindex="-1"])')
    );
    // Include the close/toggle button (outside #mobile-menu) in the trap cycle
    if (btn) menuItems.unshift(btn as HTMLElement);
    return menuItems;
  }

  function trapFocus(e: KeyboardEvent): void {
    if (e.key !== 'Tab') return;
    const focusable = getFocusableElements();
    if (focusable.length === 0) return;

    const first = focusable[0];
    const last = focusable[focusable.length - 1];

    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
    } else {
      if (document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  }

  function openMenu(): void {
    menu?.classList.remove('hidden');
    menuIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    btn?.setAttribute('aria-expanded', 'true');
    document.addEventListener('keydown', trapFocus);
    // Focus first link after menu opens
    requestAnimationFrame(() => {
      const focusable = getFocusableElements();
      if (focusable.length > 0) focusable[0].focus();
    });
  }

  function closeMenu(): void {
    menu?.classList.add('hidden');
    menuIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    document.removeEventListener('keydown', trapFocus);
    btn?.focus();
  }

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
    }
  });

  // Update aria-expanded on desktop Work dropdown
  document.querySelectorAll<HTMLElement>('[aria-haspopup="true"]').forEach((trigger) => {
    const li = trigger.closest('li');
    if (!li) return;
    const update = () => {
      const submenu = li.querySelector('ul[role="menu"]');
      if (!submenu) return;
      const visible = window.getComputedStyle(submenu).opacity !== '0';
      trigger.setAttribute('aria-expanded', String(visible));
    };
    li.addEventListener('mouseenter', () => { trigger.setAttribute('aria-expanded', 'true'); });
    li.addEventListener('mouseleave', () => { trigger.setAttribute('aria-expanded', 'false'); });
    li.addEventListener('focusin', () => { trigger.setAttribute('aria-expanded', 'true'); });
    li.addEventListener('focusout', (e) => {
      if (!li.contains((e as FocusEvent).relatedTarget as Node)) {
        trigger.setAttribute('aria-expanded', 'false');
      }
    });
  });

  // Nav background on scroll. Hysteresis prevents class churn near
  // the threshold and limits DOM writes to true state transitions.
  // Engage backdrop at scrollY > 50, release at scrollY < 20.
  let ticking = false;
  let isScrolled = false;
  window.addEventListener('scroll', () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      if (!isScrolled && y > 50) {
        nav?.classList.add('is-scrolled');
        isScrolled = true;
      } else if (isScrolled && y < 20) {
        nav?.classList.remove('is-scrolled');
        isScrolled = false;
      }
      ticking = false;
    });
  }, { passive: true });
</script>
