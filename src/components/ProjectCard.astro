---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, cover, tags } = project.data;
---

<a
  href={`/work/${project.id}`}
  class="group block bg-midnight-graphite overflow-hidden hover:bg-slate-gray/50 transition-colors duration-300"
>
  <div class="aspect-[4/3] overflow-hidden">
    <img
      src={cover}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>

  <div class="p-6">
    <h3 class="font-heading text-[var(--text-fluid-xl)] text-titanium-white mb-2 group-hover:text-soft-gray transition-colors">
      {title}
    </h3>
    <p class="text-[var(--text-fluid-sm)] text-shadow-gray mb-4 line-clamp-2">
      {description}
    </p>
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-[var(--text-fluid-xs)] text-smoke-gray border border-slate-gray px-2.5 py-0.5 uppercase tracking-wider">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
