---
interface Props {
  id?: string;
  class?: string;
  background?: 'default' | 'elevated' | 'accent';
  narrow?: boolean;
}

const {
  id,
  class: className = '',
  background = 'default',
  narrow = false,
} = Astro.props;

const bgClasses = {
  default: '',
  elevated: 'bg-midnight-graphite',
  accent: 'bg-slate-gray',
};
---

<section
  id={id}
  class:list={[
    'py-[var(--spacing-section)]',
    bgClasses[background],
    className,
  ]}
>
  <div class:list={['mx-auto px-6 lg:px-12', narrow ? 'max-w-3xl' : 'max-w-7xl']}>
    <slot />
  </div>
</section>
