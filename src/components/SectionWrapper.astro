---
/**
 * SectionWrapper — canonical section primitive.
 *
 * Handles vertical rhythm (mobile 64px / desktop 96px by default), horizontal
 * gutters (24px / 48px), and max-width. Three width tiers:
 *
 *   wide     (max-w-7xl, 1280px) — full-bleed grids, portfolio, journal index
 *   content  (max-w-5xl, 1024px) — most section content (default)
 *   prose    (max-w-[65ch])      — long-form reading (about, case study body)
 *
 * Three spacing modes:
 *   default — 64px mobile / 96px desktop
 *   major   — 96px mobile / 128px desktop (hero boundary, footer boundary)
 *   compact — 40px mobile / 64px desktop (dense sequences, footers-inside-pages)
 */

interface Props {
  id?: string;
  class?: string;
  background?: 'default' | 'elevated' | 'accent';
  width?: 'wide' | 'content' | 'prose';
  spacing?: 'default' | 'major' | 'compact';
  /** Keep this for back-compat with existing callers that pass narrow={true}. */
  narrow?: boolean;
}

const {
  id,
  class: className = '',
  background = 'default',
  width,
  spacing = 'default',
  narrow,
} = Astro.props;

// Back-compat: narrow={true} maps to width='prose'
const resolvedWidth = width ?? (narrow ? 'prose' : 'content');

const bgClasses = {
  default: '',
  elevated: 'bg-midnight-graphite',
  accent: 'bg-slate-gray',
};

const widthClasses = {
  wide:    'max-w-7xl',
  content: 'max-w-5xl',
  prose:   'max-w-[65ch]',
};

const spacingClasses = {
  default: 'py-[var(--spacing-section-mobile)] md:py-[var(--spacing-section)]',
  major:   'py-[var(--spacing-section)] md:py-[var(--spacing-section-major)]',
  compact: 'py-10 md:py-16',
};
---

<section
  id={id}
  class:list={[spacingClasses[spacing], bgClasses[background], className]}
>
  <div class:list={['mx-auto px-6 lg:px-12', widthClasses[resolvedWidth]]}>
    <slot />
  </div>
</section>
