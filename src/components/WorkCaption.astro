---
interface Props {
  num?: string;
  place?: string;
  year?: string | number;
  title: string;
  medium?: string;
  action?: string;
  class?: string;
}

const { num, place, year, title, medium, action, class: className = '' } = Astro.props;

const metaParts = [
  num ? `№ ${num}` : null,
  place,
  year != null ? String(year) : null,
].filter(Boolean);
---

<div class={`work-caption ${className}`.trim()}>
  <div class="min-w-0">
    {metaParts.length > 0 && (
      <div class="work-caption-meta">{metaParts.join(' · ')}</div>
    )}
    <div class="work-caption-title">{title}</div>
    {medium && <div class="work-caption-medium">{medium}</div>}
  </div>
  {action && <span class="work-caption-action">{action}</span>}
</div>
