---
import { getCollection } from 'astro:content';
import SectionLabel from '../SectionLabel.astro';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const hero = projects.slice(0, 2);
const rest = projects.slice(2, 5);
---

<section class="featured-c">
  <h2 class="sr-only">Selected Work</h2>
  <div class="featured-c-inner">
    <SectionLabel num="01" name="Selected Work" action="View all →" actionHref="/murals" />

    {hero.length > 0 && (
      <div class="featured-c-row featured-c-row--hero">
        {hero.map((project, i) => {
          const num = String(i + 1).padStart(2, '0');
          return (
            <a href={`/work/${project.id}`} class="featured-c-tile" data-animate="scale" data-animate-delay={String(i + 1)}>
              <div class="featured-c-image">
                <img
                  src={project.data.cover}
                  alt={project.data.title}
                  width="1200"
                  height="825"
                  decoding="async"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </div>
              <div class="featured-c-cap">
                <div class="featured-c-cap-left">
                  <p class="featured-c-cap-meta">&#8470; {num}{project.data.location && <> &middot; {project.data.location}</>}</p>
                  <h3 class="featured-c-cap-title">{project.data.title}</h3>
                  {project.data.materials && <p class="featured-c-cap-medium">{project.data.materials}</p>}
                </div>
                <span class="featured-c-cap-view">View &rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
    )}

    {rest.length > 0 && (
      <div class="featured-c-row featured-c-row--rest">
        {rest.map((project, i) => {
          const num = String(i + 3).padStart(2, '0');
          return (
            <a href={`/work/${project.id}`} class="featured-c-tile" data-animate="scale" data-animate-delay={String(i + 3)}>
              <div class="featured-c-image featured-c-image--portrait">
                <img
                  src={project.data.cover}
                  alt={project.data.title}
                  width="600"
                  height="750"
                  decoding="async"
                  loading="lazy"
                />
              </div>
              <div class="featured-c-cap">
                <div class="featured-c-cap-left">
                  <p class="featured-c-cap-meta">&#8470; {num}{project.data.location && <> &middot; {project.data.location}</>}</p>
                  <h3 class="featured-c-cap-title featured-c-cap-title--sm">{project.data.title}</h3>
                  {project.data.materials && <p class="featured-c-cap-medium">{project.data.materials}</p>}
                </div>
                <span class="featured-c-cap-view">View &rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
  .featured-c {
    padding-top: clamp(4rem, 8vw, 8rem);
    padding-bottom: clamp(4rem, 8vw, 8rem);
    padding-inline: clamp(1.5rem, 3vw, 3rem);
    background: var(--color-bone-black);
  }
  .featured-c-inner {
    max-width: 1400px;
    margin-inline: auto;
  }

  .featured-c-row {
    display: grid;
    gap: clamp(1.5rem, 2.5vw, 2rem);
    margin-top: clamp(2rem, 4vw, 3.5rem);
  }
  .featured-c-row--hero { grid-template-columns: 1fr; }
  .featured-c-row--rest { grid-template-columns: 1fr; }

  @media (min-width: 768px) {
    .featured-c-row--hero { grid-template-columns: 7fr 5fr; }
    .featured-c-row--rest { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  }

  .featured-c-tile {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .featured-c-image {
    position: relative;
    overflow: hidden;
    background: var(--color-midnight-graphite, #0a0d12);
    aspect-ratio: 16 / 11;
  }
  .featured-c-image--portrait { aspect-ratio: 4 / 5; }

  .featured-c-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-out, ease-out);
    filter: brightness(0.92) contrast(1.04);
  }
  .featured-c-tile:hover .featured-c-image img,
  .featured-c-tile:focus-visible .featured-c-image img {
    transform: scale(1.03);
  }

  .featured-c-cap {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-6);
    padding-top: var(--space-5);
  }
  .featured-c-cap-left { min-width: 0; }
  .featured-c-cap-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(238,236,233,0.55);
    margin-bottom: var(--space-2);
  }
  .featured-c-cap-title {
    font-family: var(--font-heading);
    color: var(--color-titanium-white);
    font-size: clamp(1.375rem, 1.8vw, 1.75rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    font-weight: 400;
    margin: 0 0 var(--space-2);
  }
  .featured-c-cap-title--sm {
    font-size: clamp(1.125rem, 1.4vw, 1.375rem);
  }
  .featured-c-cap-medium {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(238,236,233,0.6);
    margin: 0;
  }
  .featured-c-cap-view {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(238,236,233,0.7);
    white-space: nowrap;
    margin-top: 2px;
    transition: color 200ms var(--ease-out, ease-out), transform 200ms var(--ease-out, ease-out);
  }
  .featured-c-tile:hover .featured-c-cap-view,
  .featured-c-tile:focus-visible .featured-c-cap-view {
    color: var(--color-editorial-accent);
    transform: translateX(4px);
  }
</style>
