---
import Button from '../Button.astro';
---

<section class="relative min-h-screen flex items-center justify-center pt-20">
  <!-- Background overlay -->
  <div class="absolute inset-0 bg-bone-black/60 z-10"></div>

  <!-- Hero image placeholder -->
  <div class="absolute inset-0 bg-midnight-graphite">
    <!-- Replace with actual hero image: -->
    <!-- <img src="/images/hero/trolley-barn.jpg" alt="" class="w-full h-full object-cover" /> -->
  </div>

  <!-- Content -->
  <div class="relative z-20 mx-auto max-w-4xl px-6 text-center">
    <h1 class="font-heading text-[var(--text-fluid-5xl)] text-titanium-white mb-6 text-balance">
      Hand-painted murals and signs.<br />
      <span class="text-soft-gray">Landmarks, not lookalikes.</span>
    </h1>

    <p class="text-[var(--text-fluid-lg)] text-shadow-gray max-w-2xl mx-auto mb-10 text-balance">
      We paint murals, restore signs, and build brand installations
      for the businesses and stories that refuse to be forgotten.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button href="mailto:hello@untitledmixedmedia.com">
        Request a Site Visit
      </Button>
      <Button href="/work" variant="secondary">
        See Our Work
      </Button>
    </div>

    <p class="text-smoke-gray text-[var(--text-fluid-xs)] mt-8 italic">
      Every commission treated like the landmark it is.
    </p>
  </div>
</section>
