---
import { Image } from 'astro:assets';
import Button from '../Button.astro';
import heroPoster from '../../assets/images/hero-poster.jpg';

interface Props {
  headline?: string;
  subline?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  headline = 'We help you build your idea into something worth painting.',
  subline = 'Hand-painted murals and signs in Richmond, Virginia. Most artists paint for themselves. Most sign shops print for speed. I paint for you.',
  ctaLabel = 'Schedule Your Free Discovery Session',
  ctaHref = '/contact',
} = Astro.props;
---

<section class="relative min-h-dvh flex items-end overflow-hidden">
  <Image
    src={heroPoster}
    alt="Hand-painted mural and sign work by Untitled Mixed Media in Richmond, Virginia"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
  />

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-bone-black via-bone-black/60 to-bone-black/10" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 w-full px-6 lg:px-12 pb-24 lg:pb-32">
    <div class="max-w-3xl mx-auto">
      <p
        class="label-eyebrow mb-6 eyebrow-label"
        data-animate
      >
        Richmond, Virginia
      </p>
      <h1
        class="font-blackletter text-titanium-white text-5xl mb-6"
        style="line-height: var(--leading-solid); letter-spacing: 0;"
        data-animate
        data-animate-delay="1"
      >
        {headline}
      </h1>
      {subline && (
        <div
          class="mb-10 space-y-4"
          data-animate
          data-animate-delay="2"
        >
          <p class="font-body text-soft-gray text-lg">
            {subline}
          </p>
          <p class="font-body text-soft-gray text-lg">
            Your building, your story, your business.
          </p>
        </div>
      )}
      <div class="flex flex-wrap gap-4" data-animate data-animate-delay="3">
        <Button
          href={ctaHref}
          variant="primary"
          size="large"
          data-plausible-event-name="CtaClick"
          data-plausible-event-position="HeroPrimary"
          class="plausible-event-name=CtaClick plausible-event-position=HeroPrimary"
        >
          {ctaLabel}
        </Button>
        <Button
          href="/mural-cost-estimator"
          variant="secondary"
          size="large"
        >
          Get a Price Estimate
        </Button>
      </div>
      <p
        class="font-body text-soft-gray italic text-sm mt-6"
        data-animate
        data-animate-delay="4"
      >
        You don't need a finished concept to get started.
      </p>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    video { display: none; }
  }
</style>
