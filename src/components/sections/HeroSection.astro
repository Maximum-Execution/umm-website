---
import Button from '../Button.astro';
---

<section class="relative min-h-screen flex flex-col justify-center px-6 lg:px-12 pt-20">
  <div class="max-w-7xl w-full">
    <p class="font-mono text-smoke-gray uppercase mb-6" style="font-size: var(--text-fluid-sm); letter-spacing: 0.08em; line-height: 1.5;">
      Richmond, Virginia &mdash; Hand-painted murals &amp; signs
    </p>

    <h1 class="font-heading text-titanium-white font-black mb-4" style="font-size: var(--text-fluid-5xl); line-height: 1.15; letter-spacing: -0.02em;">
      Landmarks, not lookalikes.
    </h1>

    <p class="font-body text-soft-gray mb-8" style="font-size: var(--text-fluid-xl); line-height: 1.5; letter-spacing: 0.02em;">
      Public art from your story, not a template. We paint murals and signs in Richmond, Virginia.
    </p>

    <div class="flex flex-row items-center gap-6">
      <Button href="mailto:hello@untitledmixedmedia.com">
        Request a Site Visit
      </Button>
      <Button href="#work" variant="ghost">
        See the Work
      </Button>
    </div>
  </div>
</section>
