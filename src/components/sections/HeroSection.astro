---
import { Image } from 'astro:assets';
import heroPoster from '../../assets/images/hero-poster.jpg';

interface Props {
  headline?: string;
  subline?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  headline = 'We help you build your idea into something worth painting.',
  subline = 'Hand-painted murals and signs in Richmond, Virginia. Most artists paint for themselves. Most sign shops print for speed. I paint for you.',
  ctaLabel = 'Schedule Your Free Discovery Session',
  ctaHref = '/contact',
} = Astro.props;
---

<section class="relative min-h-screen flex items-end overflow-hidden">
  <Image
    src={heroPoster}
    alt="Hand-painted mural and sign work by Untitled Mixed Media in Richmond, Virginia"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
  />

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-bone-black via-bone-black/60 to-bone-black/10" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 w-full px-6 lg:px-12 pb-24 lg:pb-32">
    <div class="max-w-5xl">
      <p
        class="font-mono text-smoke-gray uppercase mb-6"
        style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
        data-animate
      >
        Richmond, Virginia
      </p>
      <h1
        class="font-blackletter text-titanium-white mb-4"
        style="font-size: var(--text-fluid-5xl); line-height: var(--leading-solid); letter-spacing: 0;"
        data-animate
        data-animate-delay="1"
      >
        {headline}
      </h1>
      {subline && (
        <div
          class="mb-10 max-w-2xl space-y-4"
          data-animate
          data-animate-delay="2"
        >
          <p
            class="font-body text-soft-gray"
            style="font-size: var(--text-fluid-lg);"
          >
            {subline}
          </p>
          <p
            class="font-body text-soft-gray"
            style="font-size: var(--text-fluid-lg);"
          >
            Your building, your story, your business.
          </p>
        </div>
      )}
      <div class="flex flex-wrap gap-4" data-animate data-animate-delay="3">
        <a
          href={ctaHref}
          class="font-sans inline-block bg-titanium-white text-bone-black px-8 py-3.5 text-sm font-medium tracking-[0.15em] uppercase hover:bg-light-ash transition-colors duration-200"
        >
          {ctaLabel}
        </a>
        <a
          href="/mural-cost-estimator"
          class="font-sans inline-block border border-titanium-white text-titanium-white px-8 py-3.5 text-sm font-medium tracking-[0.15em] uppercase hover:bg-titanium-white hover:text-bone-black transition-colors duration-200"
        >
          Get a Price Estimate <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <p
        class="font-body text-smoke-gray italic mt-6"
        style="font-size: var(--text-fluid-sm);"
        data-animate
        data-animate-delay="4"
      >
        You don't need a finished concept to get started.
      </p>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    video { display: none; }
  }
</style>
