---
import { Image } from 'astro:assets';
import processVisit from '../../assets/images/process-visit.jpg';
import processRender from '../../assets/images/process-render.jpg';
import processPaint from '../../assets/images/process-paint.jpg';

const steps = [
  {
    number: '01',
    label: 'Discover',
    title: 'We start with questions, not sketches.',
    body: [
      "Most people reach out with a feeling, not a finished concept. That's normal. We sit down together and talk about what you're trying to do, what the space means to you, and what the people who walk past it should notice.",
      "Then we visit the building. We study the materials, the architecture, the block, the light.",
      "For murals, we're looking for what we call the Landmark Moment: the one specific thing your mural should be about. For signs, we're figuring out what your name stands for and how the sign should carry it. The way your sign is made tells people everything about how you run your business, before they ever walk through the door.",
    ],
    image: processVisit,
    imageAlt: 'Spencer in conversation with a client during a discovery session',
  },
  {
    number: '02',
    label: 'Design',
    title: 'You see it on your actual wall before we paint anything.',
    body: [
      "We take everything from discovery and build a photorealistic render showing the finished work on your specific building. Not a sketch on paper. A picture of what your wall will actually look like when we're done.",
      "You review it. You tell us what to change. We revise it. Nothing moves forward until you look at it and say \"that's it.\"",
    ],
    image: processRender,
    imageAlt: 'Photorealistic Blender render showing a mural design on a real building',
    secondaryImage: processPaint,
    secondaryImageAlt: 'Finished mural matching the render design',
    imageLabels: ['Render', 'Reality'] as const,
  },
  {
    number: '03',
    label: 'Install',
    title: 'We paint it by hand. Built to last.',
    body: [
      "The approved design goes on the wall. Professional-grade paints matched to your surface and Richmond's climate. UV-protective sealant. Anti-graffiti coating where needed.",
      "When it's done, you get a Certificate of Provenance documenting where every visual element came from. So when someone asks about the work on your wall, you can tell them exactly why it looks the way it does.",
    ],
    image: processPaint,
    imageAlt: 'Spencer hand-painting a mural on an exterior wall',
  },
];
---

<section id="process" class="bg-midnight-graphite py-24 lg:py-32 px-6 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <p
      class="font-mono text-smoke-gray uppercase mb-16 lg:mb-24"
      style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
      data-animate="fade"
    >
      How It Works
    </p>

    <h2
      class="font-heading text-titanium-white mb-16 lg:mb-24 max-w-2xl"
      style="font-size: var(--text-fluid-3xl); line-height: var(--leading-tight);"
      data-animate="fade"
    >
      Three steps. You approve everything before we paint.
    </h2>

    <div class="space-y-24 lg:space-y-32">
      {steps.map((step, i) => {
        const isReversed = i % 2 === 1;
        return (
          <div
            class={`grid lg:grid-cols-2 gap-8 lg:gap-16 items-center ${isReversed ? 'lg:[direction:rtl]' : ''}`}
          >
            {/* Image */}
            <div class={`overflow-hidden ${isReversed ? 'lg:[direction:ltr]' : ''}`} data-animate="scale">
              {step.secondaryImage ? (
                <div class="grid grid-cols-2 gap-1">
                  <div class="relative aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                    <Image
                      src={step.image}
                      alt={step.imageAlt}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    {step.imageLabels && (
                      <span class="absolute bottom-2 left-2 font-mono text-titanium-white uppercase bg-bone-black/60 px-2 py-0.5" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                        {step.imageLabels[0]}
                      </span>
                    )}
                  </div>
                  <div class="relative aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                    <Image
                      src={step.secondaryImage}
                      alt={step.secondaryImageAlt}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    {step.imageLabels && (
                      <span class="absolute bottom-2 left-2 font-mono text-titanium-white uppercase bg-bone-black/60 px-2 py-0.5" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                        {step.imageLabels[1]}
                      </span>
                    )}
                  </div>
                </div>
              ) : (
                <div class="aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                  <Image
                    src={step.image}
                    alt={step.imageAlt}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}
            </div>

            {/* Text */}
            <div class={isReversed ? 'lg:[direction:ltr]' : ''} data-animate="fade">
              <span
                class="font-mono block mb-4"
                style="font-size: var(--text-fluid-sm); letter-spacing: var(--tracking-wider);"
                aria-hidden="true"
              >
                <span class="text-titanium-white">{step.number}</span><span class="text-slate-gray"> / {step.label}</span>
              </span>
              <h3
                class="font-heading text-titanium-white mb-4"
                style="font-size: var(--text-fluid-xl);"
              >
                {step.title}
              </h3>
              <div class="space-y-4">
                {step.body.map((paragraph: string) => (
                  <p
                    class="font-body text-soft-gray"
                    style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);"
                  >
                    {paragraph}
                  </p>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
