---
import { Image } from 'astro:assets';
import processVisit from '../../assets/images/process-visit.jpg';
import processRender from '../../assets/images/process-render.jpg';
import processPaint from '../../assets/images/process-paint.jpg';

const steps = [
  {
    number: '01',
    label: 'Discover',
    title: 'We start with questions, not sketches.',
    body: [
      "Most people who reach out don't have a finished concept. They have a feeling, or a rough direction. That's exactly where we want to start.",
      "We sit down and talk about what you're trying to do, what the space means to you, and what the people who walk past it should notice. Then we visit the building. We look at the materials, the architecture, the block, the light.",
      "For murals, we're searching for what I call the Landmark Moment: the one specific thing your mural should be about. Not three themes. Not a collage of ideas. One clear thing that makes strangers stop.",
      "For signs, we're figuring out what your name actually stands for and how the sign should carry it. The way a sign is made tells people everything about how you run your business. They read that before they ever read the words on it.",
    ],
    image: processVisit,
    imageAlt: 'Spencer in conversation with a client during a discovery session',
  },
  {
    number: '02',
    label: 'Design',
    title: 'You see it on your actual wall before we paint anything.',
    body: [
      "I take everything from discovery and build a photorealistic render showing the finished work on your specific building. Not a sketch on paper. A picture of what your wall will actually look like when it's done.",
      "You review it. You tell me what to change. I revise it. Nothing moves forward until you look at it and say, \"That's it.\"",
    ],
    image: processRender,
    imageAlt: 'Photorealistic Blender render showing a mural design on a real building',
    secondaryImage: processPaint,
    secondaryImageAlt: 'Finished mural matching the render design',
    imageLabels: ['Render', 'Reality'] as const,
  },
  {
    number: '03',
    label: 'Install',
    title: 'Painted by hand. Built to last.',
    body: [
      "The approved design goes on the wall. Professional-grade paints matched to your surface and Richmond's climate. UV-protective sealant. Anti-graffiti coating where it's needed.",
      "When it's finished, you get a Certificate of Provenance documenting where every visual element came from, how each color was selected, and why. So when someone asks about the work on your building, you don't just say \"I hired an artist.\" You can tell them exactly why it looks the way it does.",
    ],
    image: processPaint,
    imageAlt: 'Spencer hand-painting a mural on an exterior wall',
  },
];
---

<section id="process" class="bg-midnight-graphite py-24 lg:py-32 px-6 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="max-w-3xl mx-auto text-center mb-16 lg:mb-24">
      <p
        class="font-mono text-soft-gray uppercase mb-6 eyebrow-label"
        style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
        data-animate="fade"
      >
        How It Works
      </p>

      <h2
        class="font-heading text-titanium-white"
        style="font-size: var(--text-fluid-3xl); line-height: var(--leading-tight);"
        data-animate="fade"
      >
        Three steps. You approve everything before we paint.
      </h2>
    </div>

    <div class="space-y-24 lg:space-y-32">
      {steps.map((step, i) => {
        const isReversed = i % 2 === 1;
        return (
          <div
            class={`grid lg:grid-cols-2 gap-8 lg:gap-16 items-center ${isReversed ? 'lg:[direction:rtl]' : ''}`}
          >
            {/* Image */}
            <div class={`overflow-hidden ${isReversed ? 'lg:[direction:ltr]' : ''}`} data-animate="scale">
              {step.secondaryImage ? (
                <div class="grid grid-cols-2 gap-1">
                  <div class="relative aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                    <Image
                      src={step.image}
                      alt={step.imageAlt}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    {step.imageLabels && (
                      <span class="absolute bottom-2 left-2 font-mono text-titanium-white uppercase bg-bone-black/60 px-2 py-0.5" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                        {step.imageLabels[0]}
                      </span>
                    )}
                  </div>
                  <div class="relative aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                    <Image
                      src={step.secondaryImage}
                      alt={step.secondaryImageAlt}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    {step.imageLabels && (
                      <span class="absolute bottom-2 left-2 font-mono text-titanium-white uppercase bg-bone-black/60 px-2 py-0.5" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                        {step.imageLabels[1]}
                      </span>
                    )}
                  </div>
                </div>
              ) : (
                <div class="aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                  <Image
                    src={step.image}
                    alt={step.imageAlt}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}
            </div>

            {/* Text */}
            <div class={isReversed ? 'lg:[direction:ltr]' : ''} data-animate="fade">
              <span
                class="font-mono block mb-4"
                style="font-size: var(--text-fluid-sm); letter-spacing: var(--tracking-wider);"
                aria-hidden="true"
              >
                <span class="text-titanium-white">{step.number}</span><span class="text-slate-gray"> / {step.label}</span>
              </span>
              <h3
                class="font-heading text-titanium-white mb-4"
                style="font-size: var(--text-fluid-xl);"
              >
                {step.title}
              </h3>
              <div class="space-y-4">
                {step.body.map((paragraph: string) => (
                  <p
                    class="font-body text-soft-gray"
                    style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);"
                  >
                    {paragraph}
                  </p>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
