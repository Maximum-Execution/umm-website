---
const steps = [
  {
    number: '01',
    label: 'Discover',
    title: 'We listen to your story and figure out what makes you different.',
    body: 'Every project starts with a conversation. Not a template. Not a questionnaire. We sit down, we listen, and we identify what makes your place unlike anything else on the block. Then we visit your site and collect the raw materials: photography from every angle, spectrometer color readings from your physical surfaces, and a full record of what your space already holds.',
    image: '/images/process-visit.jpg',
    imageAlt: 'Spencer photographing a wall during a site visit',
  },
  {
    number: '02',
    label: 'Collect',
    title: 'We gather the real colors, textures, and details from your story.',
    body: "We don't pick colors from a screen. We collect them from the source. Every color in the finished work was measured from your actual materials. Every shape was derived from what we found on-site. You see a photorealistic render of the design on your specific wall before we pick up a brush. You approve it or we revise it.",
    image: '/images/process-render.jpg',
    imageAlt: 'Photorealistic Blender render of a mural on a building wall',
  },
  {
    number: '03',
    label: 'Create',
    title: 'We paint it by hand. You approve it before it\'s final.',
    body: "Nothing goes on the wall that you haven't already seen. We hand-paint the approved design using professional-grade materials matched to your surface and climate. Every project includes documentation of where every color and material came from. The work is sealed, protected, and built to last 20+ years.",
    image: '/images/process-paint.jpg',
    imageAlt: 'Spencer painting a large-scale mural on an exterior wall',
  },
];
---

<section id="process" class="bg-midnight-graphite py-24 lg:py-32 px-6 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <p
      class="font-mono text-smoke-gray uppercase mb-16 lg:mb-24"
      style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
      data-animate="fade"
    >
      How It Works
    </p>

    <div class="space-y-24 lg:space-y-32">
      {steps.map((step, i) => {
        const isReversed = i % 2 === 1;
        return (
          <div
            class={`grid lg:grid-cols-2 gap-8 lg:gap-16 items-center ${isReversed ? 'lg:[direction:rtl]' : ''}`}
          >
            {/* Image */}
            <div class={`overflow-hidden ${isReversed ? 'lg:[direction:ltr]' : ''}`} data-animate="scale">
              <div class="aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                <img
                  src={step.image}
                  alt={step.imageAlt}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
              </div>
            </div>

            {/* Text */}
            <div class={isReversed ? 'lg:[direction:ltr]' : ''} data-animate="fade">
              <span
                class="font-mono text-slate-gray block mb-4"
                style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
                aria-hidden="true"
              >
                {step.number} / {step.label}
              </span>
              <h3
                class="font-heading text-titanium-white mb-4"
                style="font-size: var(--text-fluid-xl);"
              >
                {step.title}
              </h3>
              <p
                class="font-body text-shadow-gray"
                style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);"
              >
                {step.body}
              </p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
