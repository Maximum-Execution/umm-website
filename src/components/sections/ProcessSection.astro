---
import { Image } from 'astro:assets';
import processVisit from '../../assets/images/process-visit.jpg';
import processRender from '../../assets/images/process-render.jpg';
import processPaint from '../../assets/images/process-paint.jpg';
import SectionLabel from '../SectionLabel.astro';

const steps = [
  {
    number: '01',
    label: 'Discover',
    title: 'We start with questions, not sketches.',
    body: [
      "Most people reach out with a feeling, not a finished concept. That's fine. That's how it's supposed to work. We sit down and talk about what you're trying to do, what the space means to you, and what the people walking past it should notice. Then I visit the building and study the materials, the architecture, the light, the block. By the end, we know what belongs on your wall.",
    ],
    image: processVisit,
    imageAlt: 'Spencer in conversation with a client during a discovery session',
  },
  {
    number: '02',
    label: 'Design',
    title: 'You see it on your actual wall before we paint anything.',
    body: [
      "I take everything from discovery and build a photorealistic render showing the finished work on your specific building. Not a sketch on paper. A picture of what your wall will actually look like when it's done. You review it. You tell me what to change. I revise it. Nothing moves forward until you look at it and say, \"That's it.\"",
    ],
    image: processRender,
    imageAlt: 'Photorealistic Blender render showing a mural design on a real building',
    secondaryImage: processPaint,
    secondaryImageAlt: 'Finished mural matching the render design',
    imageLabels: ['Render', 'Reality'] as const,
  },
  {
    number: '03',
    label: 'Paint',
    title: 'Painted by hand. Documented to the source.',
    body: [
      "The approved design goes on the wall. Professional-grade paints matched to your surface and Richmond's climate. UV-protective sealant. Anti-graffiti coating where it's needed. When it's finished, you get a Certificate of Provenance documenting where every visual element came from and why. So when someone asks about the work on your building, you can tell them exactly why it looks the way it does.",
    ],
    image: processPaint,
    imageAlt: 'Spencer hand-painting a mural on an exterior wall',
  },
];
---

<section id="process" class="process-c">
  <div class="process-c-inner">
    <div class="process-c-header">
      <SectionLabel num="05" name="How It Works" />
      <h2 class="process-c-heading" data-animate="fade">
        How we get from your idea to your wall.
      </h2>
    </div>

    <div class="space-y-24 lg:space-y-32">
      {steps.map((step, i) => {
        const isReversed = i % 2 === 1;
        return (
          <div
            class={`grid lg:grid-cols-2 gap-8 lg:gap-16 items-center ${isReversed ? 'lg:[direction:rtl]' : ''}`}
          >
            {/* Image */}
            <div class={`overflow-hidden ${isReversed ? 'lg:[direction:ltr]' : ''}`} data-animate="scale">
              {step.secondaryImage ? (
                <div class="grid grid-cols-2 gap-1">
                  <div class="relative aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                    <Image
                      src={step.image}
                      alt={step.imageAlt}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    {step.imageLabels && (
                      <span class="absolute bottom-2 left-2 font-mono text-titanium-white uppercase bg-bone-black/60 px-2 py-0.5" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                        {step.imageLabels[0]}
                      </span>
                    )}
                  </div>
                  <div class="relative aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                    <Image
                      src={step.secondaryImage}
                      alt={step.secondaryImageAlt}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    {step.imageLabels && (
                      <span class="absolute bottom-2 left-2 font-mono text-titanium-white uppercase bg-bone-black/60 px-2 py-0.5" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                        {step.imageLabels[1]}
                      </span>
                    )}
                  </div>
                </div>
              ) : (
                <div class="aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                  <Image
                    src={step.image}
                    alt={step.imageAlt}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}
            </div>

            {/* Text */}
            <div class={isReversed ? 'lg:[direction:ltr]' : ''} data-animate="fade">
              <div class="process-c-rule" aria-hidden="true"></div>
              <span class="process-c-step" aria-hidden="true">
                <span class="process-c-step-num">{String(step.number).padStart(2, '0')}</span>
                <span class="process-c-step-sep">&middot;</span>
                <span class="process-c-step-label">{step.label}</span>
              </span>
              <h3 class="process-c-title">{step.title}</h3>
              <div class="process-c-body">
                {step.body.map((paragraph: string) => (
                  <p class="process-c-body-p">{paragraph}</p>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .process-c {
    padding-top: clamp(5rem, 9vw, 9rem);
    padding-bottom: clamp(5rem, 9vw, 9rem);
    padding-inline: clamp(1.5rem, 3vw, 3rem);
    background: var(--color-bone-black);
    border-top: 1px solid rgba(238,236,233,0.08);
  }
  .process-c-inner {
    max-width: 1400px;
    margin-inline: auto;
  }
  .process-c-header {
    margin-bottom: clamp(3rem, 6vw, 6rem);
    max-width: 900px;
  }
  .process-c-heading {
    font-family: var(--font-heading);
    color: var(--color-titanium-white);
    font-size: var(--text-fluid-4xl);
    line-height: 1.1;
    letter-spacing: -0.018em;
    font-weight: 500;
    margin-top: var(--space-5);
    text-wrap: balance;
  }
  .process-c-rule {
    width: 40px;
    height: 2px;
    background: var(--color-editorial-accent);
    margin-bottom: var(--space-5);
  }
  .process-c-step {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-bottom: var(--space-8);
  }
  .process-c-step-num { color: var(--color-editorial-accent); font-weight: 600; }
  .process-c-step-sep { color: rgba(238,236,233,0.45); }
  .process-c-step-label { color: rgba(238,236,233,0.72); }
  .process-c-title {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    color: var(--color-titanium-white);
    font-size: clamp(1.75rem, 3.2vw, 3rem);
    line-height: 1.12;
    letter-spacing: -0.018em;
    margin-bottom: var(--space-8);
    max-width: 22ch;
  }
  .process-c-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .process-c-body-p {
    font-family: var(--font-body);
    color: rgba(238,236,233,0.74);
    font-size: var(--text-fluid-base);
    line-height: 1.6;
    max-width: 56ch;
  }
</style>
