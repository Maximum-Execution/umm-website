---
const steps = [
  {
    number: '01',
    label: 'Discover',
    title: 'We help you build your idea into something worth painting.',
    body: "Most people don't walk in with a finished concept. That's the point. We sit down, listen to your ideas, your stories, and your goals for the space. Then we visit your building and study what's already there: the materials, the architecture, the neighborhood, the history. Our process helps us think about your project in a way most muralists never would. We don't follow the traditional path. We help you take what you have and turn it into something more meaningful than what you started with.",
    image: '/images/process-visit.jpg',
    imageAlt: 'Spencer in conversation with a client during a discovery session',
  },
  {
    number: '02',
    label: 'Design',
    title: 'We turn everything we learned into a design that could only belong to your building.',
    body: "All the ideas, stories, and details from discovery feed into the design. We create a photorealistic render showing the finished work on your actual wall. Not a sketch on paper. A picture of what your building will look like when we're done. You review it. You request changes. Nothing moves forward until you say \"that's it.\"",
    image: '/images/process-render.jpg',
    imageAlt: 'Photorealistic Blender render showing a mural design on a real building',
  },
  {
    number: '03',
    label: 'Install',
    title: 'We paint it by hand and build it to last.',
    body: "The approved design goes on the wall. Professional-grade paints matched to your surface and Richmond's climate. UV-protective sealant. Anti-graffiti coating where needed. Hand-painted, sealed, and protected. Built to hold up for 20+ years.",
    image: '/images/process-paint.jpg',
    imageAlt: 'Spencer hand-painting a mural on an exterior wall',
  },
];
---

<section id="process" class="bg-midnight-graphite py-24 lg:py-32 px-6 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <p
      class="font-mono text-smoke-gray uppercase mb-16 lg:mb-24"
      style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
      data-animate="fade"
    >
      How It Works
    </p>

    <h2
      class="font-heading text-titanium-white mb-16 lg:mb-24 max-w-2xl"
      style="font-size: var(--text-fluid-3xl); line-height: var(--leading-tight);"
      data-animate="fade"
    >
      Three steps. You approve everything before we paint.
    </h2>

    <div class="space-y-24 lg:space-y-32">
      {steps.map((step, i) => {
        const isReversed = i % 2 === 1;
        return (
          <div
            class={`grid lg:grid-cols-2 gap-8 lg:gap-16 items-center ${isReversed ? 'lg:[direction:rtl]' : ''}`}
          >
            {/* Image */}
            <div class={`overflow-hidden ${isReversed ? 'lg:[direction:ltr]' : ''}`} data-animate="scale">
              <div class="aspect-[4/3] bg-midnight-graphite border border-slate-gray overflow-hidden">
                <img
                  src={step.image}
                  alt={step.imageAlt}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
              </div>
            </div>

            {/* Text */}
            <div class={isReversed ? 'lg:[direction:ltr]' : ''} data-animate="fade">
              <span
                class="font-mono text-slate-gray block mb-4"
                style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
                aria-hidden="true"
              >
                {step.number} / {step.label}
              </span>
              <h3
                class="font-heading text-titanium-white mb-4"
                style="font-size: var(--text-fluid-xl);"
              >
                {step.title}
              </h3>
              <p
                class="font-body text-shadow-gray"
                style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);"
              >
                {step.body}
              </p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
