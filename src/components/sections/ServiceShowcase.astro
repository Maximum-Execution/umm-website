---
import { Image } from 'astro:assets';
import serviceMurals from '../../assets/images/service-murals.jpg';
import serviceSigns from '../../assets/images/service-signs.jpg';

const services = [
  {
    title: 'Murals',
    description: 'Not a template. Not someone else\'s portfolio on your wall. A mural built from your story, painted by hand, that belongs to your building and nobody else\'s. Starting at $15/sqft.',
    href: '/murals',
    image: serviceMurals,
    imageAlt: 'Hand-painted exterior mural on a commercial building',
  },
  {
    title: 'Hand-Painted Signs',
    description: 'Storefront signs and historic sign restorations, hand-painted to last 20+ years. Your name on your building, made by hand. Starting at $500 with The Brand Mark.',
    href: '/hand-painted-signs',
    image: serviceSigns,
    imageAlt: 'Hand-painted lettering on a storefront window',
  },
];
---

<section class="pt-24 lg:pt-32 pb-4">
  <h2 class="sr-only">Work</h2>
  <div class="mx-auto max-w-7xl px-6 lg:px-12 mb-6">
    <p
      class="font-mono text-soft-gray uppercase"
      aria-hidden="true"
      style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
    >
      Work
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-1">
    {services.map((service, i) => (
      <a
        href={service.href}
        class="group relative block overflow-hidden min-h-[60vh] md:min-h-[70vh]"
        data-animate="scale"
        data-animate-delay={String(i + 1)}
      >
        <Image
          src={service.image}
          alt={service.imageAlt}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-midnight-graphite" aria-hidden="true"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-bone-black/90 via-bone-black/40 to-transparent" aria-hidden="true"></div>
        <div class="relative z-10 h-full flex flex-col justify-end p-8 lg:p-12">
          <h3
            class="font-heading text-titanium-white mb-3"
            style="font-size: var(--text-fluid-3xl); line-height: var(--leading-tight);"
          >
            {service.title}
          </h3>
          <p
            class="font-body text-soft-gray mb-6 max-w-md"
            style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);"
          >
            {service.description}
          </p>
          <span
            class="font-mono text-soft-gray uppercase group-hover:text-titanium-white transition-colors"
            style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
          >
            Explore <span aria-hidden="true">&rarr;</span>
          </span>
        </div>
      </a>
    ))}
  </div>
</section>
