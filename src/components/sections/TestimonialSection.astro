---
interface Props {
  quote?: string;
  attribution?: string;
  company?: string;
  backgroundImage?: string;
}

const {
  quote = 'Most people don\'t know exactly what they want when they reach out. That\'s the best starting point. My job is to listen until I find the idea they couldn\'t see on their own.',
  attribution = 'Spencer Bennett',
  company = '',
  backgroundImage,
} = Astro.props;
---

<section class="testimonial-c">
  {backgroundImage && (
    <div class="testimonial-c-bg" aria-hidden="true">
      <img src={backgroundImage} alt="" loading="lazy" />
      <div class="testimonial-c-bg-grade"></div>
    </div>
  )}

  <div class="testimonial-c-inner" data-animate="fade">
    <span class="testimonial-c-mark" aria-hidden="true">&ldquo;</span>
    <blockquote class="testimonial-c-block">
      <p class="testimonial-c-quote">&ldquo;{quote}&rdquo;</p>
      <footer class="testimonial-c-footer">
        <span class="testimonial-c-rule" aria-hidden="true"></span>
        <cite class="testimonial-c-cite">
          {attribution}{company && `, ${company}`}
        </cite>
      </footer>
    </blockquote>
  </div>
</section>

<style>
  .testimonial-c {
    position: relative;
    overflow: hidden;
    padding-block: clamp(6rem, 12vw, 12rem);
    padding-inline: clamp(1.5rem, 3vw, 3rem);
    background: var(--color-bone-black);
    border-top: 1px solid rgba(238,236,233,0.06);
    border-bottom: 1px solid rgba(238,236,233,0.06);
  }
  .testimonial-c-bg { position: absolute; inset: 0; }
  .testimonial-c-bg img {
    width: 100%; height: 100%; object-fit: cover;
    filter: brightness(0.28) contrast(1.1);
  }
  .testimonial-c-bg-grade {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,2,5,0.55), rgba(0,2,5,0.85));
  }

  .testimonial-c-inner {
    position: relative;
    z-index: 2;
    max-width: 980px;
    margin-inline: auto;
    text-align: center;
  }
  .testimonial-c-mark {
    display: block;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    color: var(--color-editorial-accent);
    font-size: clamp(5rem, 9vw, 8rem);
    line-height: 0.72;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }
  .testimonial-c-quote {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    color: var(--color-titanium-white);
    font-size: var(--text-fluid-3xl);
    line-height: 1.3;
    letter-spacing: -0.012em;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .testimonial-c-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .testimonial-c-rule {
    width: 48px;
    height: 1px;
    background: rgba(238,236,233,0.3);
  }
  .testimonial-c-cite {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(238,236,233,0.7);
    font-style: normal;
  }
</style>
