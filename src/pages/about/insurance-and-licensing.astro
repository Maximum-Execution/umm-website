---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import RelatedPages from '../../components/RelatedPages.astro';
---

<BaseLayout title="Insurance and Licensing | Untitled Mixed Media" description="Fully insured and licensed mural and sign painting in Richmond, VA. General liability, workers compensation, business licensing, and safety certifications.">
  <Nav />
  <main class="pt-32 pb-16">
    <div class="px-6 lg:px-12 max-w-4xl">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'About', href: '/about' },
        { label: 'Insurance & Licensing' },
      ]} />

      <p class="font-mono text-smoke-gray uppercase mb-6" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">
        About
      </p>

      <h1 class="font-heading text-titanium-white mb-6" style="font-size: var(--text-fluid-4xl); line-height: 1.1; letter-spacing: -0.03em;">
        Insurance and Licensing
      </h1>

      <div class="space-y-6 mb-16">
        <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-lg); line-height: 1.6;">
          Placeholder: Write an opening paragraph explaining why insurance and licensing matter for mural and sign work. Property managers, commercial clients, and government agencies require proof of coverage before approving on-site work. This page exists so clients can verify credentials without asking.
        </p>
      </div>

      <!-- Insurance and licensing sections -->
      <div class="space-y-10 mb-16">
        <div>
          <h2 class="font-heading text-titanium-white mb-3" style="font-size: var(--text-fluid-2xl); line-height: 1.2;">
            General Liability Insurance
          </h2>
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: 1.6;">
            Placeholder: Document general liability coverage. Include the carrier name, policy limits, and what it covers (property damage, bodily injury, completed operations). Note that certificates of insurance are available on request for any project. State the coverage amount.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-titanium-white mb-3" style="font-size: var(--text-fluid-2xl); line-height: 1.2;">
            Workers Compensation
          </h2>
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: 1.6;">
            Placeholder: Document workers compensation coverage. Required for any commercial job site. Include the carrier and confirmation that coverage is current. Note that this is required by most property management companies and general contractors before work begins.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-titanium-white mb-3" style="font-size: var(--text-fluid-2xl); line-height: 1.2;">
            Business License
          </h2>
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: 1.6;">
            Placeholder: Document the business license. Untitled Mixed Media LLC is registered in the Commonwealth of Virginia. Include the business license number, jurisdiction, and any relevant trade registrations. Note the LLC formation date and registered agent.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-titanium-white mb-3" style="font-size: var(--text-fluid-2xl); line-height: 1.2;">
            Certifications
          </h2>
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: 1.6;">
            Placeholder: List any relevant certifications. This may include OSHA safety training, lead paint awareness (for historic restoration work), or manufacturer-specific certifications (KEIM mineral paint applicator, etc.). Add certifications as they are earned.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-titanium-white mb-3" style="font-size: var(--text-fluid-2xl); line-height: 1.2;">
            Scaffold & Lift Certifications
          </h2>
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: 1.6;">
            Placeholder: Document scaffold and aerial lift certifications. Large-scale mural work requires safe access to height. Include any scaffold competent person training, aerial work platform (AWP) certifications, or fall protection training. Note whether UMM owns equipment or rents from certified suppliers.
          </p>
        </div>
      </div>

      <div class="bg-midnight-graphite p-8 mb-16 border border-slate-gray">
        <p class="font-mono text-smoke-gray uppercase mb-3" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">Note</p>
        <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-sm);">
          Certificates of insurance and proof of licensing are available on request. Contact hello@untitledmixedmedia.com for documentation.
        </p>
      </div>
    </div>

    <RelatedPages heading="Related" pages={[
      { title: 'Process', href: '/about/process', description: 'The provenance methodology in three steps.' },
      { title: 'About', href: '/about', description: 'Who we are and what we do.' },
      { title: 'Contact', href: '/contact', description: 'Request a site visit.' },
    ]} />
    <CTABlock />
  </main>
  <Footer />
</BaseLayout>
