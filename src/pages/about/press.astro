---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import RelatedPages from '../../components/RelatedPages.astro';
---

<BaseLayout title="Press & Media | Untitled Mixed Media" description="Media coverage, press inquiries, and downloadable brand assets for Untitled Mixed Media. Hand-painted murals and signs in Richmond, Virginia.">
  <Nav />
  <main class="pt-32 pb-16">
    <div class="px-6 lg:px-12 max-w-4xl">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'About', href: '/about' },
        { label: 'Press & Media' },
      ]} />

      <p class="font-mono text-smoke-gray uppercase mb-6" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">
        About
      </p>

      <h1 class="font-heading text-titanium-white mb-6" style="font-size: var(--text-fluid-4xl); line-height: 1.1; letter-spacing: -0.03em;">
        Press & Media
      </h1>

      <div class="space-y-6 mb-16">
        <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-lg); line-height: 1.6;">
          Untitled Mixed Media is a hand-painted mural and sign studio based in Richmond, Virginia. Spencer Bennett is available for interviews, commentary on public art, sign painting craft, and historic preservation topics.
        </p>
      </div>

      <!-- In The Press -->
      <div class="space-y-10 mb-16">
        <div>
          <h2 class="font-heading text-titanium-white mb-6" style="font-size: var(--text-fluid-2xl); line-height: 1.2;">
            In The Press
          </h2>
          <div class="space-y-6">
            <div class="border-b border-slate-gray pb-6">
              <p class="font-mono text-smoke-gray uppercase mb-2" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">Placeholder — Publication Name</p>
              <p class="font-body text-titanium-white mb-1" style="font-size: var(--text-fluid-base); line-height: 1.6;">
                "Article headline placeholder — coverage of a completed mural project or profile of the studio."
              </p>
              <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-sm);">Month Year</p>
            </div>
            <div class="border-b border-slate-gray pb-6">
              <p class="font-mono text-smoke-gray uppercase mb-2" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">Placeholder — Publication Name</p>
              <p class="font-body text-titanium-white mb-1" style="font-size: var(--text-fluid-base); line-height: 1.6;">
                "Article headline placeholder — feature on the Short Pump Mural or another public art commission."
              </p>
              <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-sm);">Month Year</p>
            </div>
            <div class="border-b border-slate-gray pb-6">
              <p class="font-mono text-smoke-gray uppercase mb-2" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">Placeholder — Publication Name</p>
              <p class="font-body text-titanium-white mb-1" style="font-size: var(--text-fluid-base); line-height: 1.6;">
                "Article headline placeholder — coverage of sign restoration or historic preservation work."
              </p>
              <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-sm);">Month Year</p>
            </div>
          </div>
        </div>

        <!-- Press Inquiries -->
        <div>
          <h2 class="font-heading text-titanium-white mb-3" style="font-size: var(--text-fluid-2xl); line-height: 1.2;">
            Press Inquiries
          </h2>
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: 1.6;">
            For interviews, comments, or media requests, contact Spencer Bennett directly at <a href="mailto:hello@untitledmixedmedia.com" class="text-titanium-white underline hover:text-soft-gray transition-colors duration-200">hello@untitledmixedmedia.com</a>. Please include your publication name, deadline, and the topic you are covering. Response time is typically within 24 hours.
          </p>
        </div>

        <!-- Brand Assets -->
        <div>
          <h2 class="font-heading text-titanium-white mb-3" style="font-size: var(--text-fluid-2xl); line-height: 1.2;">
            Brand Assets
          </h2>
          <p class="font-body text-shadow-gray mb-6" style="font-size: var(--text-fluid-base); line-height: 1.6;">
            Downloadable logos, high-resolution project photography, and artist headshots for editorial use. All assets are provided for press and media coverage only. Commercial use requires written permission.
          </p>
          <div class="bg-midnight-graphite p-8 border border-slate-gray">
            <p class="font-mono text-smoke-gray uppercase mb-3" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">Download placeholder</p>
            <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-sm);">
              Add downloadable press kit: logo files (SVG, PNG), high-resolution project photos, Spencer Bennett headshot, and a one-page company fact sheet. Link to a ZIP file or a shared folder.
            </p>
          </div>
        </div>
      </div>
    </div>

    <RelatedPages heading="Related" pages={[
      { title: 'About', href: '/about', description: 'Untitled Mixed Media — hand-painted murals and signs in Richmond, VA.' },
      { title: 'Philosophy', href: '/about/philosophy', description: 'Why we start with discovery, not design.' },
      { title: 'Murals', href: '/murals', description: 'Hand-painted murals in Richmond, VA.' },
    ]} />
    <CTABlock />
  </main>
  <Footer />
</BaseLayout>
