---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import TransformationPair from '../../components/patterns/TransformationPair.astro';
import ArchitecturalReveal from '../../components/patterns/ArchitecturalReveal.astro';
import processVisit from '../../assets/images/process-visit.jpg';
import processRender from '../../assets/images/process-render.jpg';
import processPaint from '../../assets/images/process-paint.jpg';

const faqItems = [
  {
    question: 'How long does a project take?',
    answer: 'It depends entirely on the scope. Some projects are finished in a day. Others take a few weeks or a few months. We give you a realistic timeline before any work begins.',
  },
  {
    question: 'Do I need a design idea before I reach out?',
    answer: "No. Most people reach out with a feeling, not a finished concept. \"I don't know what I want yet\" is a fine starting point. That's what discovery is for.",
  },
  {
    question: 'What does the free discovery session include?',
    answer: "A conversation about your project, a site visit to see the space, and an initial assessment of what's possible. No charge, no obligation.",
  },
  {
    question: 'How many revisions are included?',
    answer: 'Two to three rounds are standard. Additional revisions beyond that are billed separately.',
  },
  {
    question: 'What is the Certificate of Provenance?',
    answer: 'A document you receive when the project is finished. It traces every visual element back to its source: where colors were collected, what materials were gathered, and how the concept connects to the real story.',
  },
  {
    question: 'What areas do you serve?',
    answer: 'Richmond, Virginia and the greater Richmond metro area. We travel for larger commissions.',
  },
];

const steps = [
  {
    number: '01',
    label: 'Discovery',
    title: 'We learn what the project should mean.',
    body: "I visit your site, study the space, and sit down with you. We talk about what the project should mean, not just what it should look like. I ask questions most painters and sign shops never get around to: what does this place mean to you, what happened here that matters, and what should someone feel when they see the finished work. I collect colors, photograph the space, and gather everything I need so the design comes from real information, not assumptions.",
    image: processVisit,
    imageAlt: 'Spencer on-site during a discovery visit, studying the wall and surrounding context',
  },
  {
    number: '02',
    label: 'Design',
    title: 'You see the finished work before we paint.',
    body: "I build a photorealistic 3D render of the design on your actual building. Not a sketch. Not a flat mockup. A picture of what your wall will look like when we're done, with accurate lighting and scale. You review it, tell me what to change, and I revise it. Two to three rounds of revisions are standard. Nothing moves forward until you say yes.",
    image: processRender,
    imageAlt: 'Photorealistic 3D render of a mural design composited onto a real building wall',
  },
  {
    number: '03',
    label: 'Paint',
    title: 'Every material chosen, every decision documented.',
    body: 'The approved design goes on the wall by hand. I match every material to the surface and climate. Professional-grade paints, primers chosen for the substrate, and protective layers chosen for the conditions. Every phase is documented. When the work is finished, you receive a Certificate of Provenance tracing every visual element back to its source.',
    image: processPaint,
    imageAlt: 'Spencer hand-painting the approved design on an exterior wall',
  },
];
---

<BaseLayout
  title="How We Work | Untitled Mixed Media"
  description="Three phases: discovery, design, and paint. You see a photorealistic render of your wall before we start. Untitled Mixed Media, Richmond, VA."
  faqItems={faqItems}
  breadcrumbItems={[
    { name: 'Home', url: '/' },
    { name: 'About', url: '/about' },
    { name: 'Process' },
  ]}
>
  <Nav />
  <main class="pb-0">

    <!-- ─── I · HERO ─────────────────────────────────────── -->
    <section class="pt-36 lg:pt-44 pb-24 lg:pb-32 px-6 lg:px-12 border-b border-slate-gray">
      <div class="max-w-7xl mx-auto">
        <Breadcrumb items={[
          { label: 'Home', href: '/' },
          { label: 'About', href: '/about' },
          { label: 'Process' },
        ]} />

        <div class="mt-12 lg:mt-20 grid lg:grid-cols-12 gap-x-8 lg:gap-x-16">
          <div class="lg:col-span-11">
            <h1
              class="font-heading text-titanium-white"
              style="font-size: var(--text-fluid-5xl); line-height: 0.95; letter-spacing: var(--tracking-tight);"
              data-animate="headline"
            >
              Your project has more depth than you think. Our process finds it.
            </h1>
          </div>
        </div>

        <div class="mt-16 lg:mt-24 max-w-3xl mx-auto">
          <p
            class="font-body text-soft-gray"
            style="font-size: var(--text-fluid-lg); line-height: var(--leading-relaxed);"
            data-animate="fade"
            data-animate-delay="1"
          >
            Most people reach out with a vague idea. We add clarity and depth to that starting point, so the finished work expresses who you actually are.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── II · HOW THIS IS DIFFERENT ─────────────────── -->
    <section class="py-24 lg:py-36 px-6 lg:px-12 border-b border-slate-gray">
      <div class="max-w-7xl mx-auto">

        <!-- Heading + body: split layout -->
        <div class="grid lg:grid-cols-12 gap-x-8 lg:gap-x-16">
          <div class="lg:col-span-5 mb-10 lg:mb-0">
            <h2
              class="font-heading text-titanium-white"
              style="font-size: var(--text-fluid-3xl); line-height: 1.04; letter-spacing: var(--tracking-snug);"
              data-animate="headline"
            >
              What most muralists and sign shops skip.
            </h2>
          </div>

          <div class="lg:col-span-7 space-y-8">
            <p
              class="font-body text-soft-gray"
              style="font-size: var(--text-fluid-lg); line-height: var(--leading-relaxed);"
              data-animate="fade"
            >
              Most muralists show up with a portfolio and start painting. Most sign shops print your logo on vinyl and install it in a week. Both produce what you asked for. Neither digs into what you actually meant.
            </p>
            <p
              class="font-body text-soft-gray"
              style="font-size: var(--text-fluid-lg); line-height: var(--leading-relaxed);"
              data-animate="fade"
              data-animate-delay="1"
            >
              I look at every project from three angles before I design anything. Is the concept creative enough to surprise people? Is it functional enough to work in the real world? Does it express something authentic about who you are?
            </p>
            <p
              class="font-body text-soft-gray"
              style="font-size: var(--text-fluid-lg); line-height: var(--leading-relaxed);"
              data-animate="fade"
              data-animate-delay="2"
            >
              A fine artist might chase a creative idea that doesn&rsquo;t survive its first winter. A sign shop might produce something functional with zero personality. A muralist might paint something expressive that ignores the viewing distance and fades in two years. I treat all three as non-negotiable. The overlap is where the best work happens.
            </p>
          </div>
        </div>

        <!-- Restaurant story as an editorial pullquote, centered -->
        <div class="mt-24 lg:mt-32 max-w-3xl mx-auto">
          <div class="relative py-8 lg:py-12" data-animate="fade">
            <span aria-hidden="true" class="block h-px bg-titanium-white w-20 mb-10 lg:mb-14"></span>
            <p
              class="font-heading italic text-titanium-white max-w-[26ch]"
              style="font-size: var(--text-fluid-3xl); line-height: 1.14; letter-spacing: var(--tracking-snug);"
            >
              A restaurant owner walks in saying &ldquo;I want something food-related&rdquo; and walks out with a concept built around the summer her grandmother taught her to cook. That clarity doesn&rsquo;t come from guessing. It comes from the process.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="px-6 lg:px-12 py-8">
      <div class="max-w-7xl mx-auto">
        <TransformationPair
          leftImage="/images/content-design/carytown-render.jpg"
          rightImage="/images/content-design/carytown-finished.jpg"
          leftAlt="3D pre-visualization render"
          rightAlt="The finished hand-painted mural"
          leftLabel="Render"
          rightLabel="Reality"
        />
      </div>
    </div>

    <!-- ─── III · THREE STEPS ──────────────────────────── -->
    <section class="bg-midnight-graphite py-24 lg:py-36 px-6 lg:px-12 border-b border-slate-gray">
      <div class="max-w-7xl mx-auto">

        <div class="max-w-3xl mx-auto mb-20 lg:mb-28">
          <h2
            class="font-heading text-titanium-white"
            style="font-size: var(--text-fluid-3xl); line-height: 1.04; letter-spacing: var(--tracking-snug);"
            data-animate="headline"
          >
            Three steps. You know what&rsquo;s happening at every stage.
          </h2>
        </div>

        <ol class="space-y-24 lg:space-y-40 list-none">
          {steps.map((step, i) => {
            const isReversed = i % 2 === 1;
            return (
              <li>
                <article class="grid lg:grid-cols-12 gap-x-8 gap-y-10 lg:gap-x-16 items-start">
                  <!-- Image -->
                  <div class={`lg:col-span-7 ${isReversed ? 'lg:order-2' : 'lg:order-1'}`}>
                    <div class="aspect-[4/3] overflow-hidden" data-animate="reveal">
                      <Image
                        src={step.image}
                        alt={step.imageAlt}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    </div>
                  </div>

                  <!-- Text -->
                  <div class={`lg:col-span-5 ${isReversed ? 'lg:order-1' : 'lg:order-2'}`}>
                    <div class="flex items-baseline gap-6 mb-6 lg:mb-8" data-animate="fade">
                      <span
                        class="font-heading text-slate-gray"
                        style="font-size: var(--text-fluid-4xl); line-height: 0.85;"
                        aria-hidden="true"
                      >
                        {step.number}
                      </span>
                      <span class="h-px flex-1 bg-slate-gray" aria-hidden="true"></span>
                      <span
                        class="font-mono text-titanium-white uppercase"
                        style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
                      >
                        {step.label}
                      </span>
                    </div>
                    <h3
                      class="font-heading text-titanium-white mb-6 lg:mb-8"
                      style="font-size: var(--text-fluid-2xl); line-height: 1.12; letter-spacing: var(--tracking-snug);"
                      data-animate="fade"
                      data-animate-delay="1"
                    >
                      {step.title}
                    </h3>
                    <p
                      class="font-body text-soft-gray"
                      style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);"
                      data-animate="fade"
                      data-animate-delay="2"
                    >
                      {step.body}
                    </p>
                  </div>
                </article>
              </li>
            );
          })}
        </ol>

        <!-- Editorial text-link CTA after Step 3 -->
        <div class="mt-24 lg:mt-32 max-w-3xl mx-auto pt-10 lg:pt-14 border-t border-slate-gray" data-animate="fade">
          <a
            href="/contact"
            class="cta-link group inline-flex items-baseline gap-4 lg:gap-6 font-heading text-titanium-white pb-3 border-b border-titanium-white hover:border-soft-gray"
            style="font-size: var(--text-fluid-xl); letter-spacing: var(--tracking-snug);"
          >
            <span>Schedule Your Free Discovery Session</span>
            <span aria-hidden="true" class="cta-arrow inline-block">&rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <ArchitecturalReveal
      image="/images/content-design/trolley-full.jpg"
      alt="Finished mural on a Richmond building"
      class="my-8"
    />

    <!-- ─── IV · WHAT YOU WALK AWAY WITH ──────────────── -->
    <section class="py-24 lg:py-36 px-6 lg:px-12 border-b border-slate-gray">
      <div class="max-w-7xl mx-auto">

        <!-- Heading + pullquote -->
        <div class="max-w-3xl mx-auto">
          <h2
            class="font-heading text-titanium-white"
            style="font-size: var(--text-fluid-3xl); line-height: 1.04; letter-spacing: var(--tracking-snug);"
            data-animate="headline"
          >
            The finished work doesn&rsquo;t just look good. It feels like yours.
          </h2>

          <div class="mt-16 lg:mt-24 pt-10 lg:pt-14 border-t border-slate-gray" data-animate="fade">
            <p
              class="font-heading italic text-titanium-white max-w-[30ch]"
              style="font-size: var(--text-fluid-2xl); line-height: 1.22; letter-spacing: var(--tracking-snug);"
            >
              The idea you started with is still there. But it&rsquo;s sharper, deeper, and more specific than you thought it could be. The mural tells your story in a way you couldn&rsquo;t have articulated on your own. The sign carries your name with intention you didn&rsquo;t know was possible. The restored ghost sign brings back a piece of history that was disappearing one year at a time. That&rsquo;s what the process is for.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── V · FAQ ─────────────────────────────────────── -->
    <section class="py-24 lg:py-36 px-6 lg:px-12 border-b border-slate-gray">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-12 gap-x-8 lg:gap-x-16">

        <!-- Heading occupies the left column -->
        <div class="lg:col-span-5 mb-12 lg:mb-0">
          <h2
            class="font-heading text-titanium-white"
            style="font-size: var(--text-fluid-3xl); line-height: 1.04; letter-spacing: var(--tracking-snug);"
            data-animate="headline"
          >
            Common questions about the process.
          </h2>
        </div>

        <!-- Accordion occupies the right column -->
        <div class="lg:col-span-7" data-animate="fade">
          {faqItems.map((item, i) => (
            <details class={`faq-item group border-t border-slate-gray ${i === faqItems.length - 1 ? 'border-b' : ''}`}>
              <summary class="faq-summary flex items-start justify-between gap-8 py-7 lg:py-8 cursor-pointer">
                <span
                  class="font-heading text-titanium-white group-hover:text-soft-gray transition-colors duration-200"
                  style="font-size: var(--text-fluid-lg); line-height: 1.3;"
                >
                  {item.question}
                </span>
                <span class="faq-icon shrink-0 text-titanium-white" aria-hidden="true"></span>
              </summary>
              <div class="faq-content pb-8 lg:pb-10 pr-0 lg:pr-12">
                <p
                  class="font-body text-soft-gray"
                  style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);"
                >
                  {item.answer}
                </p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <RelatedPages heading="Related" pages={[
      { title: 'Philosophy', href: '/about/philosophy', description: 'Why we start with discovery, not design.' },
      { title: 'Insurance & Licensing', href: '/about/insurance-and-licensing', description: 'Credentials, coverage, and compliance.' },
      { title: 'Murals', href: '/murals', description: 'Hand-painted murals in Richmond, VA.' },
    ]} />

    <CTABlock />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* CTA arrow glide */
  .cta-link .cta-arrow {
    display: inline-block;
    transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta-link:hover .cta-arrow,
  .cta-link:focus-visible .cta-arrow {
    transform: translateX(0.5rem);
  }

  /* Hide native details marker */
  .faq-summary::-webkit-details-marker {
    display: none;
  }
  .faq-summary {
    list-style: none;
  }
  .faq-summary::marker {
    display: none;
  }

  /* Plus / minus icon */
  .faq-icon {
    position: relative;
    display: inline-block;
    width: 20px;
    height: 20px;
    margin-top: 0.35em;
  }
  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background: currentColor;
    transition: transform 300ms ease, opacity 300ms ease;
  }
  /* horizontal bar */
  .faq-icon::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    transform: translateY(-50%);
  }
  /* vertical bar */
  .faq-icon::after {
    left: 50%;
    top: 0;
    width: 1px;
    height: 100%;
    transform: translateX(-50%) scaleY(1);
    transform-origin: center;
  }
  /* Collapse vertical bar to form a minus */
  .faq-item[open] .faq-icon::after {
    transform: translateX(-50%) scaleY(0);
  }

  /* Content fade in when opened */
  .faq-item[open] .faq-content {
    animation: faqFadeIn 360ms ease both;
  }

  @keyframes faqFadeIn {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Keyboard focus ring */
  .faq-summary:focus-visible {
    outline: 2px solid var(--color-titanium-white, #EEECE9);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-icon::before,
    .faq-icon::after {
      transition: none;
    }
    .faq-item[open] .faq-content {
      animation: none;
    }
    .cta-link .cta-arrow {
      transition: none;
    }
  }
</style>
