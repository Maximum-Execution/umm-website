---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<BaseLayout
  title="Contact Spencer | Hand-Painted Murals & Signs | Richmond, VA"
  description="Get in touch about a mural, hand-painted sign, or sign restoration project in Richmond, Virginia. Tell us about your wall."
  breadcrumbItems={[
    { name: 'Home', url: '/' },
    { name: 'Contact' },
  ]}
>
  <Nav />
  <main class="pb-16">
    <div class="px-6 lg:px-12 max-w-7xl mx-auto pt-32 lg:pt-36">

      <!-- ============================================ -->
      <!-- HERO: DEFAULT VARIANT                         -->
      <!-- ============================================ -->
      <div data-variant="default" class="mb-10 lg:mb-16">
        <div class="w-12 h-0.5 bg-[var(--color-editorial-accent)] mb-4"></div>
        <p class="font-mono uppercase mb-5 lg:mb-6" style="font-size: 11px; letter-spacing: 0.24em; color: rgba(238,236,233,0.72);">
          <span style="color: var(--color-editorial-accent); font-weight: 600;">&sect; 01</span>
          <span style="color: rgba(238,236,233,0.45); margin: 0 8px;">&middot;</span>
          Contact
        </p>
        <h1 class="font-heading text-titanium-white" style="font-size: var(--text-fluid-5xl); line-height: 1.05; letter-spacing: -0.02em; font-weight: 500; text-wrap: balance; max-width: 22ch;" data-animate="headline">
          Tell us about your project. <span class="italic-accent">We'll take it from here.</span>
        </h1>
        <p class="mt-8 lg:mt-10 font-body text-soft-gray" style="font-size: var(--text-fluid-lg); line-height: var(--leading-relaxed);" data-animate>
          Describe what you're thinking. It doesn't have to be finished or figured out yet. We respond within one business day, and if the project is a good fit, we'll schedule a free site visit to see the space in person before we design anything.
        </p>
      </div>

      <!-- ============================================ -->
      <!-- HERO: BRAND MARK VARIANT                      -->
      <!-- ============================================ -->
      <div data-variant="brand-mark" style="display: none;" class="mb-10 lg:mb-16">
        <div class="w-12 h-0.5 bg-[var(--color-editorial-accent)] mb-4"></div>
        <p class="font-mono uppercase mb-5 lg:mb-6" style="font-size: 11px; letter-spacing: 0.24em; color: rgba(238,236,233,0.72);">
          <span style="color: var(--color-editorial-accent); font-weight: 600;">The Brand Mark</span>
          <span style="color: rgba(238,236,233,0.45); margin: 0 8px;">&middot;</span>
          $500 / Same Week
        </p>
        <h2 class="font-heading text-titanium-white" style="font-size: var(--text-fluid-5xl); line-height: 1.05; letter-spacing: -0.02em; font-weight: 500; text-wrap: balance; max-width: 22ch;" data-animate="headline">
          Tell me <span class="italic-accent">what you're thinking.</span>
        </h2>
        <p class="mt-8 lg:mt-10 font-body text-soft-gray" style="font-size: var(--text-fluid-lg); line-height: var(--leading-relaxed);" data-animate>
          Your words, hand-painted on wood. On your wall by the end of the week. I read every inquiry myself, and if it's a fit, I'll follow up within 24 hours to confirm the details and get started.
        </p>
      </div>

      <!-- ============================================ -->
      <!-- FORMS + SIDEBAR                               -->
      <!-- ============================================ -->
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-16">
        <div class="lg:col-span-7">

          <!-- ============================================ -->
          <!-- FORM: DEFAULT VARIANT                         -->
          <!-- ============================================ -->
          <form data-variant="default" class="space-y-6 mb-16" action="#" method="GET" id="contact-form">
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
            <fieldset class="space-y-6 border-0 m-0 p-0">
              <legend class="sr-only">Tell us about your project</legend>
              <div>
                <label for="contact-name" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Name</label>
                <input type="text" id="contact-name" name="name" required autocomplete="name" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);" placeholder="Your name" />
              </div>
              <div>
                <label for="contact-email" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Email</label>
                <input type="email" id="contact-email" name="email" required autocomplete="email" aria-describedby="contact-email-error" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);" placeholder="you@example.com" />
                <p id="contact-email-error" class="hidden font-body text-red-400 mt-2" style="font-size: var(--text-fluid-xs);" role="alert">Please enter a valid email address (e.g., name@example.com).</p>
              </div>
              <div>
                <label for="contact-phone" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Phone <span class="text-smoke-gray">(optional)</span></label>
                <input type="tel" id="contact-phone" name="phone" autocomplete="tel" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);" placeholder="(804) 555-0100" />
              </div>
              <div>
                <label for="contact-project-type" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Project Type</label>
                <select id="contact-project-type" name="project_type" required class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);">
                  <option value="" disabled selected>Select a project type</option>
                  <option value="mural">Mural</option>
                  <option value="hand-painted-sign">Hand-Painted Sign</option>
                  <option value="brand-mark">Brand Mark</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="contact-message" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Message</label>
                <p id="contact-message-help" class="font-body text-smoke-gray mb-2" style="font-size: var(--text-fluid-xs); line-height: var(--leading-relaxed);">A few things that help us prepare: the type of project, the location, the size of the wall or surface, any ideas you have so far, and your timeline if you have one.</p>
                <textarea id="contact-message" name="message" required rows="6" aria-describedby="contact-message-help" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);"></textarea>
              </div>
              <div>
                <label for="contact-timeline" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Timeline <span class="text-smoke-gray">(optional)</span></label>
                <select id="contact-timeline" name="timeline" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);">
                  <option value="" disabled selected>When do you need this done?</option>
                  <option value="asap">As soon as possible</option>
                  <option value="1-3-months">1-3 months</option>
                  <option value="3-6-months">3-6 months</option>
                  <option value="planning">Just planning / no rush</option>
                </select>
              </div>
              <div>
                <label for="contact-budget" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Budget Range <span class="text-smoke-gray">(optional)</span></label>
                <select id="contact-budget" name="budget_range" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);">
                  <option value="" disabled selected>What is your budget range?</option>
                  <option value="brand-mark">Brand Mark ($500)</option>
                  <option value="under-5k">Under $5,000</option>
                  <option value="5k-15k">$5,000 - $15,000</option>
                  <option value="15k-50k">$15,000 - $50,000</option>
                  <option value="50k-plus">$50,000+</option>
                  <option value="unsure">Not sure yet</option>
                </select>
              </div>
            </fieldset>
            <div class="mt-10 space-y-3">
              <Button type="submit" variant="primary" size="large">
                Send Your Project Details
              </Button>
              <p class="font-body text-smoke-gray" style="font-size: var(--text-fluid-xs);">Spencer reads every message personally. No auto-replies. No sales team.</p>
              <p id="form-status" class="font-body text-soft-gray hidden" role="status" aria-live="polite" style="font-size: var(--text-fluid-sm);"></p>
            </div>
          </form>

          <!-- ============================================ -->
          <!-- FORM: BRAND MARK VARIANT                      -->
          <!-- ============================================ -->
          <form data-variant="brand-mark" style="display: none;" class="space-y-6 mb-16" action="#" method="GET" id="brand-mark-form">
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="project_type" value="brand-mark" />
            <input type="hidden" name="format" value="panel" />
            <fieldset class="space-y-6 border-0 m-0 p-0">
              <legend class="sr-only">Commission a Brand Mark</legend>

              <div>
                <label for="bm-words" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">What words do you want painted?</label>
                <p class="font-body text-smoke-gray mb-2" style="font-size: var(--text-fluid-xs); line-height: var(--leading-relaxed);">Your business name, your logo wordmark, a phrase. Whatever belongs on the panel.</p>
                <input type="text" id="bm-words" name="words" required class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);" placeholder="e.g., Scott's Addition Supply Co." />
              </div>

              <div>
                <label for="bm-neighborhood" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Which neighborhood is your business in?</label>
                <select id="bm-neighborhood" name="neighborhood" required class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);">
                  <option value="" disabled selected>Select a neighborhood</option>
                  <option value="scotts-addition">Scott's Addition</option>
                  <option value="carytown">Carytown</option>
                  <option value="church-hill">Church Hill</option>
                  <option value="manchester">Manchester</option>
                  <option value="the-fan">The Fan</option>
                  <option value="jackson-ward">Jackson Ward</option>
                  <option value="shockoe-bottom">Shockoe Bottom</option>
                  <option value="brookland-park">Brookland Park</option>
                  <option value="oregon-hill">Oregon Hill</option>
                  <option value="other">Other / Outside Richmond</option>
                </select>
              </div>

              <div>
                <label for="bm-logo" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Upload your logo or reference image <span class="text-smoke-gray">(optional)</span></label>
                <p class="font-body text-smoke-gray mb-2" style="font-size: var(--text-fluid-xs); line-height: var(--leading-relaxed);">PNG, JPG, PDF, or SVG. If you don't have a logo yet, skip this and describe it in the notes below.</p>
                <input type="file" id="bm-logo" name="logo" accept="image/*,.pdf,.svg" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white file:bg-bone-black file:text-titanium-white file:border-0 file:px-4 file:py-1 file:mr-4 file:font-sans file:uppercase file:tracking-wider file:text-xs" style="font-size: var(--text-fluid-sm);" />
              </div>

              <div>
                <label for="bm-notes" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Anything else I should know? <span class="text-smoke-gray">(optional)</span></label>
                <textarea id="bm-notes" name="notes" rows="4" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);" placeholder="Colors you're drawn to, where the panel will hang, a specific date you need it by."></textarea>
              </div>

              <div class="pt-2 border-t border-slate-gray">
                <p class="font-mono text-smoke-gray uppercase mb-4" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">Your Information</p>
              </div>

              <div>
                <label for="bm-name" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Name</label>
                <input type="text" id="bm-name" name="name" required autocomplete="name" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);" placeholder="Your name" />
              </div>

              <div>
                <label for="bm-email" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Email</label>
                <input type="email" id="bm-email" name="email" required autocomplete="email" aria-describedby="bm-email-error" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);" placeholder="you@example.com" />
                <p id="bm-email-error" class="hidden font-body text-red-400 mt-2" style="font-size: var(--text-fluid-xs);" role="alert">Please enter a valid email address (e.g., name@example.com).</p>
              </div>

              <div>
                <label for="bm-phone" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Phone <span class="text-smoke-gray">(optional)</span></label>
                <input type="tel" id="bm-phone" name="phone" autocomplete="tel" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body focus:outline-none focus:border-titanium-white" style="font-size: var(--text-fluid-base);" placeholder="(804) 555-0100" />
              </div>
            </fieldset>

            <div class="mt-10 space-y-3">
              <Button type="submit" variant="primary" size="large">
                Send to Spencer
              </Button>
              <p class="font-body text-smoke-gray" style="font-size: var(--text-fluid-xs);">Spencer will follow up within 24 hours.</p>
              <p id="bm-form-status" class="font-body text-soft-gray hidden" role="status" aria-live="polite" style="font-size: var(--text-fluid-sm);"></p>
            </div>
          </form>

        </div>

        <!-- ============================================ -->
        <!-- SIDEBAR: DEFAULT VARIANT                      -->
        <!-- ============================================ -->
        <div data-variant="default" class="lg:col-span-4 lg:col-start-9">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-heading text-titanium-white mb-10 lg:mb-14" style="font-size: var(--text-fluid-xl); line-height: 1.3;">
              Direct Contact
            </h2>
            <div class="space-y-4">
              <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
                <strong class="text-titanium-white block mb-1">Email</strong>
                <a href="mailto:hello@untitledmixedmedia.com" class="text-soft-gray hover:text-titanium-white transition-colors duration-200">hello@untitledmixedmedia.com</a>
              </p>
              <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
                <strong class="text-titanium-white block mb-1">Location</strong>
                Richmond, Virginia. We serve the greater Richmond metro area and travel for larger commissions.
              </p>
              <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
                We respond to every inquiry within one business day.
              </p>
            </div>
          </div>
        </div>

        <!-- ============================================ -->
        <!-- SIDEBAR: BRAND MARK VARIANT                   -->
        <!-- ============================================ -->
        <div data-variant="brand-mark" style="display: none;" class="lg:col-span-4 lg:col-start-9">
          <div class="lg:sticky lg:top-32 border border-slate-gray bg-midnight-graphite p-6 lg:p-8">
            <p class="font-mono text-smoke-gray uppercase mb-4" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
              What's Included
            </p>
            <h2 class="font-heading text-titanium-white mb-10 lg:mb-14" style="font-size: var(--text-fluid-xl); line-height: 1.3;">
              $500. Same week.
            </h2>
            <ul class="space-y-3 mb-8">
              <li class="font-body text-soft-gray flex gap-3" style="font-size: var(--text-fluid-sm); line-height: var(--leading-relaxed);">
                <span class="text-titanium-white">/</span>
                <span>Your words, hand-painted on a wood panel</span>
              </li>
              <li class="font-body text-soft-gray flex gap-3" style="font-size: var(--text-fluid-sm); line-height: var(--leading-relaxed);">
                <span class="text-titanium-white">/</span>
                <span>Professional-grade archival materials</span>
              </li>
              <li class="font-body text-soft-gray flex gap-3" style="font-size: var(--text-fluid-sm); line-height: var(--leading-relaxed);">
                <span class="text-titanium-white">/</span>
                <span>Finished panel, ready to hang</span>
              </li>
              <li class="font-body text-soft-gray flex gap-3" style="font-size: var(--text-fluid-sm); line-height: var(--leading-relaxed);">
                <span class="text-titanium-white">/</span>
                <span>The Collector's Guarantee</span>
              </li>
            </ul>
            <div class="pt-6 border-t border-slate-gray">
              <p class="font-body text-soft-gray mb-2" style="font-size: var(--text-fluid-sm); line-height: var(--leading-relaxed);">
                <strong class="text-titanium-white block mb-1">Questions first?</strong>
                <a href="mailto:hello@untitledmixedmedia.com" class="text-soft-gray hover:text-titanium-white transition-colors duration-200">hello@untitledmixedmedia.com</a>
              </p>
            </div>
          </div>
        </div>

      </div>

      <script>
        // URL-param-driven variant toggle
        const params = new URLSearchParams(window.location.search);
        const variant = params.get('type') === 'brand-mark' ? 'brand-mark' : 'default';

        if (variant === 'brand-mark') {
          document.querySelectorAll('[data-variant="default"]').forEach((el) => {
            (el as HTMLElement).style.display = 'none';
          });
          document.querySelectorAll('[data-variant="brand-mark"]').forEach((el) => {
            (el as HTMLElement).style.display = '';
          });
          document.title = 'Commission a Brand Mark | Untitled Mixed Media';
        }

        // Default form submit
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const status = document.getElementById('form-status') as HTMLElement;
        const emailInput = document.getElementById('contact-email') as HTMLInputElement;
        const emailError = document.getElementById('contact-email-error') as HTMLElement;

        emailInput?.addEventListener('blur', () => {
          if (emailInput.value && !emailInput.validity.valid) {
            emailInput.classList.add('border-red-400');
            emailInput.classList.remove('border-slate-gray');
            emailInput.setAttribute('aria-invalid', 'true');
            emailError?.classList.remove('hidden');
          } else {
            emailInput.classList.remove('border-red-400');
            emailInput.classList.add('border-slate-gray');
            emailInput.removeAttribute('aria-invalid');
            emailError?.classList.add('hidden');
          }
        });

        emailInput?.addEventListener('focus', () => {
          emailInput.classList.remove('border-red-400');
          emailInput.classList.add('border-slate-gray');
          emailInput.removeAttribute('aria-invalid');
          emailError?.classList.add('hidden');
        });

        // Build a readable email body from form fields, skipping the honeypot and empty fields.
        const buildMailtoBody = (formEl: HTMLFormElement, labelMap: Record<string, string>) => {
          const data = new FormData(formEl);
          const lines: string[] = [];
          for (const [key, value] of data.entries()) {
            if (key === '_gotcha') continue;
            if (value instanceof File) continue;
            const v = String(value).trim();
            if (!v) continue;
            const label = labelMap[key] || key;
            lines.push(`${label}: ${v}`);
          }
          return lines.join('\n');
        };

        form?.addEventListener('submit', (e) => {
          e.preventDefault();
          const labels: Record<string, string> = {
            name: 'Name',
            email: 'Email',
            phone: 'Phone',
            project_type: 'Project Type',
            message: 'Message',
            timeline: 'Timeline',
            budget_range: 'Budget Range',
          };
          const body = buildMailtoBody(form, labels);
          const subject = 'New project inquiry from untitledmixedmedia.com';
          window.location.href = `mailto:hello@untitledmixedmedia.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
          status.textContent = 'Your email app should open with your message ready to send. If nothing happens, email hello@untitledmixedmedia.com directly.';
          status.classList.remove('hidden');
          status.classList.remove('text-red-400');
          status.classList.add('text-titanium-white');
        });

        // Brand Mark form submit
        const bmForm = document.getElementById('brand-mark-form') as HTMLFormElement;
        const bmStatus = document.getElementById('bm-form-status') as HTMLElement;
        const bmEmailInput = document.getElementById('bm-email') as HTMLInputElement;
        const bmEmailError = document.getElementById('bm-email-error') as HTMLElement;

        bmEmailInput?.addEventListener('blur', () => {
          if (bmEmailInput.value && !bmEmailInput.validity.valid) {
            bmEmailInput.classList.add('border-red-400');
            bmEmailInput.classList.remove('border-slate-gray');
            bmEmailInput.setAttribute('aria-invalid', 'true');
            bmEmailError?.classList.remove('hidden');
          } else {
            bmEmailInput.classList.remove('border-red-400');
            bmEmailInput.classList.add('border-slate-gray');
            bmEmailInput.removeAttribute('aria-invalid');
            bmEmailError?.classList.add('hidden');
          }
        });

        bmEmailInput?.addEventListener('focus', () => {
          bmEmailInput.classList.remove('border-red-400');
          bmEmailInput.classList.add('border-slate-gray');
          bmEmailInput.removeAttribute('aria-invalid');
          bmEmailError?.classList.add('hidden');
        });

        bmForm?.addEventListener('submit', (e) => {
          e.preventDefault();
          const labels: Record<string, string> = {
            words: 'Words to paint',
            neighborhood: 'Neighborhood',
            notes: 'Notes',
            name: 'Name',
            email: 'Email',
            phone: 'Phone',
            project_type: 'Project Type',
            format: 'Format',
          };
          const body = buildMailtoBody(bmForm, labels) + '\n\n(If you have a logo or reference image, please attach it to this email before sending.)';
          const subject = 'Brand Mark commission inquiry';
          window.location.href = `mailto:hello@untitledmixedmedia.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
          bmStatus.textContent = 'Your email app should open with your message ready to send. Attach your logo or reference image before sending. If nothing happens, email hello@untitledmixedmedia.com directly.';
          bmStatus.classList.remove('hidden');
          bmStatus.classList.remove('text-red-400');
          bmStatus.classList.add('text-titanium-white');
        });
      </script>

    </div>
  </main>
  <Footer />
