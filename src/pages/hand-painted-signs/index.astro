---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SlideInCTA from '../../components/SlideInCTA.astro';
import { getCollection } from 'astro:content';

const signProjects = (await getCollection('projects'))
  .filter((p) => p.data.tags.some((t: string) => t.toLowerCase().includes('sign')))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Hand-Painted Signs — Untitled Mixed Media | Richmond VA Sign Painter"
  description="Hand-painted signs, gold leaf lettering, window lettering, and sign restoration in Richmond, Virginia. Craft that outlasts vinyl."
  breadcrumbItems={[
    { name: 'Home', url: '/' },
    { name: 'Work', url: '/work' },
    { name: 'Hand-Painted Signs' },
  ]}
  service={{
    name: 'Hand-Painted Signs',
    description: 'Hand-painted signs, gold leaf lettering, window lettering, and sign restoration in Richmond, Virginia.',
    priceRange: '$500 - $10,000+',
  }}
>
  <Nav />
  <main class="pt-24 pb-16 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Work', href: '/work' },
        { label: 'Hand-Painted Signs' },
      ]} />

      <p class="font-mono text-smoke-gray uppercase mb-4" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
        Hand-Painted Signs
      </p>

      <h1 class="font-heading text-titanium-white mb-6 text-balance" data-animate="headline">
        If you can order your sign online, so can your competitor.
      </h1>

      <p class="font-body text-shadow-gray mb-16 max-w-2xl" style="font-size: var(--text-fluid-lg);" data-animate>
        Vinyl signs start deteriorating the day they go up. Hand-painted lettering does the opposite. It ages into the building, developing the kind of patina that makes a business look established rather than temporary. Gold leaf, enamel, window gilding, and traditional sign-painting techniques that have lasted centuries. Every letter placed by hand.
      </p>

      <p class="font-heading text-titanium-white italic max-w-3xl my-12"
         style="font-size: var(--text-fluid-2xl); line-height: var(--leading-snug);"
         data-animate="settle">
        A hand-painted sign doesn't just look different. It is different.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-[var(--spacing-section)]">
        <div data-animate="fade" data-animate-delay="1">
          <ServiceCard
            title="Storefront Signs Richmond VA"
            description="The first thing customers see. Painted lettering that makes your storefront impossible to walk past without noticing."
            href="/hand-painted-signs/storefront-signs-richmond-va"
          />
        </div>
        <div data-animate="fade" data-animate-delay="2">
          <ServiceCard
            title="Gold Leaf Signs"
            description="23-karat gold leaf lettering applied by hand. Catches light in a way no paint, print, or vinyl can replicate. The highest standard in sign craft."
            href="/hand-painted-signs/gold-leaf-signs"
          />
        </div>
        <div data-animate="fade" data-animate-delay="3">
          <ServiceCard
            title="Window Lettering"
            description="Lettering painted on the interior face of glass so it reads from the street. The sign is part of the window, not stuck to it."
            href="/hand-painted-signs/window-lettering"
          />
        </div>
        <div data-animate="fade" data-animate-delay="1">
          <ServiceCard
            title="Bar & Restaurant Signs"
            description="Your sign sets the atmosphere before anyone walks in. Exterior identity, chalkboards, and menu systems for bars and restaurants."
            href="/hand-painted-signs/bar-and-restaurant-signs"
          />
        </div>
        <div data-animate="fade" data-animate-delay="2">
          <ServiceCard
            title="Interior Signs"
            description="Lobby lettering, wayfinding, and branded walls. The spaces your customers see inside deserve the same craft as the ones they see outside."
            href="/hand-painted-signs/interior-signs"
          />
        </div>
        <div data-animate="fade" data-animate-delay="3">
          <ServiceCard
            title="Hand-Painted Menus"
            description="Menu boards and specials boards painted once and built for years of daily use. No peeling, no reprinting, no replacement."
            href="/hand-painted-signs/hand-painted-menus"
          />
        </div>
      </div>

      <!-- Why Hand-Painted -->
      <section class="border-t border-slate-gray pt-[var(--spacing-section)] mb-[var(--spacing-section)]">
        <h2 class="font-mono text-smoke-gray uppercase mb-8" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
          Why Hand-Painted
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div data-animate="fade" data-animate-delay="1" class="border-l-2 border-titanium-white pl-4">
            <ServiceCard
              title="Hand-Painted vs Vinyl"
              description="Vinyl starts failing the day it goes up. Hand-painted lettering does the opposite. A direct comparison of durability, appearance, and long-term cost."
              href="/hand-painted-signs/hand-painted-vs-vinyl"
            />
          </div>
          <div data-animate="fade" data-animate-delay="2" class="border-l-2 border-titanium-white pl-4">
            <ServiceCard
              title="Cost Per Year Comparison"
              description="Spread over 10+ years, hand-painted signs cost less than vinyl. The math behind longevity, laid out plainly."
              href="/hand-painted-signs/cost-per-year-comparison"
            />
          </div>
          <div data-animate="fade" data-animate-delay="3" class="border-l-2 border-titanium-white pl-4">
            <ServiceCard
              title="Why Hand-Painted Signs Last Longer"
              description="The materials science behind longevity. What enamel, gold leaf, and proper surface preparation actually do, and why vinyl cannot compete."
              href="/hand-painted-signs/why-hand-painted-signs-last-longer"
            />
          </div>
        </div>
      </section>

      <!-- Pull Quote -->
      <blockquote class="border-l-2 border-titanium-white pl-6 mb-[var(--spacing-section)]" data-animate="settle">
        <p class="font-heading text-titanium-white italic mb-4" style="font-size: var(--text-fluid-xl); line-height: var(--leading-snug);">
          "Sign restoration requires more patience than any other part of a project. The letters have to sit in space the way the original sat in space. This isn't recreation. It's recovery."
        </p>
        <cite class="font-mono text-smoke-gray uppercase not-italic" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
          Church Hill Trolley Barn Restoration, Richmond VA
        </cite>
      </blockquote>

      <!-- Sign Restoration -->
      <section class="border-t border-slate-gray pt-[var(--spacing-section)] mb-[var(--spacing-section)]">
        <h2 class="font-mono text-smoke-gray uppercase mb-8" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
          Restoration
        </h2>
        <div class="max-w-lg">
          <ServiceCard
            title="Sign Restoration"
            description="Restoring faded, damaged, and historic signs. Ghost signs, gilded lettering, and century-old painted advertisements brought back to life."
            href="/hand-painted-signs/sign-restoration"
          />
        </div>
      </section>

      {/* Featured Work */}
      {signProjects.length > 0 && (
        <section class="border-t border-slate-gray pt-[var(--spacing-section)] mb-[var(--spacing-section)]">
          <h2 class="font-mono text-smoke-gray uppercase mb-8" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
            Featured Sign Work
          </h2>
          <div class="grid sm:grid-cols-2 gap-8">
            {signProjects.slice(0, 4).map((project) => (
              <a href={`/work/${project.id}`} class="group block overflow-hidden" data-animate>
                <div class="aspect-[16/10] overflow-hidden bg-midnight-graphite">
                  <img
                    src={project.data.cover}
                    alt={project.data.title}
                    class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-700 ease-out"
                    loading="lazy"
                  />
                </div>
                <div class="mt-4 mb-8">
                  <h3 class="font-heading text-titanium-white group-hover:text-soft-gray transition-colors mb-2" style="font-size: var(--text-fluid-xl);">
                    {project.data.title}
                  </h3>
                  <p class="font-body text-shadow-gray line-clamp-2" style="font-size: var(--text-fluid-sm);">
                    {project.data.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Cross-hub link -->
      <p class="font-body text-shadow-gray mb-16" style="font-size: var(--text-fluid-lg);">
        We also paint <a href="/murals" class="text-titanium-white underline underline-offset-4 hover:text-soft-gray transition-colors duration-200">murals</a>.
      </p>
    </div>
  </main>

  <CTABlock />

  <SlideInCTA headline="Not ready for a full project?" />
  <Footer />
</BaseLayout>
