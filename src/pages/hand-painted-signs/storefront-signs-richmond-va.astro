---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQSection from '../../components/FAQSection.astro';
import RelatedPages from '../../components/RelatedPages.astro';

const faqItems = [
  { question: 'What size options are available for storefront signs?', answer: 'Every storefront is different. We design to your specific facade, whether that is a 2-foot transom window or a 20-foot brick wall. The site visit determines what the building can support and what will read best from the street.' },
  { question: 'How long does a storefront sign take?', answer: 'Most storefront signs take 1 to 3 weeks from design approval to completion, depending on size, detail level, and weather. We will give you a specific timeline after the site visit.' },
  { question: 'Can you paint double-sided or projecting signs?', answer: 'Yes. We paint hanging blade signs, projecting signs, and A-frame sidewalk boards. If it has a paintable surface, we can letter it.' },
];
---

<BaseLayout
  title="Hand-Painted Storefront Signs in Richmond, VA | Untitled Mixed Media"
  description="Custom hand-painted storefront signs in Richmond, Virginia. Painted lettering that gives your business real street presence."
  faqItems={faqItems}
  breadcrumbItems={[
    { name: 'Home', url: '/' },
    { name: 'Work', url: '/work' },
    { name: 'Hand-Painted Signs', url: '/hand-painted-signs' },
    { name: 'Storefront Signs' },
  ]}
  service={{
    name: 'Storefront Signs',
    description: 'Custom hand-painted storefront signs in Richmond, Virginia.',
    priceRange: '$500 - $5,000',
  }}
>
  <Nav />
  <main class="pt-32 pb-16">
    <div class="px-6 lg:px-12 max-w-7xl mx-auto">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Work', href: '/work' },
        { label: 'Hand-Painted Signs', href: '/hand-painted-signs' },
        { label: 'Storefront Signs Richmond VA' },
      ]} />

      <p class="font-mono text-smoke-gray uppercase mb-6" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">
        Hand-Painted Signs
      </p>

      <!-- Hero: split layout -->
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-16 mb-20">
        <div class="lg:col-span-7">
          <h1 class="font-heading text-titanium-white mb-6" data-animate="headline" style="font-size: var(--text-fluid-4xl); line-height: 1.05;">
        Hand-Painted Storefront Signs in Richmond, VA
      </h1>
        </div>
        <div class="lg:col-span-5 lg:flex lg:items-end">
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
          Your storefront is the first thing people see, and right now it is not stopping anyone. Vinyl lettering fades. Generic signage blends in. Customers walk past without a second look because nothing on the outside tells them something worthwhile is on the inside. You have put real effort into your business, and your sign should show it.
        </p>
        </div>
      </div>

      <!-- Body: two-column editorial -->
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 mb-20">
        <div class="space-y-6" data-animate="fade" data-animate-delay="1">
                    <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
          We have painted storefronts across Richmond, from Carytown boutiques to Scott's Addition restaurants. We know the city's architecture, its sign codes, and how to make lettering that belongs on your building. We match the technique to the facade so the sign looks like it has always been there.
        </p>
        </div>
        <div class="space-y-6" data-animate="fade" data-animate-delay="2">
                    <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
          The process is simple. We visit your site, assess the surface and the street context, and show you the design before any paint goes on. You approve it, we paint it, and the work speaks for itself: a storefront that people photograph, a sign that weathers into character, and foot traffic that starts before the door opens.
        </p>
        </div>
      </div>

      <div class="aspect-[16/9] overflow-hidden bg-midnight-graphite border border-slate-gray mb-20 flex items-center justify-center p-8">
        <p class="font-mono text-smoke-gray uppercase mb-3" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">Image placeholder</p>
        <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-sm);">Add photo of a completed Richmond storefront sign, ideally showing the full facade with the business name visible and the street context.</p>
      </div>
    </div>

    <FAQSection items={faqItems} />

    <RelatedPages heading="Related" pages={[
      { title: 'Bar & Restaurant Signs', href: '/hand-painted-signs/bar-and-restaurant-signs', description: 'Signage that builds atmosphere before guests walk in.' },
      { title: 'Sign Restoration', href: '/hand-painted-signs/sign-restoration', description: 'Restoring faded, damaged, and historic signs across Richmond.' },
      { title: 'Window Lettering', href: '/hand-painted-signs/window-lettering', description: 'Hand-painted window lettering for storefronts and doors.' },
    ]} />

    <CTABlock />
  </main>
  <Footer />
</BaseLayout>
