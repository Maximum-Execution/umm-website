---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ProcessSection from '../components/sections/ProcessSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import JournalCard from '../components/JournalCard.astro';
import CTABlock from '../components/CTABlock.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredProject = projects[0];

const journalPosts = (await getCollection('journal'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout>
  <Nav />
  <main>
    <!-- Hero — UNTOUCHED -->
    <HeroSection />

    <!-- Services Overview -->
    <section class="py-24 px-6 lg:px-12">
      <div class="max-w-7xl">
        <p class="font-mono text-smoke-gray uppercase mb-12" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">
          What We Do
        </p>
        <div class="grid md:grid-cols-2 gap-6">
          <ServiceCard
            title="Murals"
            description="Hand-painted murals for businesses, property owners, and public spaces in Richmond, Virginia. From site visit to sealed wall."
            href="/murals"
          />
          <ServiceCard
            title="Hand-Painted Signs"
            description="Gold leaf, window lettering, storefront signs, and menu boards. Traditional sign painting that outlasts vinyl by decades."
            href="/hand-painted-signs"
          />
        </div>
      </div>
    </section>

    <!-- Featured Project -->
    {featuredProject && (
      <section class="border-t border-slate-gray py-24 px-6 lg:px-12">
        <div class="max-w-7xl">
          <p class="font-mono text-smoke-gray uppercase mb-12" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">
            Featured Project
          </p>
          <a href={`/murals/${featuredProject.id}`} class="group block">
            <div class="bg-midnight-graphite border border-slate-gray aspect-[16/9] mb-8 flex items-center justify-center">
              <p class="font-mono text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs);">
                Project image — {featuredProject.data.title}
              </p>
            </div>
            <h2 class="font-heading text-titanium-white group-hover:text-soft-gray transition-colors duration-200 mb-4" style="font-size: var(--text-fluid-3xl); line-height: 1.1;">
              {featuredProject.data.title}
            </h2>
            <p class="font-body text-shadow-gray max-w-2xl" style="font-size: var(--text-fluid-base); line-height: 1.6;">
              {featuredProject.data.description}
            </p>
            {featuredProject.data.location && (
              <p class="font-mono text-smoke-gray uppercase mt-4" style="font-size: var(--text-fluid-xs);">
                {featuredProject.data.location}
              </p>
            )}
          </a>
        </div>
      </section>
    )}

    <!-- Process -->
    <ProcessSection />

    <!-- Testimonial -->
    <section class="border-t border-slate-gray py-24 px-6 lg:px-12">
      <div class="max-w-3xl">
        <blockquote>
          <p class="font-heading text-titanium-white italic mb-8" style="font-size: var(--text-fluid-2xl); line-height: 1.3;">
            "Placeholder for client testimonial. Replace with a real quote from a completed project — ideally one that speaks to the process, professionalism, and result."
          </p>
          <footer class="font-sans text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">
            — Client Name, Business Name
          </footer>
        </blockquote>
      </div>
    </section>

    <!-- Journal Preview -->
    {journalPosts.length > 0 && (
      <section class="border-t border-slate-gray py-24 px-6 lg:px-12">
        <div class="max-w-7xl">
          <div class="flex items-baseline justify-between mb-12">
            <p class="font-mono text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">
              Journal
            </p>
            <a href="/journal" class="font-mono text-smoke-gray uppercase hover:text-titanium-white transition-colors" style="font-size: var(--text-fluid-xs);">
              View all &rarr;
            </a>
          </div>
          <div class="grid md:grid-cols-3 gap-8">
            {journalPosts.map((post) => (
              <JournalCard
                title={post.data.title}
                description={post.data.description}
                href={`/journal/${post.id}`}
                date={post.data.date}
                tags={post.data.tags}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <CTABlock
      headline="See what your wall could become."
      description="Get a free estimate for your mural or sign project. We'll visit your site, show you the design before we start, and paint it right."
    />
  </main>
  <Footer />
</BaseLayout>
