---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import ScrollProgress from '../../components/ScrollProgress.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import JournalCard from '../../components/JournalCard.astro';
import BrandMarkCallout from '../../components/BrandMarkCallout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('journal');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, dateModified, tags, cover, author, faqItems } = post.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Related posts: find 2-3 other posts that share at least one tag
const allPosts = await getCollection('journal');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => ({
    post: p,
    sharedTags: p.data.tags.filter((t: string) => tags.includes(t)).length,
  }))
  .filter((p) => p.sharedTags > 0)
  .sort((a, b) => b.sharedTags - a.sharedTags)
  .slice(0, 3)
  .map((p) => p.post);
---

<BaseLayout
  title={`${title} | Untitled Mixed Media Journal`}
  description={description}
  ogImage={cover}
  ogType="article"
  blogPosting={{
    headline: title,
    description: description,
    datePublished: date.toISOString().split('T')[0],
    dateModified: (dateModified || date).toISOString().split('T')[0],
    author: author || 'Untitled Mixed Media',
    image: cover,
  }}
  faqItems={faqItems}
>
  <Nav />
  <ScrollProgress />
  <main class="pt-24 pb-16">
    <article class="px-6 lg:px-12">
      <div class="max-w-3xl mx-auto">
        <Breadcrumb items={[
          { label: 'Home', href: '/' },
          { label: 'Journal', href: '/journal' },
          { label: title },
        ]} />

        <!-- Date + Tags -->
        <div class="flex flex-wrap items-center gap-4 mb-6">
          <time
            datetime={date.toISOString().split('T')[0]}
            class="font-mono text-smoke-gray uppercase"
            style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);"
          >
            {formattedDate}
          </time>
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="font-mono text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>

        <h1 class="font-heading text-titanium-white mb-4 text-balance" style="font-size: var(--text-fluid-4xl); line-height: 1.05;" data-animate="headline">
          {title}
        </h1>

        <p class="font-mono text-smoke-gray uppercase mb-12" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
          By {author}
        </p>

        {cover && (
          <div class="aspect-[16/9] overflow-hidden mb-16">
            <img
              src={cover}
              alt={`${title} | Untitled Mixed Media journal`}
              class="w-full h-full object-cover"
              width="1200"
              height="675"
              decoding="async"
              loading="eager"
            />
          </div>
        )}

        <div class="case-study-prose">
          <Content />
        </div>

        <!-- Brand Mark Callout -->
        <div class="mt-16 lg:mt-24">
          <BrandMarkCallout variant="journal" />
        </div>
      </div>
    </article>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="px-6 lg:px-12 border-t border-slate-gray pt-[var(--spacing-section)] mt-[var(--spacing-section)]">
        <div class="max-w-7xl mx-auto">
          <h2 class="font-mono text-smoke-gray uppercase mb-8" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
            Related Posts
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-12">
            {relatedPosts.map((related) => (
              <JournalCard
                title={related.data.title}
                description={related.data.description}
                href={`/journal/${related.id}`}
                date={related.data.date}
                tags={related.data.tags}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <CTABlock />
  </main>
  <Footer />
</BaseLayout>
