---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CTABlock from '../components/CTABlock.astro';
import RelatedPages from '../components/RelatedPages.astro';
import Button from '../components/Button.astro';

const faqItems = [
  { question: "How much does a mural cost per square foot?", answer: "$15 to $80 per square foot depending on complexity. Simple graphics and lettering run $15 to $25. Moderate detail (most commercial murals) runs $25 to $40. Detailed photorealistic work runs $40 to $55. Archival heritage murals using KEIM mineral paint run $55 to $80. Volume discounts of 10 to 40 percent apply based on wall size." },
  { question: "How much does a small mural cost?", answer: "An 80-square-foot accent wall (8 by 10 feet) at simple complexity costs $1,200 to $2,000. At moderate complexity, the same wall costs $2,000 to $3,200. The minimum project cost is $500 for a Brand Mark (16-square-foot hand-painted logo)." },
  { question: "How much does an outdoor mural cost?", answer: "Exterior murals add 20 percent to the base rate for UV-resistant paint, weather-grade primer, and protective sealant. A 200-square-foot exterior mural at moderate complexity typically runs $5,400 to $8,600 after volume discount and exterior modifier." },
  { question: "How much does a restaurant mural cost?", answer: "Most restaurant murals fall in the moderate tier ($25 to $40 per square foot). A typical 200-square-foot restaurant wall costs $4,500 to $7,200 after volume discount. The price includes discovery, custom design, a 3D render showing the mural on your actual wall, and all materials and labor." },
  { question: "Is a mural a good investment for my business?", answer: "76 percent of consumers have entered a store they had never visited before based solely on its signage or visual presence (FedEx Office / ORC International survey). A mural turns a blank wall into a destination. Businesses with murals report increased foot traffic, social media visibility (people photograph and share murals), and stronger neighborhood recognition." },
  { question: "What is the cheapest type of mural?", answer: "The most affordable hand-painted option is the Brand Mark at $500: a 16-square-foot hand-painted logo on wall or panel with a ghost-sign finish. For full wall murals, the simple tier starts at $15 per square foot." },
  { question: "What factors affect mural pricing?", answer: "Five factors: wall size (square footage is the primary driver), design complexity (the tier), surface condition (drywall is baseline, brick adds 15 percent), interior vs exterior (exterior adds 20 percent), and access requirements (lift rental is a $5,000 flat fee for walls above two stories). All modifiers are additive, not multiplicative, and capped at 35 percent combined." },
  { question: "Does the estimate include design?", answer: "Yes. Every project includes a discovery session, site visit, and photorealistic 3D render showing the design on your actual wall. You approve the design before any painting begins. Design is included in the estimate, not billed separately." },
  { question: "How long does a mural take?", answer: "Most murals take 3 to 12 weeks from discovery to completion. The timeline depends on wall size, design complexity, weather (for exteriors), and scheduling. The painting phase itself typically runs 1 to 3 weeks on site." },
  { question: "Do you require a deposit?", answer: "Yes. 50 percent deposit before work begins, with the remaining balance due upon completion. For projects over $10,000, I offer milestone-based payment schedules. The deposit covers materials, surface preparation, and design development." },
  { question: "Are there hidden costs I should know about?", answer: "No. I quote all-inclusive pricing that covers design, materials, paint, surface prep, equipment rental, and labor. The only variables that can change a quote are scope changes you request after approval, or unexpected surface damage discovered during prep (I document and discuss before proceeding). The price I quote is the price you pay." },
  { question: "How do I get started?", answer: "Use the estimator at the top of this page for an instant ballpark range. For a detailed estimate, enter your email and I will send a planning guide within one business day. Or schedule a free discovery session and I will visit your site, assess the wall, and give you a firm quote." },
];
---

<BaseLayout
  title="Mural Cost Estimator | 2026 Pricing Guide | Untitled Mixed Media"
  description="Mural pricing from $15 to $80 per square foot. Most commercial murals in Richmond run $25 to $40/sqft. Free interactive estimator for an instant ballpark."
  faqItems={faqItems}
  breadcrumbItems={[
    { name: 'Home', url: '/' },
    { name: 'Mural Cost Estimator' },
  ]}
  service={{
    name: 'Mural Cost Estimator',
    description: 'Interactive tool to estimate the cost of a hand-painted mural in Richmond, Virginia. Transparent pricing from $15 to $80 per square foot.',
    priceRange: '$500 - $100,000+',
  }}
  blogPosting={{
    headline: 'How Much Does a Mural Cost? 2026 Pricing Guide + Free Estimator',
    description: 'A hand-painted mural costs $15 to $80 per square foot depending on complexity. Transparent pricing tiers, interactive estimator, and real project examples.',
    datePublished: '2026-04-11',
    author: 'Untitled Mixed Media',
  }}
>
  <Nav />
  <main class="pb-0">

    <!-- ─── I · HERO ─────────────────────────────────────── -->
    <section class="relative overflow-hidden pt-32 lg:pt-36 pb-12 lg:pb-16 px-6 lg:px-12 border-b border-slate-gray">
      <div class="absolute inset-0" aria-hidden="true">
        <img
          src="/images/content-design/trolley-full.jpg"
          alt=""
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-bone-black/90 via-bone-black/70 to-bone-black/50"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto">
        <Breadcrumb items={[
          { label: 'Home', href: '/' },
          { label: 'Mural Cost Estimator' },
        ]} />

        <div class="mt-6 lg:mt-8 max-w-3xl mx-auto">
          <div class="w-12 h-0.5 bg-[var(--color-editorial-accent)] mb-4"></div>
          <p class="font-mono uppercase mb-5 lg:mb-6" style="font-size: 11px; letter-spacing: 0.24em; color: rgba(238,236,233,0.72);">
            <span style="color: var(--color-editorial-accent); font-weight: 600;">&sect; 01</span>
            <span style="color: rgba(238,236,233,0.45); margin: 0 8px;">&middot;</span>
            Cost Estimator / 2026
          </p>
          <h1
            class="font-heading text-titanium-white"
            style="font-size: var(--text-fluid-4xl); line-height: 1.05; letter-spacing: -0.02em; font-weight: 500; text-wrap: balance; max-width: 22ch;"
            data-animate="headline"
          >
            How much does a mural <span class="italic-accent">cost?</span>
          </h1>
        </div>

        <div class="mt-6 lg:mt-8 max-w-3xl mx-auto">
          <p
            class="font-body text-soft-gray"
            style="font-size: var(--text-fluid-lg); line-height: var(--leading-relaxed);"
            data-animate="fade"
            data-animate-delay="1"
          >
            Hand-painted murals run $15 to $80 per square foot. Most Richmond commercial murals run $25 to $40. Use the estimator for your specific wall. No email required.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-4" data-animate="fade" data-animate-delay="2">
            <a
              href="#estimator"
              class="estimator-hero-cta plausible-event-name=CtaClick plausible-event-position=EstimatorHero"
            >
              <span class="estimator-hero-cta-label">Start the Estimator</span>
              <span class="estimator-hero-cta-arrow" aria-hidden="true">&darr;</span>
            </a>
            <span class="font-mono uppercase text-smoke-gray" style="font-size: 11px; letter-spacing: 0.2em;">
              30 seconds &middot; no email
            </span>
          </div>

          {/* PLACEHOLDER — Spencer to update */}
          <div class="mt-10 lg:mt-12 pt-6 border-t border-[rgba(238,236,233,0.12)]" data-animate="fade" data-animate-delay="3">
            <p class="font-mono uppercase text-smoke-gray mb-3" style="font-size: 10px; letter-spacing: 0.28em;">
              Trusted across Richmond
            </p>
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 font-mono uppercase text-soft-gray" style="font-size: 11px; letter-spacing: 0.2em;">
              <span>[ 20+ murals painted ]</span>
              <span class="text-smoke-gray">&middot;</span>
              <span>[ Henrico County commissioned ]</span>
              <span class="text-smoke-gray">&middot;</span>
              <span>[ Featured in Richmond Magazine ]</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── II · THE ESTIMATOR TOOL ──────────────────────── -->
    <section class="bg-midnight-graphite py-12 lg:py-16 px-6 lg:px-12 border-b border-slate-gray scroll-mt-24" id="estimator">
      <div class="max-w-7xl mx-auto">

        <div class="mb-8 lg:mb-12 max-w-3xl">
          <h2
            class="font-heading text-titanium-white"
            style="font-size: var(--text-fluid-3xl); line-height: 1.1; letter-spacing: -0.02em;"
            data-animate="headline"
          >
            Get your ballpark estimate in 30 seconds.
          </h2>
        </div>

        <div class="grid lg:grid-cols-12 gap-x-8 lg:gap-x-16">

          <!-- ── Left Column: Form Inputs ── -->
          <div class="lg:col-span-7">

            <!-- Step 1: Wall Dimensions -->
            <fieldset class="mb-10">
              <legend class="block font-sans text-titanium-white mb-4 tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">
                1. Wall Dimensions
              </legend>

              <!-- Preset Size Cards -->
              <div class="grid grid-cols-3 gap-3 mb-6" role="group" aria-label="Preset wall sizes">
                <button type="button" data-width="10" data-height="5" class="preset-card border border-titanium-white bg-bone-black p-4 text-left cursor-pointer transition-colors duration-200 hover:border-titanium-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-titanium-white" aria-pressed="true">
                  <span class="block font-sans text-titanium-white tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">Small</span>
                  <span class="block font-body text-soft-gray mt-1" style="font-size: var(--text-fluid-sm);">10 &times; 5 ft</span>
                  <span class="block font-mono text-smoke-gray mt-1" style="font-size: var(--text-fluid-xs);">50 sqft</span>
                </button>
                <button type="button" data-width="20" data-height="10" class="preset-card border border-slate-gray p-4 text-left cursor-pointer transition-colors duration-200 hover:border-titanium-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-titanium-white" aria-pressed="false">
                  <span class="block font-sans text-titanium-white tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">Medium</span>
                  <span class="block font-body text-soft-gray mt-1" style="font-size: var(--text-fluid-sm);">20 &times; 10 ft</span>
                  <span class="block font-mono text-smoke-gray mt-1" style="font-size: var(--text-fluid-xs);">200 sqft</span>
                </button>
                <button type="button" data-width="50" data-height="20" class="preset-card border border-slate-gray p-4 text-left cursor-pointer transition-colors duration-200 hover:border-titanium-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-titanium-white" aria-pressed="false">
                  <span class="block font-sans text-titanium-white tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">Large</span>
                  <span class="block font-body text-soft-gray mt-1" style="font-size: var(--text-fluid-sm);">50 &times; 20 ft</span>
                  <span class="block font-mono text-smoke-gray mt-1" style="font-size: var(--text-fluid-xs);">1,000 sqft</span>
                </button>
              </div>

              <!-- Custom Dimensions -->
              <p class="font-mono text-smoke-gray uppercase mb-3" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">Or enter custom dimensions</p>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="calc-width" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Width (ft)</label>
                  <input type="number" id="calc-width" name="width" min="1" max="200" inputmode="numeric" value="10" class="w-full bg-bone-black border border-slate-gray text-titanium-white px-4 py-3 font-body transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-titanium-white" style="font-size: var(--text-fluid-base); min-height: 48px;" placeholder="10" />
                </div>
                <div>
                  <label for="calc-height" class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Height (ft)</label>
                  <input type="number" id="calc-height" name="height" min="1" max="200" inputmode="numeric" value="5" class="w-full bg-bone-black border border-slate-gray text-titanium-white px-4 py-3 font-body transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-titanium-white" style="font-size: var(--text-fluid-base); min-height: 48px;" placeholder="5" />
                </div>
              </div>
              <p id="sqft-readout" class="font-mono text-smoke-gray mt-3 hidden" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;" aria-live="polite"></p>
            </fieldset>

            <!-- Step 2: Design Complexity -->
            <fieldset class="mb-10">
              <legend class="block font-sans text-titanium-white mb-4 tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">
                2. Design Complexity
              </legend>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <label class="complexity-card relative cursor-pointer">
                  <input type="radio" name="complexity" value="simple" class="peer sr-only" checked />
                  <div class="border border-slate-gray p-4 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray">
                    <span class="block font-sans text-titanium-white tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">Simple</span>
                    <span class="block font-heading text-titanium-white mt-1" style="font-size: var(--text-fluid-lg);">$15 &ndash; $25/sqft</span>
                    <span class="block font-body text-soft-gray mt-2" style="font-size: var(--text-fluid-xs);">2&ndash;4 colors, lettering, geometric shapes, flat fields</span>
                  </div>
                </label>
                <label class="complexity-card relative cursor-pointer">
                  <input type="radio" name="complexity" value="moderate" class="peer sr-only" />
                  <div class="border border-slate-gray p-4 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray">
                    <span class="block font-sans text-titanium-white tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">Moderate</span>
                    <span class="block font-heading text-titanium-white mt-1" style="font-size: var(--text-fluid-lg);">$25 &ndash; $40/sqft</span>
                    <span class="block font-body text-soft-gray mt-2" style="font-size: var(--text-fluid-xs);">5&ndash;10 colors, illustration, gradients, layered composition</span>
                  </div>
                </label>
                <label class="complexity-card relative cursor-pointer">
                  <input type="radio" name="complexity" value="detailed" class="peer sr-only" />
                  <div class="border border-slate-gray p-4 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray">
                    <span class="block font-sans text-titanium-white tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">Detailed</span>
                    <span class="block font-heading text-titanium-white mt-1" style="font-size: var(--text-fluid-lg);">$40 &ndash; $55/sqft</span>
                    <span class="block font-body text-soft-gray mt-2" style="font-size: var(--text-fluid-xs);">10+ colors, photorealistic, complex multi-figure scenes</span>
                  </div>
                </label>
                <label class="complexity-card relative cursor-pointer">
                  <input type="radio" name="complexity" value="archival" class="peer sr-only" />
                  <div class="border border-slate-gray p-4 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray">
                    <span class="block font-sans text-titanium-white tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">Archival</span>
                    <span class="block font-heading text-titanium-white mt-1" style="font-size: var(--text-fluid-lg);">$55 &ndash; $80/sqft</span>
                    <span class="block font-body text-soft-gray mt-2" style="font-size: var(--text-fluid-xs);">KEIM mineral paint, museum-grade, 100+ year durability</span>
                  </div>
                </label>
              </div>
            </fieldset>

            <!-- Step 3: Surface Type -->
            <fieldset class="mb-10">
              <legend class="block font-sans text-titanium-white mb-4 tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">
                3. Surface Type
              </legend>
              <div class="flex flex-wrap gap-2">
                <label class="surface-chip relative cursor-pointer">
                  <input type="radio" name="surface" value="drywall" class="peer sr-only" checked />
                  <span class="inline-block border border-slate-gray text-soft-gray font-sans tracking-[0.1em] uppercase px-4 py-3 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:text-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray" style="font-size: var(--text-fluid-xs); min-height: 48px; display: inline-flex; align-items: center;">Drywall</span>
                </label>
                <label class="surface-chip relative cursor-pointer">
                  <input type="radio" name="surface" value="wood" class="peer sr-only" />
                  <span class="inline-block border border-slate-gray text-soft-gray font-sans tracking-[0.1em] uppercase px-4 py-3 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:text-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray" style="font-size: var(--text-fluid-xs); min-height: 48px; display: inline-flex; align-items: center;">Wood</span>
                </label>
                <label class="surface-chip relative cursor-pointer">
                  <input type="radio" name="surface" value="stucco" class="peer sr-only" />
                  <span class="inline-block border border-slate-gray text-soft-gray font-sans tracking-[0.1em] uppercase px-4 py-3 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:text-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray" style="font-size: var(--text-fluid-xs); min-height: 48px; display: inline-flex; align-items: center;">Stucco</span>
                </label>
                <label class="surface-chip relative cursor-pointer">
                  <input type="radio" name="surface" value="concrete" class="peer sr-only" />
                  <span class="inline-block border border-slate-gray text-soft-gray font-sans tracking-[0.1em] uppercase px-4 py-3 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:text-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray" style="font-size: var(--text-fluid-xs); min-height: 48px; display: inline-flex; align-items: center;">Concrete</span>
                </label>
                <label class="surface-chip relative cursor-pointer">
                  <input type="radio" name="surface" value="brick" class="peer sr-only" />
                  <span class="inline-block border border-slate-gray text-soft-gray font-sans tracking-[0.1em] uppercase px-4 py-3 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:text-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray" style="font-size: var(--text-fluid-xs); min-height: 48px; display: inline-flex; align-items: center;">Brick</span>
                </label>
              </div>
            </fieldset>

            <!-- Step 4: Location -->
            <fieldset class="mb-10">
              <legend class="block font-sans text-titanium-white mb-4 tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">
                4. Location
              </legend>
              <div class="grid grid-cols-2 gap-0">
                <label class="relative cursor-pointer">
                  <input type="radio" name="location" value="interior" class="peer sr-only" checked />
                  <span class="block border border-slate-gray text-soft-gray font-sans tracking-[0.1em] uppercase px-4 py-3 text-center transition-colors duration-200 peer-checked:border-titanium-white peer-checked:text-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray" style="font-size: var(--text-fluid-xs); min-height: 48px; display: flex; align-items: center; justify-content: center;">Interior</span>
                </label>
                <label class="relative cursor-pointer">
                  <input type="radio" name="location" value="exterior" class="peer sr-only" />
                  <span class="block border border-slate-gray border-l-0 text-soft-gray font-sans tracking-[0.1em] uppercase px-4 py-3 text-center transition-colors duration-200 peer-checked:border-titanium-white peer-checked:text-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray" style="font-size: var(--text-fluid-xs); min-height: 48px; display: flex; align-items: center; justify-content: center;">Exterior</span>
                </label>
              </div>
            </fieldset>

            <!-- Step 5: Access Requirements -->
            <fieldset class="mb-10 lg:mb-0">
              <legend class="block font-sans text-titanium-white mb-4 tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">
                5. Access Requirements
              </legend>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                <label class="relative cursor-pointer">
                  <input type="radio" name="access" value="ground" class="peer sr-only" checked />
                  <div class="border border-slate-gray p-4 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray">
                    <span class="block font-sans text-titanium-white tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">Ground Level</span>
                    <span class="block font-body text-soft-gray mt-1" style="font-size: var(--text-fluid-xs);">No special equipment</span>
                  </div>
                </label>
                <label class="relative cursor-pointer">
                  <input type="radio" name="access" value="ladder" class="peer sr-only" />
                  <div class="border border-slate-gray p-4 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray">
                    <span class="block font-sans text-titanium-white tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">Ladder Access</span>
                    <span class="block font-body text-soft-gray mt-1" style="font-size: var(--text-fluid-xs);">+10% (2+ stories)</span>
                  </div>
                </label>
                <label class="relative cursor-pointer">
                  <input type="radio" name="access" value="lift" class="peer sr-only" />
                  <div class="border border-slate-gray p-4 transition-colors duration-200 peer-checked:border-titanium-white peer-checked:bg-bone-black peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-titanium-white hover:border-soft-gray">
                    <span class="block font-sans text-titanium-white tracking-[0.1em] uppercase" style="font-size: var(--text-fluid-xs);">Lift Required</span>
                    <span class="block font-body text-soft-gray mt-1" style="font-size: var(--text-fluid-xs);">+$5,000 (heavy equipment)</span>
                  </div>
                </label>
              </div>
            </fieldset>
          </div>

