<script>
  // ╔══════════════════════════════════════════════════════════════════╗
  // ║  MURAL COST ESTIMATOR: PRICING CONFIGURATION                    ║
  // ║  Version: 2026.04                                               ║
  // ║  Last updated: 2026-04-11                                       ║
  // ║                                                                 ║
  // ║  TO UPDATE PRICING:                                             ║
  // ║  1. Change the values in PRICING_CONFIG below                   ║
  // ║  2. Update the matching HTML in the pricing tiers section       ║
  // ║  3. Update the FAQ answers if ranges changed                    ║
  // ║  4. Rebuild and deploy                                          ║
  // ║                                                                 ║
  // ║  CHANGELOG:                                                     ║
  // ║  2026-04-11  Initial v2 with 4 tiers, access modifier,         ║
  // ║              and documented config system.                      ║
  // ╚══════════════════════════════════════════════════════════════════╝

  const PRICING_CONFIG = {
    version: '2026.04.2',

    // Minimum project fee (The Brand Mark: 16sqft hand-painted logo)
    minimumProjectFee: 500,

    // Mural lifespan in years (used for cost-per-year calculation)
    lifespanYears: 20,

    // ── Base rates per square foot by complexity tier ──
    // Aligned to Richmond, VA market data ($20-45/sqft experienced professional).
    // These rates are BEFORE surface/location/access adjustments.
    tiers: {
      simple:   { min: 15,  max: 25,  label: 'Simple' },
      moderate: { min: 25,  max: 40,  label: 'Moderate' },
      detailed: { min: 40,  max: 55,  label: 'Detailed' },
      archival: { min: 55,  max: 80,  label: 'Archival' },
    } as Record<string, { min: number; max: number; label: string }>,

    // ── Surface adjustments (ADDITIVE percentages) ──
    // These are added together with location and access, not multiplied.
    // Example: brick (+15%) + exterior (+20%) = +35% total (cap).
    surfaces: {
      drywall:  { pct: 0,    label: 'Drywall' },
      wood:     { pct: 0,    label: 'Wood' },
      stucco:   { pct: 0.05, label: 'Stucco' },
      concrete: { pct: 0.10, label: 'Concrete' },
      brick:    { pct: 0.15, label: 'Brick' },
    } as Record<string, { pct: number; label: string }>,

    // ── Location adjustments (ADDITIVE percentages) ──
    // Exterior at +20% covers UV-resistant materials and weather scheduling.
    // Does NOT include specialty coatings (anti-graffiti, extra UV sealant).
    locations: {
      interior: { pct: 0,    label: 'Interior' },
      exterior: { pct: 0.20, label: 'Exterior' },
    } as Record<string, { pct: number; label: string }>,

    // ── Access adjustments ──
    // Ground and ladder are additive percentages.
    // Lift is a flat fee for the first week (rental, delivery, site logistics).
    access: {
      ground: { type: 'pct' as const,  value: 0,    label: 'Ground Level' },
      ladder: { type: 'pct' as const,  value: 0.10, label: 'Ladder Access' },
      lift:   { type: 'flat' as const, value: 5000, label: 'Lift Required' },
    } as Record<string, { type: 'pct' | 'flat'; value: number; label: string }>,

    // ── Volume discount ──
    // Per-sqft rates decrease as wall size increases.
    // Based on St. Louis Mural Program data: 96sqft ~$47/sqft avg,
    // 1200sqft ~$29/sqft avg (roughly 40% lower per sqft).
    volumeBreaks: [
      { maxSqft: 100,  discount: 0 },
      { maxSqft: 300,  discount: 0.10 },
      { maxSqft: 600,  discount: 0.20 },
      { maxSqft: 1000, discount: 0.30 },
      { maxSqft: Infinity, discount: 0.40 },
    ],

    // Maximum additive modifier cap (surface + location + access)
    maxModifierPct: 0.35,
  };

  // ╔══════════════════════════════════════════════════════════════════╗
  // ║  CALCULATOR LOGIC                                               ║
  // ╚══════════════════════════════════════════════════════════════════╝

  interface EstimateResult {
    low: number;
    high: number;
    sqft: number;
    perYearLow: number;
    perYearHigh: number;
    perDayLow: number;
    perDayHigh: number;
    complexity: string;
    surface: string;
    location: string;
    access: string;
    liftFee: number;
    volumeDiscount: number;
    modifierPct: number;
  }

  function getVolumeDiscount(sqft: number): number {
    for (const tier of PRICING_CONFIG.volumeBreaks) {
      if (sqft <= tier.maxSqft) return tier.discount;
    }
    return 0;
  }

  function calculateEstimate(
    width: number,
    height: number,
    complexity: string,
    surface: string,
    location: string,
    access: string
  ): EstimateResult | null {
    const tier = PRICING_CONFIG.tiers[complexity];
    const surf = PRICING_CONFIG.surfaces[surface];
    const loc = PRICING_CONFIG.locations[location];
    const acc = PRICING_CONFIG.access[access];

    if (!tier || !surf || !loc || !acc) return null;

    const sqft = width * height;
    if (sqft <= 0) return null;

    // Step 1: Base calculation (sqft x tier rate)
    let rawLow = sqft * tier.min;
    let rawHigh = sqft * tier.max;

    // Step 2: Additive modifier (surface% + location% + access%)
    // Capped at maxModifierPct to prevent runaway estimates.
    let modifierPct = surf.pct + loc.pct;
    let liftFee = 0;
    if (acc.type === 'pct') {
      modifierPct += acc.value;
    }
    modifierPct = Math.min(modifierPct, PRICING_CONFIG.maxModifierPct);

    rawLow *= (1 + modifierPct);
    rawHigh *= (1 + modifierPct);

    // Step 3: Flat fees (lift rental) added after percentage modifiers
    if (acc.type === 'flat') {
      liftFee = acc.value;
      rawLow += liftFee;
      rawHigh += liftFee;
    }

    // Step 4: Volume discount (larger walls = lower effective per-sqft rate)
    const volumeDiscount = getVolumeDiscount(sqft);
    if (volumeDiscount > 0) {
      // Apply discount to the pre-flat-fee portion, then re-add flat fees
      const baseLow = rawLow - liftFee;
      const baseHigh = rawHigh - liftFee;
      rawLow = baseLow * (1 - volumeDiscount) + liftFee;
      rawHigh = baseHigh * (1 - volumeDiscount) + liftFee;
    }

    // Step 5: Apply minimum and round to nearest $100
    const low = Math.max(PRICING_CONFIG.minimumProjectFee, Math.round(rawLow / 100) * 100);
    const high = Math.max(PRICING_CONFIG.minimumProjectFee, Math.round(rawHigh / 100) * 100);

    // Step 6: Per-year and per-day calculations
    const years = PRICING_CONFIG.lifespanYears;
    const perYearLow = Math.round(low / years);
    const perYearHigh = Math.round(high / years);
    const perDayLow = low / (years * 365);
    const perDayHigh = high / (years * 365);

    return {
      low, high, sqft, perYearLow, perYearHigh, perDayLow, perDayHigh,
      complexity, surface, location, access, liftFee, volumeDiscount, modifierPct
    };
  }

  // ╔══════════════════════════════════════════════════════════════════╗
  // ║  UI ELEMENTS                                                    ║
  // ╚══════════════════════════════════════════════════════════════════╝

  const $ = (id: string) => document.getElementById(id);

  const widthInput = $('calc-width') as HTMLInputElement;
  const heightInput = $('calc-height') as HTMLInputElement;
  const sqftReadout = $('sqft-readout') as HTMLElement;
  const estimateDisplay = $('estimate-display') as HTMLElement;
  const estimateEmpty = $('estimate-empty') as HTMLElement;
  const estimateComputed = $('estimate-computed') as HTMLElement;
  const estimateRange = $('estimate-range') as HTMLElement;
  const estimateSummary = $('estimate-summary') as HTMLElement;
  const estimatePerYear = $('estimate-per-year') as HTMLElement;
  const leadCapture = $('lead-capture') as HTMLElement;
  const leadForm = $('lead-form') as HTMLFormElement;
  const thankYou = $('thank-you') as HTMLElement;
  const stickyBar = $('sticky-bar') as HTMLElement;
  const stickyRange = $('sticky-range') as HTMLElement;
  const stickyScrollBtn = $('sticky-scroll-btn') as HTMLElement;

  const presetCards = document.querySelectorAll('.preset-card');

  // ── Helper functions ──

  function fmt(amount: number): string {
    return '$' + amount.toLocaleString('en-US', { maximumFractionDigits: 0 });
  }

  function fmtCents(amount: number): string {
    return '$' + amount.toFixed(2);
  }

  function getRadioValue(name: string): string {
    const el = document.querySelector(`input[name="${name}"]:checked`) as HTMLInputElement | null;
    return el?.value ?? '';
  }

  // ── Animated counter ──

  function animateCounter(element: HTMLElement, low: number, high: number, duration = 600): void {
    const finalText = fmt(low) + ' \u2013 ' + fmt(high);

    // Always set the final value immediately (ensures display even if rAF is throttled)
    element.textContent = finalText;

    // Skip animation if user prefers reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Animate with ease-out cubic
    const start = performance.now();
    function tick(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      element.textContent = fmt(Math.round(eased * low)) + ' \u2013 ' + fmt(Math.round(eased * high));
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  // ╔══════════════════════════════════════════════════════════════════╗
  // ║  MAIN CALCULATE + RENDER                                        ║
  // ╚══════════════════════════════════════════════════════════════════╝

  let currentEstimate: EstimateResult | null = null;
  let leadFormRevealed = false;

  function updateEstimate(): void {
    const w = parseFloat(widthInput.value);
    const h = parseFloat(heightInput.value);

    // Show sqft readout even without full estimate
    if (w > 0 && h > 0) {
      sqftReadout.textContent = (w * h).toLocaleString() + ' square feet';
      sqftReadout.classList.remove('hidden');
    } else {
      sqftReadout.classList.add('hidden');
    }

    const complexity = getRadioValue('complexity');
    const surface = getRadioValue('surface');
    const location = getRadioValue('location');
    const access = getRadioValue('access');

    // Need at minimum: dimensions + complexity to show an estimate
    if (!w || !h || !complexity) {
      // Show empty state
      estimateEmpty.classList.remove('hidden');
      estimateComputed.classList.add('hidden');
      if (!leadFormRevealed) leadCapture.classList.add('hidden');
      stickyBar.classList.add('hidden');
      currentEstimate = null;
      return;
    }

    // Use defaults for optional fields
    const effectiveSurface = surface || 'drywall';
    const effectiveLocation = location || 'interior';
    const effectiveAccess = access || 'ground';

    const result = calculateEstimate(w, h, complexity, effectiveSurface, effectiveLocation, effectiveAccess);
    if (!result) return;

    currentEstimate = result;

    // Switch to computed state (synchronous, no rAF gating)
    estimateEmpty.classList.add('hidden');
    estimateComputed.classList.remove('hidden');

    // Animate the range number (rAF used only for counter, with fallback)
    animateCounter(estimateRange, result.low, result.high);

    // Summary line
    const parts = [result.sqft.toLocaleString() + ' sqft'];
    parts.push(PRICING_CONFIG.tiers[result.complexity]?.label ?? result.complexity);
    if (surface) parts.push(PRICING_CONFIG.surfaces[result.surface]?.label ?? result.surface);
    if (location) parts.push(PRICING_CONFIG.locations[result.location]?.label ?? result.location);
    if (access && access !== 'ground') parts.push(PRICING_CONFIG.access[result.access]?.label ?? result.access);
    estimateSummary.textContent = parts.join(' \u00B7 ');

    // Per-year context
    const midLow = result.perYearLow;
    const midHigh = result.perYearHigh;
    estimatePerYear.textContent = fmt(midLow) + ' \u2013 ' + fmt(midHigh) + '/year (' + fmtCents(result.perDayLow) + ' \u2013 ' + fmtCents(result.perDayHigh) + '/day)';

    // Update hidden form fields
    const hiddenLow = $('hidden-low') as HTMLInputElement;
    const hiddenHigh = $('hidden-high') as HTMLInputElement;
    const hiddenSqft = $('hidden-sqft') as HTMLInputElement;
    const hiddenWidth = $('hidden-width') as HTMLInputElement;
    const hiddenHeight = $('hidden-height') as HTMLInputElement;
    const hiddenSurface = $('hidden-surface') as HTMLInputElement;
    const hiddenLocation = $('hidden-location') as HTMLInputElement;
    const hiddenComplexity = $('hidden-complexity') as HTMLInputElement;
    const hiddenAccess = $('hidden-access') as HTMLInputElement;

    if (hiddenLow) hiddenLow.value = String(result.low);
    if (hiddenHigh) hiddenHigh.value = String(result.high);
    if (hiddenSqft) hiddenSqft.value = String(result.sqft);
    if (hiddenWidth) hiddenWidth.value = widthInput.value;
    if (hiddenHeight) hiddenHeight.value = heightInput.value;
    if (hiddenSurface) hiddenSurface.value = result.surface;
    if (hiddenLocation) hiddenLocation.value = result.location;
    if (hiddenComplexity) hiddenComplexity.value = result.complexity;
    if (hiddenAccess) hiddenAccess.value = result.access;

    // Update sticky bar (always visible when an estimate exists)
    stickyRange.textContent = fmt(result.low) + ' \u2013 ' + fmt(result.high);
    stickyBar.classList.remove('hidden');
    stickyBar.removeAttribute('aria-hidden');

    // Reveal lead form after a delay (only once)
    if (!leadFormRevealed) {
      setTimeout(() => {
        leadCapture.classList.remove('hidden');
        leadFormRevealed = true;
      }, 2000);
    }
  }

  // ╔══════════════════════════════════════════════════════════════════╗
  // ║  EVENT LISTENERS                                                ║
  // ╚══════════════════════════════════════════════════════════════════╝

  // ── Preset cards ──
  function clearPresetActive(): void {
    presetCards.forEach(card => {
      card.classList.remove('border-titanium-white', 'bg-bone-black');
      card.classList.add('border-slate-gray');
      card.setAttribute('aria-pressed', 'false');
    });
  }

  presetCards.forEach(card => {
    card.addEventListener('click', () => {
      const btn = card as HTMLButtonElement;
      const w = btn.dataset.width;
      const h = btn.dataset.height;
      if (w && h) {
        widthInput.value = w;
        heightInput.value = h;
        clearPresetActive();
        btn.classList.remove('border-slate-gray');
        btn.classList.add('border-titanium-white', 'bg-bone-black');
        btn.setAttribute('aria-pressed', 'true');
        updateEstimate();
      }
    });
  });

  // ── Custom dimension inputs ──
  widthInput.addEventListener('input', () => { clearPresetActive(); updateEstimate(); });
  heightInput.addEventListener('input', () => { clearPresetActive(); updateEstimate(); });

  // ── Radio inputs ──
  document.querySelectorAll('input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', updateEstimate);
  });

  // ── Sticky bar scroll button ──
  stickyScrollBtn?.addEventListener('click', () => {
    estimateDisplay.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  // Sticky bar visibility is handled inside updateEstimate().
  // It shows unconditionally whenever an estimate exists. No toggling.

  // ── Email inline validation ──
  const emailInput = $('lead-email') as HTMLInputElement;
  const emailError = $('email-error') as HTMLElement;

  function validateEmail(): boolean {
    if (!emailInput || !emailError) return true;
    const value = emailInput.value.trim();
    // Only validate if the user has entered something
    if (!value) {
      emailError.classList.add('hidden');
      emailInput.classList.remove('email-invalid');
      emailInput.removeAttribute('aria-invalid');
      emailInput.removeAttribute('aria-describedby');
      return true;
    }
    const isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
    if (isValid) {
      emailError.classList.add('hidden');
      emailInput.classList.remove('email-invalid');
      emailInput.removeAttribute('aria-invalid');
      emailInput.removeAttribute('aria-describedby');
    } else {
      emailError.classList.remove('hidden');
      emailInput.classList.add('email-invalid');
      emailInput.setAttribute('aria-invalid', 'true');
      emailInput.setAttribute('aria-describedby', 'email-error');
    }
    return isValid;
  }

  emailInput?.addEventListener('blur', validateEmail);
  emailInput?.addEventListener('input', () => {
    // Clear error on typing (re-validate on blur)
    if (emailInput.classList.contains('email-invalid')) {
      validateEmail();
    }
  });

  // ── Lead form submission ──
  const formError = $('form-error') as HTMLElement;

  function showFormError(): void {
    if (formError) formError.classList.remove('hidden');
  }

  function hideFormError(): void {
    if (formError) formError.classList.add('hidden');
  }

  leadForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    hideFormError();

    if (!validateEmail()) {
      emailInput?.focus();
      return;
    }

    const labels: Record<string, string> = {
      name: 'Name',
      email: 'Email',
      estimated_low: 'Estimated low',
      estimated_high: 'Estimated high',
      wall_sqft: 'Wall sqft',
      wall_width: 'Wall width',
      wall_height: 'Wall height',
      surface: 'Surface',
      location: 'Location',
      complexity: 'Complexity',
      access: 'Access',
    };
    const data = new FormData(leadForm);
    const lines: string[] = [];
    for (const [key, value] of data.entries()) {
      if (key === '_gotcha' || key === '_subject') continue;
      if (value instanceof File) continue;
      const v = String(value).trim();
      if (!v) continue;
      lines.push(`${labels[key] || key}: ${v}`);
    }
    const body = lines.join('\n');
    const subject = 'Mural Cost Estimator Lead';
    window.location.href = `mailto:hello@untitledmixedmedia.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    leadCapture.classList.add('hidden');
    thankYou.classList.remove('hidden');
    thankYou.classList.add('fade-in');
    thankYou.focus();
  });

  // ── Initialize: run calculation with defaults ──
  updateEstimate();
</script>
