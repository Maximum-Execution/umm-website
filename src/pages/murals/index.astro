---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SlideInCTA from '../../components/SlideInCTA.astro';

const muralProjects = (await getCollection('projects'))
  .filter((p) => p.data.tags.some((t: string) => t.toLowerCase().includes('mural')))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Murals — Untitled Mixed Media | Richmond VA Mural Painter"
  description="Hand-painted murals for businesses, property owners, and public spaces in Richmond, Virginia. Every mural starts with your building's story."
  breadcrumbItems={[
    { name: 'Home', url: '/' },
    { name: 'Work', url: '/work' },
    { name: 'Murals' },
  ]}
  service={{
    name: 'Hand-Painted Murals',
    description: 'Custom hand-painted murals for businesses, property owners, and public spaces in Richmond, Virginia.',
    priceRange: '$3,000 - $100,000+',
  }}
>
  <Nav />
  <main class="pt-24 pb-16">
    <!-- Hero: full-width split -->
    <div class="px-6 lg:px-12 max-w-7xl mx-auto">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Work', href: '/work' },
        { label: 'Murals' },
      ]} />

      <div class="grid lg:grid-cols-12 gap-8 lg:gap-16 mb-20">
        <div class="lg:col-span-8">
          <p class="font-mono text-smoke-gray uppercase mb-4" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
            Murals
          </p>
          <h1 class="font-heading text-titanium-white mb-6 text-balance" data-animate="headline" style="font-size: var(--text-fluid-4xl); line-height: 1.05;">
            Your building becomes a landmark people photograph, remember, and use to give directions.
          </h1>
        </div>
        <div class="lg:col-span-4 lg:flex lg:items-end">
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);" data-animate>
            A mural that could go on any wall isn't worth painting. We start with a site visit: photographing your building, reading its materials, researching its neighborhood and history. You see a photorealistic render on your actual wall before we ever pick up a brush.
          </p>
        </div>
      </div>
    </div>

    <!-- Pull quote — full bleed -->
    <div class="border-y border-slate-gray py-12 lg:py-16 mb-20">
      <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center" data-animate="settle">
        <p class="font-heading text-titanium-white italic" style="font-size: var(--text-fluid-2xl); line-height: var(--leading-snug);">
          A mural is not a decoration. It is a declaration.
        </p>
      </div>
    </div>

    <div class="px-6 lg:px-12 max-w-7xl mx-auto">
      <!-- Featured service: hero card -->
      <div class="mb-8" data-animate="fade">
        <a href="/murals/business-murals-richmond-va" class="group block border border-slate-gray p-8 lg:p-12 hover:border-soft-gray transition-colors duration-200">
          <div class="grid lg:grid-cols-2 gap-8 items-center">
            <div>
              <p class="font-mono text-cobalt-blue uppercase mb-3" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">Featured</p>
              <h3 class="font-heading text-titanium-white group-hover:text-soft-gray transition-colors duration-200 mb-4" style="font-size: var(--text-fluid-2xl); line-height: var(--leading-tight);">
                Business Murals Richmond VA
              </h3>
              <p class="font-body text-shadow-gray mb-6" style="font-size: var(--text-fluid-lg); line-height: var(--leading-relaxed);">
                Your storefront becomes the reason people stop, photograph, and come back. Painted for restaurants, breweries, retail, and offices.
              </p>
              <span class="font-mono text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs);">
                Learn more <span aria-hidden="true">&rarr;</span>
              </span>
            </div>
            <div class="hidden lg:block">
              <p class="font-heading text-slate-gray text-right select-none" style="font-size: clamp(6rem, 12vw, 10rem); line-height: 1;" aria-hidden="true">01</p>
            </div>
          </div>
        </a>
      </div>

      <!-- Service grid: 2+1 asymmetric -->
      <div class="grid lg:grid-cols-3 gap-8 mb-8">
        <div class="lg:col-span-2" data-animate="fade" data-animate-delay="1">
          <ServiceCard
            title="Outdoor Murals Richmond VA"
            description="Exterior murals that hold through Virginia summers, winters, and everything between. Built to last 10-15 years without fading."
            href="/murals/outdoor-murals-richmond-va"
          />
        </div>
        <div data-animate="fade" data-animate-delay="2">
          <ServiceCard
            title="Property Owner Murals"
            description="A blank wall is a missed opportunity. Painted murals attract quality tenants, raise perceived value, and make your building easier to lease."
            href="/murals/property-owner-murals-richmond-va"
          />
        </div>
      </div>

      <div class="grid lg:grid-cols-3 gap-8 mb-8">
        <div data-animate="fade" data-animate-delay="1">
          <ServiceCard
            title="Mural Cost Richmond VA"
            description="What a mural actually costs in Richmond, how the number breaks down, and what to expect at every price point. No surprises."
            href="/murals/mural-cost-richmond-va"
          />
        </div>
        <div class="lg:col-span-2" data-animate="fade" data-animate-delay="2">
          <ServiceCard
            title="Indoor Murals Richmond VA"
            description="No weather. No permits. No scaffolding. Interior murals painted on your schedule, with zero disruption to your business."
            href="/murals/indoor-murals-richmond-va"
          />
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-[var(--spacing-section)]">
        <div data-animate="fade" data-animate-delay="1">
          <ServiceCard
            title="Real Estate Developer Murals"
            description="Amenity art for mixed-use, multifamily, and commercial developments. The kind of detail that makes a rendering look real and a building worth choosing."
            href="/murals/real-estate-developer-murals"
          />
        </div>
        <div data-animate="fade" data-animate-delay="2">
          <ServiceCard
            title="Public Art Murals Richmond VA"
            description="Percent-for-art commissions, community murals, and heritage installations. Work that gives neighborhoods something worth keeping."
            href="/murals/public-art-murals-richmond-va"
          />
        </div>
        <div data-animate="fade" data-animate-delay="3">
          <ServiceCard
            title="Mural Maintenance"
            description="Your mural was a real investment. Cleaning protocols, sealant reapplication, and touch-up schedules to make it last decades."
            href="/murals/mural-maintenance"
          />
        </div>
      </div>

      <!-- Project Pull Quotes — asymmetric two-column -->
      <div class="grid lg:grid-cols-12 gap-8 mb-[var(--spacing-section)] border-t border-slate-gray pt-[var(--spacing-section)]">
        <blockquote class="lg:col-span-7 border-l-2 border-titanium-white pl-6" data-animate="fade">
          <p class="font-heading text-titanium-white italic mb-4" style="font-size: var(--text-fluid-xl); line-height: var(--leading-snug);">
            "The walls and the ground now tell the same story. You don't read Short Pump's history here. You stand inside it."
          </p>
          <cite class="font-mono text-smoke-gray uppercase not-italic" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
            Short Pump Park Heritage Mural, Henrico County VA
          </cite>
        </blockquote>
        <blockquote class="lg:col-span-5 lg:mt-16 border-l-2 border-titanium-white pl-6" data-animate="fade" data-animate-delay="1">
          <p class="font-heading text-titanium-white italic mb-4" style="font-size: var(--text-fluid-lg); line-height: var(--leading-snug);">
            "The workers who spent their careers here now look out from these walls permanently."
          </p>
          <cite class="font-mono text-smoke-gray uppercase not-italic" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
            Church Hill Trolley Barn, Richmond VA
          </cite>
        </blockquote>
      </div>

      <!-- Featured Projects -->
      {muralProjects.length > 0 && (
        <section class="border-t border-slate-gray pt-[var(--spacing-section)] mb-[var(--spacing-section)]">
          <h2 class="font-mono text-smoke-gray uppercase mb-8" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
            Featured Projects
          </h2>
          <div class="grid sm:grid-cols-2 gap-8">
            {muralProjects.slice(0, 4).map((project) => (
              <a href={`/work/${project.id}`} class="group block overflow-hidden" data-animate>
                <div class="aspect-[16/10] overflow-hidden bg-midnight-graphite">
                  <img
                    src={project.data.cover}
                    alt={project.data.title}
                    class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-700 ease-out"
                    loading="lazy"
                  />
                </div>
                <div class="mt-4 mb-8">
                  <h3 class="font-heading text-titanium-white group-hover:text-soft-gray transition-colors mb-2" style="font-size: var(--text-fluid-xl);">
                    {project.data.title}
                  </h3>
                  <p class="font-body text-shadow-gray line-clamp-2" style="font-size: var(--text-fluid-sm);">
                    {project.data.description}
                  </p>
                  <div class="flex gap-2 mt-2">
                    {project.data.tags.slice(0, 3).map((tag: string) => (
                      <span class="font-mono text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Cross-hub link -->
      <p class="font-body text-shadow-gray mb-16" style="font-size: var(--text-fluid-lg);">
        We also paint <a href="/hand-painted-signs" class="text-titanium-white underline underline-offset-4 hover:text-soft-gray transition-colors duration-200">hand-painted signs</a>.
      </p>
    </div>
  </main>

  <CTABlock />

  <SlideInCTA />
  <Footer />
</BaseLayout>
