---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQSection from '../../components/FAQSection.astro';
import RelatedPages from '../../components/RelatedPages.astro';

const faqItems = [
  { question: 'How long do outdoor murals last?', answer: 'With proper surface preparation, archival-grade paints, and UV-resistant clear coats, exterior murals in Richmond typically last 7-15 years before needing significant touch-up. KEIM mineral paint systems can last even longer — they bond chemically with masonry and become part of the wall itself.' },
  { question: 'What type of paint do you use for outdoor murals?', answer: 'We select paint systems based on the surface material and exposure conditions. For masonry walls, KEIM mineral silicate paint is the gold standard — it is breathable, UV-stable, and bonds permanently with the substrate. For other surfaces, we use high-grade acrylic systems with UV-resistant top coats. Every project gets a paint specification matched to its environment.' },
  { question: 'Do I need a permit for an outdoor mural in Richmond?', answer: 'Richmond mural permits depend on the district, wall visibility from public right-of-way, and whether the mural includes signage or branding. We help navigate the permitting process and can advise on what your specific location requires before we start.' },
  { question: 'How do you maintain an outdoor mural?', answer: 'We provide a maintenance guide with every completed exterior mural. Most outdoor murals need only periodic cleaning with mild detergent and water. We offer scheduled touch-up services and can apply anti-graffiti coatings for walls in high-traffic areas.' },
];
---

<BaseLayout
  title="Outdoor Murals in Richmond, VA | Untitled Mixed Media"
  description="Hand-painted outdoor murals in Richmond, VA. Weather-durable exterior murals using archival-grade paint systems designed to withstand Virginia's climate for years."
  faqItems={faqItems}
  breadcrumbItems={[
    { name: 'Home', url: '/' },
    { name: 'Work', url: '/work' },
    { name: 'Murals', url: '/murals' },
    { name: 'Outdoor Murals' },
  ]}
  service={{
    name: 'Outdoor Murals',
    description: 'Weather-durable hand-painted exterior murals for buildings in Richmond, Virginia.',
    priceRange: '$3,000 - $25,000',
  }}
>
  <Nav />
  <main class="pt-32 pb-16">
    <div class="px-6 lg:px-12 max-w-7xl mx-auto">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Work', href: '/work' },
        { label: 'Murals', href: '/murals' },
        { label: 'Outdoor Murals' },
      ]} />

      <!-- Hero: split layout -->
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-16 mb-20">
        <div class="lg:col-span-7">
          <p class="font-mono text-smoke-gray uppercase mb-6" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">
            Murals
          </p>
          <h1 class="font-heading text-titanium-white" style="font-size: var(--text-fluid-4xl); line-height: 1.05; letter-spacing: -0.03em;" data-animate="headline">
            Outdoor Murals in Richmond, VA
          </h1>
        </div>
        <div class="lg:col-span-5 lg:flex lg:items-end">
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
            You have an exterior wall that is doing nothing for your property. Maybe it is blank. Maybe it is stained, tagged, or just tired. Either way, it detracts from the building and the street around it. You have probably seen outdoor murals that looked great for a year and then faded into a washed-out mess. That is a reasonable concern in Virginia, where walls take a beating from summer UV, winter freezes, and everything in between.
          </p>
        </div>
      </div>

      <!-- Body: two-column editorial -->
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 mb-20">
        <div class="space-y-6" data-animate="fade" data-animate-delay="1">
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
            Durability is not an afterthought for us. It is the starting point. We select paint systems based on your wall material and sun exposure, from KEIM mineral paint that bonds chemically with masonry to high-grade acrylics with UV-resistant clear coats. Every exterior project starts with proper surface preparation because no paint system can save a wall that was not prepped correctly. Our completed exterior murals hold their color and clarity for years because we build them to.
          </p>
        </div>
        <div class="space-y-6" data-animate="fade" data-animate-delay="2">
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
            We visit your site, assess the wall condition and exposure, and create a photorealistic mockup of the design on your actual building before we start. You approve the design, we paint it, and the wall that was dragging down your property becomes a landmark that draws attention for the right reasons.
          </p>
        </div>
      </div>

      <!-- Image placeholder — full width -->
      <div class="aspect-[16/9] overflow-hidden bg-midnight-graphite border border-slate-gray mb-20">
        <div class="p-8">
          <p class="font-mono text-smoke-gray uppercase mb-3" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">Image placeholder</p>
          <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-sm);">
            Add a project photo here showing a large-scale exterior mural on brick, concrete, or stucco — ideally showing the scale of the wall and the surrounding environment. Use Astro Image component when real photos are available.
          </p>
        </div>
      </div>
    </div>

    <FAQSection items={faqItems} />
    <RelatedPages heading="Related" pages={[
      { title: 'Business Murals', href: '/murals/business-murals-richmond-va', description: 'Commercial murals that drive foot traffic and brand identity.' },
      { title: 'Mural Maintenance', href: '/murals/mural-maintenance', description: 'Keep your mural looking sharp for years.' },
      { title: 'Public Art Murals', href: '/murals/public-art-murals-richmond-va', description: 'Community-scale public art and heritage murals.' },
    ]} />
    <CTABlock />
  </main>
  <Footer />
</BaseLayout>
