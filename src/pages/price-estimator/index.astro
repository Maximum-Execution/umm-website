---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import CTABlock from '../../components/CTABlock.astro';
---

<BaseLayout title="Mural Price Estimator | Untitled Mixed Media" description="Estimate the cost of a hand-painted mural based on wall size, surface type, location, and design complexity. Get a ballpark figure in minutes.">
  <Nav />
  <main class="pt-32 pb-16">
    <div class="px-6 lg:px-12 max-w-4xl">

      <h1 class="font-heading text-titanium-white mb-6" style="font-size: var(--text-fluid-4xl); line-height: 1.1; letter-spacing: -0.03em;">
        How much does a mural cost?
      </h1>

      <p class="font-body text-shadow-gray mb-12" style="font-size: var(--text-fluid-lg); line-height: 1.6;">
        Every mural is different, but the pricing follows a pattern. Wall size, surface condition, location, and design complexity are the primary drivers. Fill out the form below and we will send you a ballpark estimate within one business day. No commitment, no sales pitch.
      </p>

      <form class="space-y-6 max-w-xl mb-16">
        <div class="grid grid-cols-2 gap-6">
          <div>
            <label class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Wall Width (ft)</label>
            <input type="number" min="1" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body" style="font-size: var(--text-fluid-base);" placeholder="20" />
          </div>
          <div>
            <label class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Wall Height (ft)</label>
            <input type="number" min="1" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body" style="font-size: var(--text-fluid-base);" placeholder="12" />
          </div>
        </div>
        <div>
          <label class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Surface Type</label>
          <select class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body" style="font-size: var(--text-fluid-base);">
            <option value="" disabled selected>Select surface type</option>
            <option value="brick">Brick</option>
            <option value="stucco">Stucco</option>
            <option value="concrete">Concrete</option>
            <option value="wood">Wood</option>
            <option value="drywall">Drywall</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Location</label>
          <select class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body" style="font-size: var(--text-fluid-base);">
            <option value="" disabled selected>Select location</option>
            <option value="exterior">Exterior</option>
            <option value="interior">Interior</option>
          </select>
        </div>
        <div>
          <label class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Style Complexity</label>
          <select class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body" style="font-size: var(--text-fluid-base);">
            <option value="" disabled selected>Select complexity level</option>
            <option value="simple">Simple graphics / text</option>
            <option value="moderate">Moderate detail</option>
            <option value="complex">Highly detailed / realistic</option>
          </select>
        </div>
        <div class="border-t border-slate-gray pt-6">
          <p class="font-mono text-smoke-gray uppercase mb-4" style="font-size: var(--text-fluid-xs); letter-spacing: 0.08em;">Your Information</p>
          <div class="space-y-6">
            <div>
              <label class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Your Name</label>
              <input type="text" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body" style="font-size: var(--text-fluid-base);" placeholder="Your name" />
            </div>
            <div>
              <label class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Email</label>
              <input type="email" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body" style="font-size: var(--text-fluid-base);" placeholder="you@example.com" />
            </div>
            <div>
              <label class="block font-sans text-soft-gray mb-2" style="font-size: var(--text-fluid-sm);">Phone <span class="text-smoke-gray">(optional)</span></label>
              <input type="tel" class="w-full bg-midnight-graphite border border-slate-gray text-titanium-white px-4 py-3 font-body" style="font-size: var(--text-fluid-base);" placeholder="(804) 555-0100" />
            </div>
          </div>
        </div>
        <button type="submit" class="bg-titanium-white text-bone-black font-sans px-8 py-3 font-medium tracking-[0.15em] uppercase hover:bg-light-ash transition-colors" style="font-size: var(--text-fluid-sm);">
          Get My Estimate
        </button>
      </form>

      <div class="bg-midnight-graphite p-8 mb-16 border border-slate-gray">
        <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: 1.6;">
          <strong class="text-titanium-white">Estimates are approximate.</strong> Wall condition, access requirements (scaffolding, lift rental), surface preparation, and design revisions all affect the final price. A site visit confirms the scope and produces a firm quote. There is no charge for the initial consultation.
        </p>
      </div>

      <p class="font-body text-shadow-gray" style="font-size: var(--text-fluid-base); line-height: 1.6;">
        Want a deeper breakdown of what drives mural pricing? Read our detailed guide: <a href="/murals/mural-cost-richmond-va" class="text-titanium-white underline hover:text-soft-gray transition-colors duration-200">Mural Cost in Richmond, VA</a>.
      </p>

    </div>

    <CTABlock />
  </main>
  <Footer />
</BaseLayout>
