---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import ScrollProgress from '../../components/ScrollProgress.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, cover, tags, client, location, materials, date } = project.data;
const year = date.getFullYear();

// Prev/Next navigation
const allProjects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = allProjects.findIndex((p) => p.id === project.id);
const prevProject = allProjects[currentIndex - 1] ?? allProjects[allProjects.length - 1];
const nextProject = allProjects[currentIndex + 1] ?? allProjects[0];

// Determine hub link based on tags
const isMural = tags.some((t: string) => t.toLowerCase().includes('mural'));
const isSign = tags.some((t: string) => t.toLowerCase().includes('sign'));
const hubLink = isMural ? '/murals' : isSign ? '/hand-painted-signs' : null;
const hubLabel = isMural ? 'See more mural projects' : isSign ? 'See more sign work' : '';
---

<BaseLayout
  title={`${title} — Untitled Mixed Media`}
  description={description}
  ogImage={cover}
>
  <Nav />
  <ScrollProgress />
  <main class="pt-24">
    <!-- Title + metadata line -->
    <div class="px-6 lg:px-12 mb-8">
      <div class="max-w-7xl mx-auto">
        <h1 class="font-heading text-titanium-white mb-3 text-balance">
          {title}
        </h1>
        <p class="font-sans text-[var(--text-fluid-sm)] text-shadow-gray tracking-wide">
          {[client, location, year].filter(Boolean).join(' · ')}
        </p>
      </div>
    </div>

    <!-- Hero image — full width -->
    <div class="px-6 lg:px-12 mb-16">
      <div class="max-w-7xl mx-auto">
        <div class="aspect-[21/9] overflow-hidden">
          <img
            src={cover}
            alt={title}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>

    <!-- About This Project — always visible, two-column -->
    <div class="px-6 lg:px-12 mb-20">
      <div class="max-w-7xl mx-auto">
        <p class="font-sans text-[var(--text-fluid-xs)] text-shadow-gray uppercase tracking-[var(--tracking-wider)] mb-8">
          About This Project
        </p>

        <div class="grid lg:grid-cols-[1fr_280px] gap-12">
          <!-- Description -->
          <p class="font-body text-[var(--text-fluid-lg)] text-shadow-gray text-balance" style="max-width: var(--measure-wide);">
            {description}
          </p>

          <!-- Metadata sidebar -->
          <aside class="lg:border-l lg:border-slate-gray lg:pl-8 space-y-5">
            {client && (
              <div>
                <span class="font-sans text-[var(--text-fluid-xs)] text-smoke-gray uppercase tracking-[var(--tracking-wider)] mb-1 block">Client</span>
                <p class="font-body text-titanium-white">{client}</p>
              </div>
            )}
            {location && (
              <div>
                <span class="font-sans text-[var(--text-fluid-xs)] text-smoke-gray uppercase tracking-[var(--tracking-wider)] mb-1 block">Location</span>
                <p class="font-body text-titanium-white">{location}</p>
              </div>
            )}
            {materials && (
              <div>
                <span class="font-sans text-[var(--text-fluid-xs)] text-smoke-gray uppercase tracking-[var(--tracking-wider)] mb-1 block">Materials</span>
                <p class="font-body text-titanium-white">{materials}</p>
              </div>
            )}
            <div>
              <span class="font-sans text-[var(--text-fluid-xs)] text-smoke-gray uppercase tracking-[var(--tracking-wider)] mb-1 block">Year</span>
              <p class="font-body text-titanium-white">{year}</p>
            </div>
            <div>
              <span class="font-sans text-[var(--text-fluid-xs)] text-smoke-gray uppercase tracking-[var(--tracking-wider)] mb-2 block">Tags</span>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class="font-mono text-[var(--text-fluid-xs)] text-smoke-gray border border-slate-gray px-2.5 py-0.5 uppercase tracking-wider">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>

    <!-- Narrative content — rendered markdown -->
    <div class="case-study-content px-6 lg:px-12 pb-16">
      <div class="max-w-7xl mx-auto">
        <div class="case-study-prose">
          <Content />
        </div>
      </div>
    </div>

    {/* Full-bleed image break */}
    {project.data.images && project.data.images.length > 0 && (
      <div class="w-full my-16" data-animate="fade">
        <img
          src={project.data.images[0]}
          alt={`${title} — detail`}
          class="w-full h-auto object-cover"
          loading="lazy"
        />
      </div>
    )}

    <!-- CTA block -->
    <div class="px-6 lg:px-12 py-20 border-t border-slate-gray">
      <div class="max-w-7xl mx-auto text-center">
        <p class="font-heading text-[var(--text-fluid-2xl)] text-titanium-white mb-6 text-balance">
          Tell us about your walls.
        </p>
        <Button href="mailto:hello@untitledmixedmedia.com">
          Start a Conversation
        </Button>
      </div>
    </div>

    {/* Cross-link back to hub */}
    {hubLink && (
      <div class="px-6 lg:px-12 pb-12">
        <div class="max-w-7xl mx-auto">
          <a href={hubLink} class="font-sans text-smoke-gray text-sm tracking-[0.15em] uppercase hover:text-titanium-white transition-colors">
            &larr; {hubLabel}
          </a>
        </div>
      </div>
    )}

    <!-- Prev / Next Navigation -->
    <nav class="px-6 lg:px-12 border-t border-slate-gray">
      <div class="max-w-7xl mx-auto py-12 grid grid-cols-2 gap-8">
        <a
          href={`/work/${prevProject.id}`}
          class="group"
        >
          <span class="font-sans text-[var(--text-fluid-xs)] text-smoke-gray uppercase tracking-[0.15em] block mb-2">
            Previous
          </span>
          <span class="font-heading text-[var(--text-fluid-lg)] text-titanium-white group-hover:text-soft-gray transition-colors">
            {prevProject.data.title}
          </span>
        </a>
        <a
          href={`/work/${nextProject.id}`}
          class="group text-right"
        >
          <span class="font-sans text-[var(--text-fluid-xs)] text-smoke-gray uppercase tracking-[0.15em] block mb-2">
            Next
          </span>
          <span class="font-heading text-[var(--text-fluid-lg)] text-titanium-white group-hover:text-soft-gray transition-colors">
            {nextProject.data.title}
          </span>
        </a>
      </div>
    </nav>
  </main>
  <Footer />
</BaseLayout>
