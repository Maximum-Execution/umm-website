---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import ScrollProgress from '../../components/ScrollProgress.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import GalleryMosaic from '../../components/patterns/GalleryMosaic.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, cover, tags, client, location, materials, date } = project.data;
const year = date.getFullYear();

// Prev/Next navigation
const allProjects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = allProjects.findIndex((p) => p.id === project.id);
const prevProject = allProjects[currentIndex - 1] ?? allProjects[allProjects.length - 1];
const nextProject = allProjects[currentIndex + 1] ?? allProjects[0];

// Determine hub link based on tags
const isMural = tags.some((t: string) => t.toLowerCase().includes('mural'));
const isSign = tags.some((t: string) => t.toLowerCase().includes('sign'));
const hubLink = isMural ? '/murals' : isSign ? '/hand-painted-signs' : null;
const hubLabel = isMural ? 'See more mural projects' : isSign ? 'See more sign work' : '';
---

<BaseLayout
  title={`${title} | Untitled Mixed Media`}
  description={description}
  ogImage={cover}
>
  <Nav />
  <ScrollProgress />
  <main id="main-content" tabindex="-1">
    <!-- Title + metadata line -->
    <div class="px-6 lg:px-12 pt-36 lg:pt-44 mb-8">
      <div class="max-w-7xl mx-auto">
        <h1 class="font-heading text-titanium-white mb-3 text-balance">
          {title}
        </h1>
        <p class="font-sans text-[var(--text-fluid-sm)] text-soft-gray tracking-wide">
          {[client, location, year].filter(Boolean).join(' · ')}
        </p>
      </div>
    </div>

    <!-- Hero image — full width -->
    <div class="px-6 lg:px-12 mb-16">
      <div class="max-w-7xl mx-auto">
        <div class="aspect-[21/9] overflow-hidden">
          <img
            src={cover}
            alt=""
            width="2100"
            height="900"
            decoding="async"
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>

    <!-- About This Project — always visible, two-column -->
    <div class="px-6 lg:px-12 mb-20">
      <div class="max-w-7xl mx-auto">
        <p class="font-sans text-[var(--text-fluid-xs)] text-soft-gray uppercase tracking-[var(--tracking-wider)] mb-8">
          About This Project
        </p>

        <div class="grid lg:grid-cols-[1fr_280px] gap-12">
          <!-- Description -->
          <p class="font-body text-[var(--text-fluid-lg)] text-soft-gray text-balance" style="max-width: var(--measure-wide);">
            {description}
          </p>

          <!-- Metadata sidebar -->
          <aside class="lg:border-l lg:border-slate-gray lg:pl-8 space-y-5">
            {client && (
              <div>
                <span class="font-sans text-[var(--text-fluid-xs)] text-shadow-gray uppercase tracking-[var(--tracking-wider)] mb-1 block">Client</span>
                <p class="font-body text-titanium-white">{client}</p>
              </div>
            )}
            {location && (
              <div>
                <span class="font-sans text-[var(--text-fluid-xs)] text-shadow-gray uppercase tracking-[var(--tracking-wider)] mb-1 block">Location</span>
                <p class="font-body text-titanium-white">{location}</p>
              </div>
            )}
            {materials && (
              <div>
                <span class="font-sans text-[var(--text-fluid-xs)] text-shadow-gray uppercase tracking-[var(--tracking-wider)] mb-1 block">Materials</span>
                <p class="font-body text-titanium-white">{materials}</p>
              </div>
            )}
            <div>
              <span class="font-sans text-[var(--text-fluid-xs)] text-shadow-gray uppercase tracking-[var(--tracking-wider)] mb-1 block">Year</span>
              <p class="font-body text-titanium-white">{year}</p>
            </div>
            <div>
              <span class="font-sans text-[var(--text-fluid-xs)] text-shadow-gray uppercase tracking-[var(--tracking-wider)] mb-2 block">Tags</span>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class="font-mono text-[var(--text-fluid-xs)] text-shadow-gray border border-slate-gray px-2.5 py-0.5 uppercase tracking-wider">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>

    <!-- Narrative content — rendered markdown -->
    <div class="case-study-content px-6 lg:px-12 pb-16">
      <div class="max-w-7xl mx-auto">
        <div class="case-study-prose">
          <Content />
        </div>
      </div>
    </div>

    {/* Image gallery */}
    {project.data.images && project.data.images.length === 1 && (
      <div class="w-full my-16" data-animate="fade">
        <img
          src={project.data.images[0]}
          alt={`${title}, detail view`}
          width="1920"
          height="1080"
          decoding="async"
          class="w-full h-auto object-cover"
          loading="lazy"
        />
      </div>
    )}
    {project.data.images && project.data.images.length > 1 && (
      <div class="px-6 lg:px-12 my-16">
        <div class="max-w-7xl mx-auto">
          <GalleryMosaic
            images={project.data.images.map((src: string, i: number) => ({
              src,
              alt: `${title}, view ${i + 1}`,
            }))}
          />
        </div>
      </div>
    )}

    <!-- CTA block -->
    <div class="px-6 lg:px-12 py-20 border-t border-slate-gray">
      <div class="max-w-7xl mx-auto text-center">
        <p class="font-heading text-[var(--text-fluid-2xl)] text-titanium-white mb-6 text-balance">
          Tell us about your walls.
        </p>
        <Button href="/contact" class="plausible-event-name=CtaClick plausible-event-position=CaseStudyFooter">
          Start a Conversation
        </Button>
      </div>
    </div>

    {/* Cross-link back to hub */}
    {hubLink && (
      <div class="px-6 lg:px-12 pb-12">
        <div class="max-w-7xl mx-auto">
          <a href={hubLink} class="font-sans text-shadow-gray text-sm tracking-[0.15em] uppercase hover:text-titanium-white transition-colors">
            &larr; {hubLabel}
          </a>
        </div>
      </div>
    )}

    <!-- Prev / Next Navigation -->
    <nav aria-label="Case studies" class="px-6 lg:px-12 border-t border-slate-gray">
      <div class="max-w-7xl mx-auto py-12 grid grid-cols-2 gap-8">
        <a
          href={`/work/${prevProject.id}`}
          class="group"
        >
          <span class="font-sans text-[var(--text-fluid-xs)] text-shadow-gray uppercase tracking-[0.15em] block mb-3">
            Previous
          </span>
          {prevProject.data.cover && (
            <div class="w-20 h-14 overflow-hidden mb-2 border border-slate-gray">
              <img
                src={prevProject.data.cover}
                alt=""
                class="w-full h-full object-cover"
                loading="lazy"
                aria-hidden="true"
              />
            </div>
          )}
          <span class="font-heading text-[var(--text-fluid-lg)] text-titanium-white group-hover:text-soft-gray transition-colors">
            {prevProject.data.title}
          </span>
        </a>
        <a
          href={`/work/${nextProject.id}`}
          class="group text-right"
        >
          <span class="font-sans text-[var(--text-fluid-xs)] text-shadow-gray uppercase tracking-[0.15em] block mb-3">
            Next
          </span>
          {nextProject.data.cover && (
            <div class="w-20 h-14 overflow-hidden mb-2 ml-auto border border-slate-gray">
              <img
                src={nextProject.data.cover}
                alt=""
                class="w-full h-full object-cover"
                loading="lazy"
                aria-hidden="true"
              />
            </div>
          )}
          <span class="font-heading text-[var(--text-fluid-lg)] text-titanium-white group-hover:text-soft-gray transition-colors">
            {nextProject.data.title}
          </span>
        </a>
      </div>
    </nav>
  </main>

  <!-- Section scroll indicators — populated by JS after load -->
  <nav
    id="section-dots"
    aria-label="Section navigation"
    class="hidden lg:flex flex-col fixed right-6 top-1/2 -translate-y-1/2 z-40"
    style="gap: 12px;"
  ></nav>

  <Footer />
</BaseLayout>

<script>
  (function () {
    const container = document.getElementById('section-dots');
    if (!container) return;

    const headings = Array.from(document.querySelectorAll('main h2')) as HTMLElement[];
    if (headings.length < 2) return;

    const COLOR_ACTIVE = '#EEECE9';
    const COLOR_INACTIVE = '#4A4A4C';

    headings.forEach((heading) => {
      const dot = document.createElement('button');
      dot.style.cssText = `width:6px;height:6px;border-radius:50%;border:none;padding:0;cursor:pointer;transition:background-color 300ms;background-color:${COLOR_INACTIVE};`;
      dot.setAttribute('aria-label', `Scroll to: ${heading.textContent?.trim() ?? ''}`);
      dot.addEventListener('click', () => {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        heading.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth' });
      });
      container.appendChild(dot);
    });

    const dots = Array.from(container.querySelectorAll('button')) as HTMLButtonElement[];

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = headings.indexOf(entry.target as HTMLElement);
            dots.forEach((d, i) => {
              d.style.backgroundColor = i === idx ? COLOR_ACTIVE : COLOR_INACTIVE;
            });
          }
        });
      },
      { threshold: 0.3, rootMargin: '-20% 0px -60% 0px' }
    );

    headings.forEach((h) => observer.observe(h));

    // Show the container now that dots are ready
    container.classList.remove('hidden');
    container.classList.add('flex');
  })();
</script>
