---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ExitIntentPopup from '../../components/ExitIntentPopup.astro';
import ComparisonBar from '../../components/patterns/ComparisonBar.astro';

// Brand Mark launch cohort: 9 spots at $500, one per neighborhood.
// Flip a neighborhood to `status: 'taken'` when a spot closes.
// When they all close, price tier steps up to $750 (Round 2).
const CURRENT_NEIGHBORHOOD = "Scott's Addition";

const NEIGHBORHOODS: { name: string; status: 'open' | 'painting' | 'taken' }[] = [
  { name: "Scott's Addition", status: 'painting' },
  { name: 'Carytown',         status: 'open' },
  { name: 'Church Hill',      status: 'open' },
  { name: 'Manchester',       status: 'open' },
  { name: 'The Fan',          status: 'open' },
  { name: 'Jackson Ward',     status: 'open' },
  { name: 'Shockoe Bottom',   status: 'open' },
  { name: 'Brookland Park',   status: 'open' },
  { name: 'Oregon Hill',      status: 'open' },
];

const SPOTS_TOTAL = NEIGHBORHOODS.length;
const SPOTS_REMAINING = NEIGHBORHOODS.filter(n => n.status !== 'taken').length;
---

<BaseLayout
  title="The Brand Mark | Your Words, Hand-Painted on Wood. $500. | Untitled Mixed Media"
  description="Your logo, phrase, or chosen words, hand-painted on a wood panel and hung on your wall. 5 business days. $500. Nine spots at launch price. Richmond, VA."
  breadcrumbItems={[
    { name: 'Home', url: '/' },
    { name: 'Work', url: '/work' },
    { name: 'Brand Mark' },
  ]}
  service={{
    name: 'The Brand Mark',
    description: 'Your logo, phrase, or chosen words, hand-painted on a wood panel and hung on your wall. 5 business days. $500. Richmond, VA.',
    priceRange: '$500',
  }}
>
  <Nav />
  <main class="pt-24 pb-16">

    <!-- ═══════════════════════════════════════════
         SECTION 1: HERO — editorial split
         Text as protagonist left, hand-painted panel right.
         The image is shown, not drowned in gradient.
         ═══════════════════════════════════════════ -->
    <div class="border-b border-slate-gray" id="brand-mark-hero">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-8">
        <Breadcrumb items={[
          { label: 'Home', href: '/' },
          { label: 'Work', href: '/work' },
          { label: 'Brand Mark' },
        ]} />
      </div>

      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-12 pb-24 lg:pt-20 lg:pb-40 grid lg:grid-cols-12 gap-10 lg:gap-16 items-end">
        <!-- Left: typographic hero -->
        <div class="lg:col-span-7 lg:pr-8">
          <p class="font-mono text-smoke-gray uppercase mb-8" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
            The Brand Mark &mdash; No. 01 / Richmond, VA
          </p>

          <h1 class="font-heading text-titanium-white mb-10" style="font-size: var(--text-fluid-5xl); line-height: 0.95; letter-spacing: -0.02em;" data-animate>
            Your words,<br />
            <span class="italic text-soft-gray">hand-painted</span><br />
            on wood.
          </h1>

          <!-- Inline fact row in place of three stacked sentences -->
          <div class="flex flex-wrap gap-x-10 gap-y-3 mb-10 font-mono uppercase text-titanium-white" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);" data-animate data-animate-delay="1">
            <span><span class="text-smoke-gray">Ships in</span> 5 business days</span>
            <span aria-hidden="true" class="text-slate-gray">&bull;</span>
            <span><span class="text-smoke-gray">Price</span> $500</span>
            <span aria-hidden="true" class="text-slate-gray">&bull;</span>
            <span><span class="text-smoke-gray">Deposit</span> $250</span>
          </div>

          <p
            class="font-body text-soft-gray mb-10"
            style="font-size: var(--text-fluid-lg); line-height: var(--leading-relaxed); max-width: 36rem;"
            data-animate
            data-animate-delay="1"
          >
            A hand-painted original for Richmond businesses that want their space to look established, permanent, and worth trusting, without mural pricing, landlord approval, wall prep, or weeks of waiting.
          </p>

          <div class="flex flex-wrap gap-4 mb-4" data-animate data-animate-delay="2">
            <a
              href="/contact?type=brand-mark"
              class="font-sans inline-block bg-titanium-white text-bone-black px-8 py-4 text-sm font-medium tracking-[0.15em] uppercase min-h-[44px] hover:bg-light-ash transition-colors duration-200"
            >
              Claim Your Spot
            </a>
            <a
              href="#how-it-works"
              class="font-sans inline-block border border-titanium-white text-titanium-white px-8 py-4 text-sm font-medium tracking-[0.15em] uppercase min-h-[44px] hover:bg-titanium-white hover:text-bone-black transition-colors duration-200"
            >
              See How It Works <span aria-hidden="true">&darr;</span>
            </a>
          </div>

          <p class="font-body text-smoke-gray" style="font-size: var(--text-fluid-xs);" data-animate data-animate-delay="2">
            4 questions. Under 2 minutes.
          </p>
        </div>

        <!-- Right: the actual hand-painted panel, given real presence -->
        <figure class="lg:col-span-5 relative" data-animate="fade" data-animate-delay="1">
          <div class="aspect-[4/5] overflow-hidden bg-midnight-graphite">
            <img
              src="/images/content-design/hand-painted-sign.jpg"
              alt="A hand-painted sign on wood, shown at scale"
              class="w-full h-full object-cover"
              loading="eager"
              width="800"
              height="1000"
            />
          </div>
          <figcaption class="absolute -bottom-4 left-0 right-0 flex items-baseline justify-between px-1">
            <span class="font-mono text-smoke-gray uppercase bg-bone-black pr-3" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
              Plate I
            </span>
            <span class="font-mono text-smoke-gray uppercase bg-bone-black pl-3" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
              Hand-lettered, sealed wood
            </span>
          </figcaption>
        </figure>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════
         PROOF BAR
         ═══════════════════════════════════════════ -->
    <div class="bg-midnight-graphite border-y border-slate-gray px-6 lg:px-12 py-8 mb-32 lg:mb-40">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12 text-center">
          <div>
            <p class="font-heading text-titanium-white mb-2" style="font-size: var(--text-fluid-lg);">Same week</p>
            <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-xs);">Discovery to install in 5 business days or fewer</p>
          </div>
          <div>
            <p class="font-heading text-titanium-white mb-2" style="font-size: var(--text-fluid-lg);">$250 to start</p>
            <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-xs);">Deposit holds your spot and covers the build</p>
          </div>
          <div>
            <p class="font-heading text-titanium-white mb-2" style="font-size: var(--text-fluid-lg);">Balance on acceptance</p>
            <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-xs);">$250 due only after the piece is hung and you approve it</p>
          </div>
          <div>
            <p class="font-heading text-titanium-white mb-2" style="font-size: var(--text-fluid-lg);">Full $500 mural credit</p>
            <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-xs);">Rolls 1:1 into a future mural. No expiration, no conditions</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════
         SECTION 2: CHOOSE THE WORDS
         Typographic specimens — the words ARE the visual.
         ═══════════════════════════════════════════ -->
    <section class="px-6 lg:px-12 mb-32 lg:mb-40">
      <div class="max-w-7xl mx-auto">

        <!-- Intro: narrow reading column -->
        <div class="max-w-2xl mb-14">
          <h2 class="font-heading text-titanium-white mb-6" style="font-size: var(--text-fluid-3xl);" data-animate="fade">
            Choose the words people remember.
          </h2>
          <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);" data-animate="fade" data-animate-delay="1">
            Your logo is the obvious pick. But a Brand Mark can also be your neighborhood, your family name, your service, your motto, or a phrase your customers already connect with your place.
          </p>
        </div>

        <!-- Typographic specimens. Full-width — the words take the stage. -->
        <div class="divide-y divide-slate-gray border-y border-slate-gray mb-12" data-animate="fade" data-animate-delay="1">
          <div class="grid grid-cols-12 gap-6 py-8 lg:py-10 items-baseline">
            <p class="col-span-12 lg:col-span-2 font-mono text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">Your neighborhood</p>
            <p class="col-span-12 lg:col-span-10 font-heading italic text-titanium-white" style="font-size: var(--text-fluid-3xl); line-height: 1.05;">
              Scott&rsquo;s Addition.<span class="text-soft-gray"> Church Hill. Manchester Born.</span>
            </p>
          </div>
          <div class="grid grid-cols-12 gap-6 py-8 lg:py-10 items-baseline">
            <p class="col-span-12 lg:col-span-2 font-mono text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">Your craft</p>
            <p class="col-span-12 lg:col-span-10 font-heading text-titanium-white" style="font-size: var(--text-fluid-3xl); line-height: 1.05;">
              Fresh Bread Daily.<span class="text-soft-gray"> Sharp Cuts. Cold Beer.</span>
            </p>
          </div>
          <div class="grid grid-cols-12 gap-6 py-8 lg:py-10 items-baseline">
            <p class="col-span-12 lg:col-span-2 font-mono text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">Your values</p>
            <p class="col-span-12 lg:col-span-10 font-heading text-titanium-white" style="font-size: var(--text-fluid-3xl); line-height: 1.05;">
              Honest Craft.<span class="text-soft-gray"> Family Owned. Quality First.</span>
            </p>
          </div>
          <div class="grid grid-cols-12 gap-6 py-8 lg:py-10 items-baseline">
            <p class="col-span-12 lg:col-span-2 font-mono text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">Your roots</p>
            <p class="col-span-12 lg:col-span-10 font-heading text-titanium-white" style="font-size: var(--text-fluid-3xl); line-height: 1.05;">
              Est. 2019.<span class="text-soft-gray"> The Original. Bennett &amp; Sons.</span>
            </p>
          </div>
          <div class="grid grid-cols-12 gap-6 py-8 lg:py-10 items-baseline">
            <p class="col-span-12 lg:col-span-2 font-mono text-smoke-gray uppercase" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">A rhythm</p>
            <p class="col-span-12 lg:col-span-10 font-heading text-titanium-white" style="font-size: var(--text-fluid-3xl); line-height: 1.05;">
              Eat. Drink. Relax.<span class="text-soft-gray"> Design. Build. Last.</span>
            </p>
          </div>
        </div>

        <!-- Closing note: desktop split with image -->
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center" data-animate="fade">
          <p class="font-body italic text-soft-gray" style="font-size: var(--text-fluid-lg); line-height: var(--leading-relaxed);">
            Just a word that means something to you and the people who walk through your door.
            <span class="block mt-4 not-italic font-body text-smoke-gray" style="font-size: var(--text-fluid-base);">Not sure what belongs on the wall yet? That is what the 15-minute Brand Session is for.</span>
          </p>
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src="/images/projects/carytown-monarch/hand-painted-detail.jpg"
              alt="Close detail of hand-painted lettering"
              class="w-full h-full object-cover"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECTION 3: PROBLEM + THREE OPTIONS
         ═══════════════════════════════════════════ -->
    <section class="px-6 lg:px-12 mb-32 lg:mb-40">
      <div class="max-w-7xl mx-auto">

        <!-- Problem intro -->
        <div class="max-w-5xl mx-auto mb-16">
          <h2 class="font-heading text-titanium-white mb-10 text-balance" style="font-size: var(--text-fluid-3xl); line-height: 1.15;" data-animate="fade">
            Your space works. It just does not say enough yet.
          </h2>

          <div class="font-body text-soft-gray space-y-5 max-w-2xl" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);" data-animate="fade" data-animate-delay="1">
            <p>You already have the functional stuff. The sign out front. The menu boards. The decals. What they have in common: they were ordered from a template or printed from a catalog. Not made for you. What you do not have is an original. A piece made for your business and nobody else's.</p>
            <p>That gap has a cost. You can do excellent work inside and still lose people at the door. Another month with the catalog-sign look and your space keeps communicating the same thing: temporary, generic, like everything else on the block.</p>
            <p>The Brand Mark fixes that. Your words, painted by hand on wood, finished to fit your space, and hung on your wall the same week. It gives people the feeling that this place has been here. That it belongs here. That a real person runs it.</p>
          </div>
        </div>

        <!-- Full-bleed image break: what "established" looks like -->
        <div class="-mx-6 lg:-mx-12 mb-20" data-animate="fade">
          <img
            src="/images/projects/trolley-barn/sign-context.jpg"
            alt="Hand-painted sign installed in context"
            class="w-full object-cover"
            style="height: clamp(200px, 40vw, 520px);"
            loading="lazy"
            width="1920"
            height="760"
          />
        </div>

        <!-- Options comparison container -->
        <div class="max-w-3xl mx-auto">

          <!-- Transition into the options comparison -->
          <div class="mb-12 max-w-2xl" data-animate="fade">
            <h3 class="font-heading text-titanium-white mb-4 text-balance" style="font-size: var(--text-fluid-2xl); line-height: 1.15;">
              Not every wall needs a mural. But some walls need more than a print.
            </h3>
            <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
              A vinyl print is a copy. A full mural is a larger commission. The Brand Mark gives you a hand-painted original that goes up fast, carries real presence, and still rolls into a future mural when you are ready.
            </p>
          </div>

          <!-- Options ladder: scale-contrast, not repeating cards. -->
          <div class="mb-12" data-animate="fade" data-animate-delay="2">
            <p class="font-mono text-smoke-gray uppercase mb-8" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">Your options</p>

            <!-- Option 01: vinyl — shown small, dim, apologetic -->
            <div class="flex items-baseline gap-6 mb-3 opacity-50">
              <span class="font-mono text-smoke-gray shrink-0" style="font-size: var(--text-fluid-xs);">01</span>
              <div class="flex-1">
                <p class="font-heading text-soft-gray mb-1" style="font-size: var(--text-fluid-base);">$200 vinyl print</p>
                <p class="font-body text-smoke-gray" style="font-size: var(--text-fluid-sm); line-height: var(--leading-relaxed);">Peels in 3 years. Replace it 3 times over a decade and you&rsquo;ve spent $600+ on something that looks worse every year. Looks like a catalog print because it is one.</p>
              </div>
            </div>

            <!-- Option 02: Brand Mark — the protagonist. Breaks the frame. -->
            <div class="relative my-10 py-10 border-y-2 border-titanium-white">
              <span class="absolute -top-3 left-0 font-mono text-titanium-white bg-bone-black pr-3 uppercase" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                02 &mdash; This one
              </span>
              <p class="font-heading text-titanium-white mb-3 text-balance" style="font-size: var(--text-fluid-3xl); line-height: 1.05;">
                The $500 Brand Mark.<br />
                <span class="italic text-soft-gray">A hand-painted original.</span>
              </p>
              <p class="font-body text-soft-gray max-w-xl" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
                On your wall this week. Lasts 20+ years. $25 per year over its lifetime. The full $500 rolls into a future mural.
              </p>
              <div class="mt-6 flex flex-wrap gap-x-8 gap-y-2 font-mono uppercase text-smoke-gray" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                <span>Hand-painted</span>
                <span aria-hidden="true">&bull;</span>
                <span>Wood panel</span>
                <span aria-hidden="true">&bull;</span>
                <span>5 business days</span>
                <span aria-hidden="true">&bull;</span>
                <span>Rolls into mural</span>
              </div>
            </div>

            <!-- Option 03: mural — shown small/distant, "not yet" -->
            <div class="flex items-baseline gap-6 opacity-50">
              <span class="font-mono text-smoke-gray shrink-0" style="font-size: var(--text-fluid-xs);">03</span>
              <div class="flex-1">
                <p class="font-heading text-soft-gray mb-1" style="font-size: var(--text-fluid-base);">$5,000+ full mural</p>
                <p class="font-body text-smoke-gray" style="font-size: var(--text-fluid-sm); line-height: var(--leading-relaxed);">Months to scope, weeks to paint. Right project for the right wall. Not always what you need right now.</p>
              </div>
            </div>
          </div>

          <ComparisonBar
            title="Lifetime Cost Comparison"
            items={[
              { label: 'Brand Mark (hand-painted, 20+ year life)', value: '$500', percent: 25, highlight: true },
              { label: 'Vinyl prints (replaced 3x over 12 years)', value: '$600+', percent: 30 },
              { label: 'Custom sign shop', value: '$2,000+', percent: 100 },
            ]}
            class="mb-8"
            data-animate="fade"
          />

          <p class="font-body text-smoke-gray mb-2" style="font-size: var(--text-fluid-xs);" data-animate="fade">
            The vinyl costs more and looks worse every year it's up there.
          </p>
          <div class="mt-6" data-animate="fade">
            <a
              href="/journal/hand-painted-vs-vinyl"
              class="font-sans inline-block border border-slate-gray text-smoke-gray px-8 py-4 text-sm font-medium tracking-[0.15em] uppercase min-h-[44px] hover:border-titanium-white hover:text-titanium-white transition-colors duration-200"
            >
              Read: Hand-Painted vs. Vinyl &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SECTION 4: HOW IT WORKS
         Editorial step layout: number / text / image per step
         ═══════════════════════════════════════════ -->
    <section id="how-it-works" class="bg-midnight-graphite border-y border-slate-gray py-28 lg:py-40 px-6 lg:px-12 mb-32 lg:mb-40">
      <div class="max-w-7xl mx-auto">

        <!-- Section header -->
        <div class="mb-20 lg:mb-24 max-w-2xl">
          <p class="font-mono text-smoke-gray uppercase mb-6" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);" data-animate="fade">
            How It Works
          </p>

          <h2 class="font-heading text-titanium-white mb-8" style="font-size: var(--text-fluid-3xl);" data-animate="fade">
            3 steps. Same week. Done.
          </h2>

          <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);" data-animate="fade">
            If you want something hand-painted but aren't ready for a full mural, this is where to start. Spencer Bennett hand-paints signs and murals in Richmond. The Brand Mark is the entry point: one piece, your words, on your wall in 5 business days. See the work: <a href="https://www.instagram.com/untitledmixedmedia/" target="_blank" rel="noopener noreferrer" class="text-titanium-white underline hover:no-underline">@untitledmixedmedia</a>.
          </p>
        </div>

        <!-- Steps — desktop: text left 7 cols, image right 5 cols -->
        <div class="space-y-20 lg:space-y-28">

          <!-- Step 01 -->
          <div class="grid lg:grid-cols-12 lg:gap-16 lg:items-start" data-animate="fade">
            <div class="lg:col-span-7 mb-8 lg:mb-0">
              <span class="font-heading text-slate-gray block mb-3" style="font-size: var(--text-fluid-4xl); line-height: var(--leading-solid);" aria-hidden="true">01</span>
              <h3 class="font-heading text-titanium-white mb-4" style="font-size: var(--text-fluid-xl);">The 15-Minute Brand Session.</h3>
              <p class="font-body text-soft-gray mb-6" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
                We meet in person or by phone. I learn your space, your brand, and what you want people to feel when they walk in. One conversation. Then I lock in your week and start.
              </p>
              <div class="space-y-3 pl-5 border-l border-slate-gray">
                <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-sm);"><span class="text-titanium-white">Feel:</span> The one impression you want people to leave with.</p>
                <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-sm);"><span class="text-titanium-white">Words:</span> 1&ndash;3 words chosen from proven options so you're never stuck.</p>
                <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-sm);"><span class="text-titanium-white">Finish:</span> Somewhere on the scale from sharp and modern to fully aged ghost-sign, matched to your space.</p>
              </div>
            </div>
            <figure class="lg:col-span-5">
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src="/images/process-visit.jpg"
                  alt="Site visit — reading the wall before a single stroke is planned"
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width="800"
                  height="600"
                />
              </div>
              <figcaption class="font-mono text-smoke-gray uppercase mt-2" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
                The visit comes first.
              </figcaption>
            </figure>
          </div>

          <!-- Step 02 -->
          <div class="grid lg:grid-cols-12 lg:gap-16 lg:items-start" data-animate="fade" data-animate-delay="1">
            <div class="lg:col-span-7 mb-8 lg:mb-0">
              <span class="font-heading text-slate-gray block mb-3" style="font-size: var(--text-fluid-4xl); line-height: var(--leading-solid);" aria-hidden="true">02</span>
              <h3 class="font-heading text-titanium-white mb-4" style="font-size: var(--text-fluid-xl);">I build and paint it in my studio.</h3>
              <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-base); line-height: var(--leading-relaxed);">
                $250 holds your spot. I design the layout, build the panel, hand-paint your words, apply the weathering, and seal everything with the Surface Shield topcoat. No supplies for you to buy. No prep work. No disruption to your business.
              </p>
            </div>
            <figure class="lg:col-span-5">
              <div class="aspect-[4/3] overflow-hidden">
                <img
