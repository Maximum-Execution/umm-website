---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import Button from '../../components/Button.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import WorkCaption from '../../components/WorkCaption.astro';
import PageHero from '../../components/patterns/PageHero.astro';

const projects = (await getCollection('projects'))
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Work | Hand-Painted Murals & Signs | Untitled Mixed Media"
  description="Hand-painted murals and signs in Richmond, Virginia. Every project starts with questions about the building, the business, and what people should notice."
  breadcrumbItems={[
    { name: 'Home', url: '/' },
    { name: 'Work' }
  ]}
>
  <Nav />
  <main id="main-content">
    <div class="px-6 lg:px-12 max-w-7xl mx-auto">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Work' },
      ]} />
    </div>

    <!-- Hero headline -->
    <PageHero
      sectionNum="01"
      eyebrow="Selected work / 2019\u20132026"
      headline="Hand-painted murals and signs in Richmond, Virginia."
      subline="Every project below started with questions about the building, the business, and what the people who walk past it should notice."
      hudRight="Portfolio index"
      hudFootLeft="Selected commissions / Richmond, VA"
    />

    <!-- Featured Projects -->
    <section class="px-6 lg:px-12 max-w-7xl mx-auto pb-24">
      <h2 class="sr-only">Featured Projects</h2>
      <SectionLabel num="01" name="Featured Projects" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {projects.map((project, i) => (
          <a
            href={`/work/${project.id}`}
            class:list={[
              'group relative block overflow-hidden',
              i === 0 ? 'md:col-span-2 aspect-[21/9]' : 'aspect-[4/3]'
            ]}
            data-animate
            data-animate-delay={String(Math.min(i + 1, 5))}
          >
            <img
              src={project.data.cover}
              alt={project.data.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-bone-black/80 via-bone-black/20 to-transparent" />
            <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-8">
              <WorkCaption
                title={project.data.title}
                place={project.data.location}
                medium={project.data.materials}
              />
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Category Sections -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-0">
      <!-- Murals -->
      <a href="/murals" class="group relative block aspect-[4/3] overflow-hidden" data-animate>
        <img
          src="/images/projects/trolley-barn/finished-full.jpg"
          alt="Hand-painted exterior mural on a commercial building in Richmond, Virginia"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-bone-black/50 group-hover:bg-bone-black/40 transition-colors" />
        <div class="absolute inset-0 flex flex-col justify-end p-8 lg:p-12">
          <h2 class="font-heading text-titanium-white mb-2" style="font-size: var(--text-fluid-3xl);">
            Murals
          </h2>
          <p class="font-body text-soft-gray mb-4 max-w-md" style="font-size: var(--text-fluid-base);">
            Not a template. Not someone else's portfolio on your wall. A mural built from your story, painted by hand, that belongs to your building and nobody else's. Starting at $15/sqft.
          </p>
          <span class="font-sans text-titanium-white text-sm tracking-[0.15em] uppercase">
            Explore &rarr;
          </span>
        </div>
      </a>

      <!-- Hand-Painted Signs -->
      <a href="/hand-painted-signs" class="group relative block aspect-[4/3] overflow-hidden" data-animate>
        <img
          src="/images/signs/signs-cover.jpg"
          alt="Hand-painted storefront sign lettering in Richmond, Virginia"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-bone-black/50 group-hover:bg-bone-black/40 transition-colors" />
        <div class="absolute inset-0 flex flex-col justify-end p-8 lg:p-12">
          <h2 class="font-heading text-titanium-white mb-2" style="font-size: var(--text-fluid-3xl);">
            Hand-Painted Signs
          </h2>
          <p class="font-body text-soft-gray mb-4 max-w-md" style="font-size: var(--text-fluid-base);">
            Storefront signs and historic sign restorations, hand-painted to last 20+ years. Your name on your building, made by hand. Starting at $500 with The Brand Mark.
          </p>
          <span class="font-sans text-titanium-white text-sm tracking-[0.15em] uppercase">
            Explore &rarr;
          </span>
        </div>
      </a>
    </section>

    <!-- Brand Mark Callout -->
    <section class="px-6 lg:px-12 py-20 bg-midnight-graphite" data-animate>
      <div class="max-w-7xl mx-auto text-center">
        <p class="font-mono text-soft-gray uppercase mb-4" style="font-size: var(--text-fluid-xs); letter-spacing: var(--tracking-wider);">
          Starting at $500
        </p>
        <h2 class="font-heading text-titanium-white mb-4" style="font-size: var(--text-fluid-2xl);">
          Your words, hand-painted on wood. On your wall this week.
        </h2>
        <div class="space-y-4 mb-8 max-w-xl mx-auto">
          <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-base);">
            Tell me what you want painted: your logo, your name, a phrase that matters to your business. I hand-paint it on a wood panel up to 16 square feet and finish it however you want. Brand new and clean. A little worn in. Or aged like it's been on that wall for 30 years. You pick.
          </p>
          <p class="font-body text-soft-gray" style="font-size: var(--text-fluid-base);">
            Your $500 includes the panel, professional installation, a protective topcoat, a touch-up kit with your exact paint, and $500 in credit toward any future mural or sign project. If you don't love the finished piece, I take it home. You owe nothing.
          </p>
        </div>
        <Button href="/brand-mark" variant="secondary" size="default">
          Claim Your Brand Mark
        </Button>
      </div>
    </section>

    <CTABlock />
  </main>
  <Footer />
</BaseLayout>
